{% extends 'base.html.twig' %}

{% block title %}Shop Management - Admin Dashboard{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700;800&display=swap');

        .dashboard-page {
            min-height: 100vh;
            background:
                radial-gradient(700px 280px at 10% -5%, rgba(11, 164, 161, 0.22), transparent 70%),
                radial-gradient(900px 360px at 95% 0%, rgba(11, 122, 176, 0.18), transparent 72%),
                #e9eff5;
            font-family: 'Sora', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: #213142;
        }

        .dashboard-top {
            height: 86px;
            background: #ffffff;
            border-bottom: 1px solid #e6ebf0;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 28px;
            position: sticky;
            top: 0;
            z-index: 20;
        }

        .back-main-btn {
            border: 2px solid #0BA4A1;
            color: #0BA4A1;
            background: #f4fffe;
            border-radius: 999px;
            padding: 10px 18px;
            font-weight: 700;
            text-decoration: none;
            box-shadow: 0 4px 10px rgba(11, 164, 161, 0.18);
        }

        .top-logo {
            height: 40px;
            width: auto;
        }

        .top-logo img {
            height: 100%;
            width: auto;
            object-fit: contain;
        }

        .dashboard-layout {
            display: grid;
            grid-template-columns: 260px minmax(0, 1fr);
            min-height: calc(100vh - 86px);
        }

        .dash-sidebar {
            background: #2f445a;
            color: #fff;
            padding: 28px 14px;
        }

        .admin-avatar {
            width: 84px;
            height: 84px;
            border-radius: 50%;
            display: grid;
            place-items: center;
            background: #e5e9ef;
            color: #2f445a;
            font-size: 28px;
            font-weight: 800;
            margin: 0 auto 14px;
            border: 4px solid rgba(255, 255, 255, 0.25);
            overflow: hidden;
        }

        .admin-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .admin-name {
            text-align: center;
            font-size: 32px;
            line-height: 1;
            margin-bottom: 4px;
            color: #ffffff;
        }

        .admin-role {
            text-align: center;
            color: #FCBE31;
            font-weight: 800;
            margin-bottom: 26px;
        }

        .sidebar-link {
            display: block;
            color: #d9e4ef;
            text-decoration: none;
            border-radius: 10px;
            padding: 10px 12px;
            margin-bottom: 8px;
            font-size: 14px;
        }

        .sidebar-link.active {
            background: #d8f4f2;
            color: #0BA4A1;
            font-weight: 700;
        }

        .admin-content {
            padding: 24px;
        }

        .hero {
            background: linear-gradient(120deg, #ffffff 0%, #f7fbff 65%, #eef7ff 100%);
            border-radius: 18px;
            border: 1px solid #d9e6f1;
            box-shadow: 0 10px 24px rgba(16, 48, 76, 0.09);
            padding: 18px 20px;
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 14px;
        }

        .hero h1 {
            margin: 0;
            font-size: 34px;
            color: #194575;
            letter-spacing: -0.6px;
        }

        .hero p {
            margin: 6px 0 0;
            color: #5d7792;
            font-size: 13px;
            font-weight: 500;
        }

        .hero-stats {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }

        .hero-chip {
            min-width: 120px;
            border-radius: 12px;
            border: 1px solid #d5e4ef;
            background: #ffffff;
            padding: 9px 12px;
            box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.7);
        }

        .hero-chip small {
            display: block;
            color: #67829d;
            font-size: 10px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .hero-chip strong {
            font-size: 22px;
            color: #0f4f7a;
        }

        .view-section {
            display: none;
        }

        .view-section.active {
            display: block;
        }

        .single-view-panel {
            max-width: 100%;
        }

        .add-product-card {
            position: relative;
            overflow: hidden;
            border: 1px solid #bfd6e8;
            background:
                radial-gradient(420px 200px at 100% 0%, rgba(11, 122, 176, 0.14), transparent 72%),
                linear-gradient(150deg, #ffffff 0%, #eef8ff 100%);
        }

        .add-product-card::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(180deg, rgba(11, 164, 161, 0.08) 0%, rgba(11, 164, 161, 0) 45%);
            pointer-events: none;
        }

        .add-product-card > * {
            position: relative;
            z-index: 1;
        }

        .form-card-head {
            margin: -20px -20px 14px;
            padding: 16px 20px;
            background: linear-gradient(120deg, #0d5e8a 0%, #0b909f 100%);
            color: #ffffff;
            border-radius: 16px 16px 12px 12px;
        }

        .form-card-head h2 {
            margin: 0;
            color: #ffffff;
            font-size: 22px;
        }

        .form-card-head p {
            margin: 6px 0 0;
            font-size: 12px;
            color: rgba(255, 255, 255, 0.88);
        }

        .form-surface {
            border: 1px solid #d5e5f0;
            border-radius: 12px;
            background: rgba(255, 255, 255, 0.78);
            padding: 14px;
            box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.85);
        }

        .panel {
            background: linear-gradient(150deg, rgba(255, 255, 255, 0.95) 0%, rgba(244, 250, 255, 0.95) 100%);
            border: 1px solid #dce8f2;
            border-radius: 16px;
            box-shadow: 0 10px 22px rgba(10, 34, 62, 0.08);
            padding: 20px;
        }

        .panel h2 {
            margin: 0 0 12px;
            color: #194575;
            font-size: 24px;
            letter-spacing: -0.3px;
        }

        .flash {
            border-radius: 10px;
            padding: 10px 12px;
            margin-bottom: 10px;
            font-size: 13px;
            font-weight: 700;
        }

        .flash-success {
            background: #e7f9f3;
            color: #11885f;
            border: 1px solid #b8ebd7;
        }

        .flash-error {
            background: #fff1f1;
            color: #c43d3d;
            border: 1px solid #ffd3d3;
        }

        .shop-form {
            display: grid;
            gap: 12px;
        }

        .shop-form-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 12px;
        }

        .shop-form-grid .field.full {
            grid-column: 1 / -1;
        }

        .field {
            display: grid;
            gap: 6px;
        }

        .field label {
            color: #4e6378;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.8px;
        }

        .field input,
        .field textarea {
            border: 1px solid #cddae6;
            border-radius: 10px;
            padding: 11px 12px;
            font-size: 14px;
            font-family: inherit;
            background: #ffffff;
            transition: border-color 0.2s ease, box-shadow 0.2s ease;
        }

        .field textarea {
            min-height: 108px;
            resize: vertical;
        }

        .field input:focus,
        .field textarea:focus {
            outline: none;
            border-color: #0BA4A1;
            box-shadow: 0 0 0 3px rgba(11, 164, 161, 0.12);
        }

        .split {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
        }

        .submit-btn {
            border: 0;
            border-radius: 10px;
            padding: 12px 14px;
            color: #ffffff;
            background: linear-gradient(115deg, #156ca2 0%, #0e9b97 100%);
            font-weight: 700;
            cursor: pointer;
            box-shadow: 0 10px 22px rgba(11, 154, 157, 0.28);
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        .submit-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 14px 28px rgba(11, 154, 157, 0.36);
        }

        .products-card {
            border: 1px solid #d5e4ef;
            background:
                radial-gradient(420px 220px at 100% 0%, rgba(11, 122, 176, 0.08), transparent 70%),
                linear-gradient(150deg, rgba(255, 255, 255, 0.96) 0%, rgba(244, 250, 255, 0.96) 100%);
        }

        .view-actions {
            margin-top: 18px;
            padding-top: 14px;
            border-top: 1px solid #dbe7f1;
            display: flex;
            justify-content: center;
        }

        .switch-btn {
            border: 1px solid #b6d4e8;
            background: #edf7ff;
            color: #14517b;
            border-radius: 999px;
            padding: 10px 18px;
            font-weight: 700;
            font-family: inherit;
            cursor: pointer;
            transition: transform 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
        }

        .switch-btn:hover {
            background: #dff0ff;
            transform: translateY(-1px);
            box-shadow: 0 8px 16px rgba(20, 81, 123, 0.16);
        }

        .products-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
            margin-bottom: 8px;
        }

        .products-note {
            color: #5f7a95;
            font-size: 12px;
            margin-bottom: 14px;
        }

        .products-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
            gap: 16px;
        }

        .product-card {
            background: linear-gradient(165deg, #ffffff 0%, #f3faff 100%);
            border: 1px solid #dce8f2;
            border-radius: 14px;
            overflow: hidden;
            box-shadow: 0 8px 18px rgba(10, 34, 62, 0.08);
            transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
            display: flex;
            flex-direction: column;
            min-height: 290px;
        }

        .product-card:hover {
            transform: translateY(-4px);
            border-color: #b9d5e7;
            box-shadow: 0 14px 28px rgba(13, 42, 66, 0.14);
        }

        .product-media {
            height: 220px;
            display: flex;
            align-items: center;
            justify-content: center;
            background:
                linear-gradient(180deg, #f5fafe 0%, #ecf4fb 100%);
            border-bottom: 1px solid #dce8f2;
            padding: 10px;
        }

        .product-image {
            width: 100%;
            height: 100%;
            object-fit: contain;
            background: transparent;
        }

        .product-body {
            padding: 13px;
            display: flex;
            flex-direction: column;
            flex: 1;
        }

        .product-name {
            margin: 0;
            color: #1f3f62;
            font-size: 24px;
            line-height: 1.1;
            letter-spacing: -0.3px;
            max-width: 95%;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .product-description {
            margin-top: 7px;
            color: #6b8198;
            font-size: 13px;
            min-height: 33px;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .meta-row {
            margin-top: 8px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 8px;
        }

        .meta-row:last-child {
            margin-top: auto;
            padding-top: 10px;
            border-top: 1px dashed #d6e3ef;
        }

        .chip {
            display: inline-block;
            border-radius: 999px;
            border: 1px solid #d8e4ef;
            background: #f1f7fc;
            color: #4d6984;
            font-size: 11px;
            font-weight: 700;
            padding: 4px 8px;
            max-width: 120px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .price {
            color: #0BA4A1;
            font-weight: 800;
            font-size: 26px;
        }

        .qty {
            color: #4f6478;
            font-size: 12px;
            font-weight: 700;
        }

        .product-id {
            font-size: 11px;
            color: #7e91a3;
        }

        .empty {
            border: 1px dashed #c8d7e4;
            border-radius: 12px;
            background: #f9fcff;
            color: #6f8398;
            padding: 22px;
            text-align: center;
            font-style: italic;
        }

        @media (max-width: 1024px) {
            .dashboard-layout {
                grid-template-columns: 1fr;
            }

            .dash-sidebar {
                display: none;
            }

            .admin-content {
                padding: 16px;
            }

            .hero h1 {
                font-size: 28px;
            }

            .hero-chip {
                min-width: 100px;
            }
        }

        @media (max-width: 760px) {
            .shop-form-grid {
                grid-template-columns: 1fr;
            }

            .split {
                grid-template-columns: 1fr;
            }

            .products-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
{% endblock %}

{% block body %}
    <div class="dashboard-page">
        <div class="dashboard-top">
            <a class="back-main-btn" href="{{ path('app_mainpage') }}">← Back to Main Page</a>
            <div class="top-logo">
                <img src="{{ asset('images/logo.png') }}" alt="Rehletna.tn" title="Rehletna.tn" />
            </div>
        </div>

        <div class="dashboard-layout">
            <aside class="dash-sidebar">
                <div class="admin-avatar">
                    {% if adminImageUrl is defined and adminImageUrl %}
                        <img src="{{ adminImageUrl }}" alt="{{ app.user.username }}" />
                    {% else %}
                        {{ app.user.username|first|upper }}
                    {% endif %}
                </div>
                <div class="admin-name">{{ app.user.username }}</div>
                <div class="admin-role">ADMIN</div>

                <a href="{{ path('app_dashboard') }}" class="sidebar-link">Dashboard</a>
                <a href="{{ path('app_users') }}" class="sidebar-link">Users</a>
                <a href="{{ path('app_todos') }}" class="sidebar-link">Todo List</a>
                <a href="{{ path('app_admin_stats') }}" class="sidebar-link">Statistics</a>
                <a href="{{ path('app_admin_shop') }}" class="sidebar-link active">Shop</a>
                <a href="{{ path('app_logout') }}" class="sidebar-link" style="color: #ff9aa5; margin-top: 30px;">Logout</a>
            </aside>

            <main class="admin-content">
                {% set productCount = products|length %}
                {% set stockCount = 0 %}
                {% for product in products %}
                    {% set stockCount = stockCount + (product.quantity|default(0)) %}
                {% endfor %}

                <section class="hero">
                    <div>
                        <h1>Shop Management</h1>
                        <p>Create products and manage your catalog in one place.</p>
                    </div>
                    <div class="hero-stats">
                        <div class="hero-chip">
                            <small>Products</small>
                            <strong>{{ productCount }}</strong>
                        </div>
                        <div class="hero-chip">
                            <small>Total Stock</small>
                            <strong>{{ stockCount }}</strong>
                        </div>
                    </div>
                </section>

                {% for label, messages in app.flashes %}
                    {% for message in messages %}
                        <div class="flash flash-{{ label == 'error' ? 'error' : 'success' }}">{{ message }}</div>
                    {% endfor %}
                {% endfor %}

                <section id="addProductView" class="view-section active">
                    <section class="panel add-product-card single-view-panel">
                        <div class="form-card-head">
                            <h2>Add Product</h2>
                            <p>Create a new shop item with details, stock, and image.</p>
                        </div>
                        <form method="post" enctype="multipart/form-data" class="shop-form">
                            <input type="hidden" name="_token" value="{{ csrf_token('shop-product-create') }}">

                            <div class="form-surface">
                                <div class="shop-form-grid">
                                    <div class="field full">
                                        <label for="name">Name</label>
                                        <input id="name" type="text" name="name" required>
                                    </div>

                                    <div class="field full">
                                        <label for="description">Description</label>
                                        <textarea id="description" name="description" rows="4"></textarea>
                                    </div>

                                    <div class="field">
                                        <label for="price_coins">Price (Coins)</label>
                                        <input id="price_coins" type="number" min="0" name="price_coins" value="0" required>
                                    </div>
                                    <div class="field">
                                        <label for="quantity">Quantity</label>
                                        <input id="quantity" type="number" min="0" name="quantity" value="0" required>
                                    </div>

                                    <div class="field full">
                                        <label for="category">Category</label>
                                        <input id="category" type="text" name="category" placeholder="Optional">
                                    </div>

                                    <div class="field full">
                                        <label for="image">Image</label>
                                        <input id="image" type="file" name="image" accept="image/*">
                                    </div>
                                </div>
                            </div>

                            <button type="submit" class="submit-btn">Add Product</button>
                        </form>
                        <div class="view-actions">
                            <button id="openProductsBtn" type="button" class="switch-btn">See Products</button>
                        </div>
                    </section>
                </section>

                <section id="productsView" class="view-section">
                    <section class="panel products-card single-view-panel">
                        <div class="products-header">
                            <h2>Products</h2>
                        </div>
                        <div class="products-note">Latest items appear first.</div>

                        {% if products is empty %}
                            <div class="empty">No products yet. Add your first one from the form.</div>
                        {% else %}
                            <div class="products-grid">
                                {% for product in products %}
                                    <article class="product-card">
                                        <div class="product-media">
                                            <img src="{{ product.image_url|default('/images/default_image.png') }}" alt="{{ product.name }}" class="product-image" />
                                        </div>
                                        <div class="product-body">
                                            <h3 class="product-name">{{ product.name }}</h3>
                                            {% if product.description %}
                                                <div class="product-description">{{ product.description }}</div>
                                            {% endif %}

                                            <div class="meta-row">
                                                <span class="chip">{{ product.category|default('Uncategorized') }}</span>
                                                <span class="price">{{ product.price_coins }} coins</span>
                                            </div>
                                            <div class="meta-row">
                                                <span class="qty">Qty: {{ product.quantity }}</span>
                                                <span class="product-id">#{{ product.id }}</span>
                                            </div>
                                        </div>
                                    </article>
                                {% endfor %}
                            </div>
                        {% endif %}
                        <div class="view-actions">
                            <button id="backToAddBtn" type="button" class="switch-btn">Back To Add Product</button>
                        </div>
                    </section>
                </section>
            </main>
        </div>
    </div>

    <script>
        (function () {
            const addView = document.getElementById('addProductView');
            const productsView = document.getElementById('productsView');
            const openProductsBtn = document.getElementById('openProductsBtn');
            const backToAddBtn = document.getElementById('backToAddBtn');

            if (!addView || !productsView || !openProductsBtn || !backToAddBtn) {
                return;
            }

            function showAddView() {
                addView.classList.add('active');
                productsView.classList.remove('active');
            }

            function showProductsView() {
                addView.classList.remove('active');
                productsView.classList.add('active');
            }

            openProductsBtn.addEventListener('click', showProductsView);
            backToAddBtn.addEventListener('click', showAddView);
        })();
    </script>
{% endblock %}
