<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Welcome!{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        <script>
            (function () {
                function getStoredTheme() {
                    return localStorage.getItem('theme') === 'dark' ? 'dark' : 'light';
                }

                function applyTheme(theme) {
                    var isDark = theme === 'dark';
                    document.documentElement.classList.toggle('dark-mode', isDark);
                    if (document.body) {
                        document.body.classList.toggle('dark-mode', isDark);
                    }
                }

                window.getStoredTheme = getStoredTheme;
                window.applyTheme = applyTheme;
                window.toggleTheme = function () {
                    var next = getStoredTheme() === 'dark' ? 'light' : 'dark';
                    localStorage.setItem('theme', next);
                    applyTheme(next);
                    window.dispatchEvent(new CustomEvent('themechange', { detail: { theme: next } }));
                    return next;
                };

                applyTheme(getStoredTheme());
                document.addEventListener('DOMContentLoaded', function () {
                    applyTheme(getStoredTheme());
                });
            })();
        </script>
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
        <style>
            html,
            body {
                margin: 0;
                padding: 0;
                min-height: 100%;
                border: 0;
                outline: 0;
                background: #f4f9ff;
                overflow-x: hidden;
            }

            html.dark-mode,
            html.dark-mode body {
                background: #121a27;
                color: #e8eef5;
            }

            html.dark-mode input,
            html.dark-mode textarea,
            html.dark-mode select,
            html.dark-mode button {
                color-scheme: dark;
            }

            .global-loader {
                position: fixed;
                inset: 0;
                display: none;
                align-items: center;
                justify-content: center;
                flex-direction: column;
                background: linear-gradient(140deg, rgba(4, 22, 38, 0.92), rgba(11, 69, 96, 0.9));
                z-index: 9999;
                color: #ffffff;
                text-align: center;
                padding: 24px;
            }

            .global-loader.active {
                display: flex;
            }

            .global-quick-toggle {
                position: fixed;
                top: 6px;
                left: 50%;
                transform: translateX(-50%);
                width: 156px;
                height: 34px;
                border-radius: 999px;
                border: 1px solid rgba(11, 164, 161, 0.4);
                background: rgba(255, 255, 255, 0.86);
                color: #1f3f5f;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                font-size: 13px;
                font-weight: 800;
                letter-spacing: 0.2px;
                white-space: nowrap;
                cursor: pointer;
                box-shadow: 0 8px 18px rgba(10, 46, 88, 0.18);
                z-index: 10003;
                transition: transform 0.2s ease, background-color 0.2s ease, box-shadow 0.2s ease, top 0.2s ease;
                backdrop-filter: blur(8px);
                user-select: none;
                touch-action: none;
            }

            .global-quick-toggle:hover {
                transform: translateX(-50%);
                background: #ffffff;
                color: #0b8e8b;
                border-color: rgba(11, 164, 161, 0.82);
                box-shadow: 0 0 12px rgba(45, 212, 191, 0.55), 0 0 26px rgba(56, 189, 248, 0.28);
            }

            .global-quick-toggle.dragging {
                transition: none;
            }

            .global-quick-badge {
                position: absolute;
                top: -5px;
                right: -7px;
                min-width: 16px;
                height: 16px;
                border-radius: 999px;
                background: #ff5e62;
                color: #fff;
                font-size: 10px;
                font-weight: 800;
                display: none;
                align-items: center;
                justify-content: center;
                padding: 0 4px;
                box-shadow: 0 4px 10px rgba(217, 74, 90, 0.4);
            }

            .global-quick-badge.show {
                display: inline-flex;
            }

            .global-glass-overlay {
                position: fixed;
                inset: 0;
                background: rgba(255, 255, 255, 0.16);
                backdrop-filter: blur(1px);
                opacity: 0;
                pointer-events: none;
                transition: opacity 0.25s ease;
                z-index: 10001;
            }

            .global-glass-overlay.open {
                opacity: 1;
                pointer-events: auto;
            }

            .global-glass-panel {
                position: fixed;
                inset: 0;
                width: 100vw;
                height: 100vh;
                border-radius: 0;
                border: 1px solid rgba(163, 208, 232, 0.55);
                background:
                    linear-gradient(140deg, rgba(255, 255, 255, 0.62), rgba(238, 248, 255, 0.46)),
                    radial-gradient(420px 220px at 10% -10%, rgba(11, 164, 161, 0.12), transparent 72%);
                box-shadow: 0 10px 24px rgba(8, 35, 66, 0.14);
                backdrop-filter: blur(6px);
                transform: translateY(-105%);
                opacity: 0;
                transition: transform 0.28s ease, opacity 0.22s ease;
                z-index: 10002;
                overflow: auto;
            }

            .global-glass-panel.open {
                transform: translateY(0);
                opacity: 1;
            }

            .global-glass-head {
                display: flex;
                align-items: center;
                justify-content: space-between;
                padding: 22px 22px 16px;
                border-bottom: 1px solid rgba(167, 202, 228, 0.5);
            }

            .global-glass-brand {
                font-weight: 800;
                color: #194575;
                letter-spacing: -0.3px;
                font-size: 16px;
            }

            .global-glass-close {
                border: 0;
                width: 30px;
                height: 30px;
                border-radius: 999px;
                background: rgba(25, 69, 117, 0.1);
                color: #194575;
                cursor: pointer;
                font-size: 16px;
            }

            .global-glass-actions {
                padding: 22px;
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
                gap: 14px;
                max-width: 760px;
            }

            .global-action-btn,
            .global-action-link {
                border: 1px solid rgba(152, 189, 216, 0.6);
                background: rgba(255, 255, 255, 0.88);
                color: #1e456e;
                border-radius: 12px;
                min-height: 72px;
                display: flex;
                flex-direction: column;
                justify-content: center;
                align-items: center;
                gap: 6px;
                text-decoration: none;
                font-weight: 700;
                font-size: 12px;
                cursor: pointer;
                transition: transform 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease, background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
            }

            .global-action-btn:hover,
            .global-action-link:hover {
                transform: translateY(-1px);
                background: linear-gradient(135deg, rgba(242, 248, 255, 0.98), rgba(231, 243, 255, 0.96));
                color: #0b8e8b;
                border-color: rgba(88, 154, 209, 0.45);
                box-shadow: 0 0 12px rgba(45, 212, 191, 0.48), 0 0 24px rgba(56, 189, 248, 0.24);
            }

            .global-action-icon {
                font-size: 20px;
                line-height: 1;
            }

            .global-action-link.power {
                border-color: rgba(220, 109, 109, 0.45);
                color: #b84848;
                background: rgba(255, 242, 242, 0.9);
            }

            .global-action-link.upgrade {
                border-color: rgba(212, 175, 55, 0.45);
                color: #c19a3f;
                background: rgba(255, 248, 235, 0.95);
                background: linear-gradient(135deg, rgba(255, 248, 235, 0.95), rgba(254, 242, 220, 0.9));
            }

            .global-action-link.upgrade:hover {
                background: linear-gradient(135deg, rgba(255, 250, 240, 1), rgba(254, 245, 230, 1));
            }

            .global-action-link.settings,
            .global-action-btn.settings,
            .global-action-language.settings {
                border-color: rgba(152, 189, 216, 0.6);
                background: rgba(255, 255, 255, 0.88);
                color: #1e456e;
            }

            .global-action-link.settings:hover,
            .global-action-btn.settings:hover,
            .global-action-language.settings:hover {
                background: linear-gradient(135deg, rgba(242, 248, 255, 0.98), rgba(231, 243, 255, 0.96));
                color: #0b8e8b;
                border-color: rgba(88, 154, 209, 0.45);
                box-shadow: 0 0 12px rgba(45, 212, 191, 0.48), 0 0 24px rgba(56, 189, 248, 0.24);
            }

            .global-action-language {
                align-items: flex-start;
                text-align: left;
                padding: 12px 14px;
                gap: 8px;
                flex-direction: column;
            }

            .global-language-title {
                font-size: 12px;
                font-weight: 800;
                color: #1e456e;
                display: block;
                margin-bottom: 8px;
            }

            .global-language-select {
                width: 100%;
                padding: 8px 10px;
                font-size: 12px;
                font-weight: 700;
                color: #1e456e;
                border: 1px solid rgba(152, 189, 216, 0.7);
                border-radius: 8px;
                background: rgba(255, 255, 255, 0.95);
                cursor: pointer;
                transition: all 0.3s ease;
            }

            .global-language-select:hover {
                border-color: rgba(11, 164, 161, 0.85);
                background: rgba(255, 255, 255, 1);
            }

            .global-language-select:focus {
                outline: none;
                border-color: rgba(11, 164, 161, 0.85);
                background: rgba(11, 164, 161, 0.08);
                box-shadow: 0 0 0 2px rgba(11, 164, 161, 0.2);
            }

            .global-action-coin {
                align-items: flex-start;
                text-align: left;
                padding: 12px 14px;
            }

            .global-coin-head {
                display: flex;
                align-items: center;
                justify-content: space-between;
                width: 100%;
                margin-bottom: 6px;
            }

            .global-coin-count {
                font-size: 26px;
                font-weight: 800;
                color: #0d5e8a;
                line-height: 1;
            }

            .global-coin-tier {
                font-size: 11px;
                color: #5b7894;
                font-weight: 700;
                text-transform: uppercase;
            }

            .global-coin-timer {
                font-size: 12px;
                color: #516b84;
                margin-bottom: 8px;
            }

            /* Collect coin button loading line */
            #globalCollectCoinBtn {
                position: relative;
                overflow: hidden;
                --coin-button-progress: 0%;
            }

            #globalCollectCoinBtn::before {
                content: '';
                position: absolute;
                bottom: 0;
                left: 0;
                height: 3px;
                width: var(--coin-button-progress, 0%);
                background: linear-gradient(90deg, #ff6b6b, #ff9f44);
                transition: width 1s linear;
                border-radius: 999px;
            }

            .global-coin-btn {
                border: 0;
                border-radius: 10px;
                padding: 8px 12px;
                font-size: 12px;
                font-weight: 800;
                color: #ffffff;
                background: linear-gradient(135deg, #0fa5a2, #1788b6);
                cursor: pointer;
            }

            .global-coin-btn:disabled {
                cursor: not-allowed;
                opacity: 0.65;
            }

            /* Ready state for coin collection button */
            #globalCollectCoinBtn:not(:disabled)::before {
                width: 100%;
                background: linear-gradient(90deg, #51cf66, #37b24d);
            }

            #globalCollectCoinBtn:disabled {
                background: rgba(255, 255, 255, 0.65);
            }

            #globalCollectCoinBtn:not(:disabled) {
                background: rgba(255, 255, 255, 1);
                box-shadow: 0 6px 16px rgba(49, 245, 196, 0.25);
            }

            html.dark-mode .global-quick-toggle {
                background: rgba(30, 41, 59, 0.95);
                border-color: rgba(94, 234, 212, 0.45);
                color: #e2e8f0;
                box-shadow: 0 8px 18px rgba(0, 0, 0, 0.35);
            }

            html.dark-mode .global-quick-toggle:hover {
                color: #7ff0ff;
                border-color: rgba(94, 234, 212, 0.85);
                box-shadow: 0 0 12px rgba(94, 234, 212, 0.58), 0 0 26px rgba(56, 189, 248, 0.28);
            }

            html.dark-mode .global-glass-panel {
                border-color: rgba(72, 105, 138, 0.55);
                background:
                    linear-gradient(140deg, rgba(22, 33, 50, 0.6), rgba(18, 28, 43, 0.5)),
                    radial-gradient(300px 140px at 10% -20%, rgba(45, 212, 191, 0.1), transparent 70%);
                box-shadow: 0 14px 28px rgba(0, 0, 0, 0.28);
            }

            html.dark-mode .global-glass-head {
                border-bottom-color: rgba(72, 105, 138, 0.55);
            }

            html.dark-mode .global-glass-brand,
            html.dark-mode .global-glass-close {
                color: #dbe8f6;
            }

            html.dark-mode .global-glass-close {
                background: rgba(157, 196, 230, 0.12);
            }

            html.dark-mode .global-action-btn,
            html.dark-mode .global-action-link {
                border-color: rgba(66, 95, 125, 0.75);
                background: rgba(20, 33, 48, 0.86);
                color: #d0e0f0;
            }

            html.dark-mode .global-action-btn:hover,
            html.dark-mode .global-action-link:hover {
                background: #ffffff;
                color: #12385f;
                border-color: rgba(170, 191, 214, 0.9);
                box-shadow: 0 8px 20px rgba(5, 21, 40, 0.25);
            }

            html.dark-mode .global-action-btn:hover .global-action-icon,
            html.dark-mode .global-action-link:hover .global-action-icon {
                color: #12385f;
            }

            html.dark-mode .global-action-link.power {
                border-color: rgba(194, 92, 92, 0.55);
                background: rgba(60, 24, 24, 0.74);
                color: #ffb6b6;
            }

            html.dark-mode .global-action-link.upgrade {
                border-color: rgba(158, 117, 39, 0.55);
                background: rgba(60, 50, 24, 0.74);
                color: #ffd699;
            }

            html.dark-mode .global-action-link.upgrade:hover {
                background: rgba(70, 60, 30, 0.9);
            }

            html.dark-mode .global-action-link.settings,
            html.dark-mode .global-action-btn.settings,
            html.dark-mode .global-action-language.settings {
                border-color: rgba(66, 95, 125, 0.75);
                background: rgba(20, 33, 48, 0.92);
                color: #7dd3fc;
            }

            html.dark-mode .global-action-link.settings:hover,
            html.dark-mode .global-action-btn.settings:hover,
            html.dark-mode .global-action-language.settings:hover {
                background: #ffffff;
                color: #12385f;
                border-color: rgba(170, 191, 214, 0.9);
                box-shadow: 0 8px 20px rgba(5, 21, 40, 0.25);
            }

            html.dark-mode .global-action-link.settings .global-action-icon,
            html.dark-mode .global-action-btn.settings .global-action-icon,
            html.dark-mode .global-language-title {
                color: #7dd3fc;
            }

            html.dark-mode .global-action-language:hover .global-language-title {
                color: #12385f;
            }

            html.dark-mode .global-language-select {
                border-color: rgba(66, 95, 125, 0.75);
                background: rgba(11, 20, 31, 0.9);
                color: #d0e0f0;
            }

            html.dark-mode .global-language-select:hover {
                border-color: rgba(94, 234, 212, 0.5);
                background: rgba(11, 20, 31, 1);
            }

            html.dark-mode .global-language-select:focus {
                border-color: rgba(94, 234, 212, 0.7);
                background: rgba(11, 20, 31, 0.95);
                box-shadow: 0 0 0 2px rgba(94, 234, 212, 0.2);
            }

            html.dark-mode .global-language-select option {
                background: #1a2a3a;
                color: #d0e0f0;
            }

            html.dark-mode .global-language-option.active {
                border-color: rgba(45, 212, 191, 0.65);
                background: rgba(45, 212, 191, 0.14);
                color: #7de2d6;
            }

            html.dark-mode .global-action-coin {
                background: rgba(20, 33, 48, 0.92);
            }

            html.dark-mode .global-coin-count {
                color: #7dd3fc;
            }

            html.dark-mode .global-coin-tier,
            html.dark-mode .global-coin-timer {
                color: #b7cadf;
            }

            html.dark-mode #globalCollectCoinBtn:disabled {
                background: rgba(30, 41, 59, 0.65);
                color: #7dd3fc;
            }

            html.dark-mode #globalCollectCoinBtn:not(:disabled) {
                background: rgba(40, 60, 80, 1);
                color: #2dd4bf;
                box-shadow: 0 6px 16px rgba(45, 212, 191, 0.2);
            }

            .global-loader-logo {
                width: clamp(220px, 34vw, 360px);
                max-width: 100%;
                height: auto;
                margin-bottom: 12px;
                filter: drop-shadow(0 4px 10px rgba(0, 0, 0, 0.28));
            }

            .global-loader-text {
                font-size: 1rem;
                opacity: 0.92;
                margin-bottom: 22px;
            }

            .global-loader-dots {
                display: flex;
                gap: 10px;
                align-items: center;
                justify-content: center;
            }

            .global-loader-dots span {
                width: 12px;
                height: 12px;
                border-radius: 50%;
                background: #ffffff;
                animation: loader-bounce 0.95s infinite ease-in-out;
            }

            .global-loader-dots span:nth-child(2) {
                animation-delay: 0.12s;
            }

            .global-loader-dots span:nth-child(3) {
                animation-delay: 0.24s;
            }

            .logout-confirm-modal {
                position: fixed;
                inset: 0;
                z-index: 10010;
                display: none;
            }

            .logout-confirm-modal.open {
                display: block;
            }

            .logout-confirm-backdrop {
                position: absolute;
                inset: 0;
                background: rgba(6, 16, 28, 0.58);
                backdrop-filter: blur(4px);
            }

            .logout-confirm-card {
                position: relative;
                width: min(420px, calc(100vw - 24px));
                margin: 16vh auto 0;
                border-radius: 16px;
                border: 1px solid rgba(152, 189, 216, 0.6);
                background: rgba(255, 255, 255, 0.96);
                box-shadow: 0 18px 40px rgba(8, 35, 66, 0.25);
                padding: 18px;
                color: #1e456e;
            }

            .logout-confirm-title {
                margin: 0;
                font-size: 20px;
                font-weight: 800;
            }

            .logout-confirm-text {
                margin: 10px 0 0;
                color: #456482;
                font-size: 14px;
                line-height: 1.5;
            }

            .logout-confirm-actions {
                margin-top: 16px;
                display: flex;
                justify-content: flex-end;
                gap: 10px;
            }

            .logout-confirm-btn {
                border: none;
                border-radius: 10px;
                padding: 9px 14px;
                font-weight: 700;
                cursor: pointer;
                min-width: 96px;
            }

            /* Requested color swap: OK uses cancel color, Cancel uses OK color. */
            .logout-confirm-btn.ok {
                background: #ff5e62;
                color: #ffffff;
            }

            .logout-confirm-btn.cancel {
                background: #0BA4A1;
                color: #ffffff;
            }

            html.dark-mode .logout-confirm-card {
                background: rgba(18, 32, 50, 0.96);
                border-color: rgba(70, 98, 126, 0.75);
                color: #d0e0f0;
            }

            html.dark-mode .logout-confirm-text {
                color: #a9bfd6;
            }

            body.vision-theme-default {
                --vision-main-background: radial-gradient(1400px 500px at 10% -20%, rgba(10, 160, 159, 0.22), transparent 60%), radial-gradient(1000px 500px at 100% 0%, rgba(252, 186, 48, 0.20), transparent 55%), linear-gradient(180deg, #f4f9ff 0%, #eff6fb 100%);
                --vision-top-bar-background: rgba(255, 255, 255, 0.90);
                --vision-side-menu-background: linear-gradient(180deg, #ffffff 0%, #f3f9ff 100%);
                --vision-nav-active-background: linear-gradient(135deg, #0b8e8b, #1a6ea0);
                --vision-nav-active-color: #f1fcff;
                --vision-hover-background: rgba(10, 160, 159, 0.10);
                --vision-hover-border: rgba(10, 160, 159, 0.22);
                --vision-hover-color: #0b8e8b;
                --vision-profile-hover-border: rgba(86, 218, 255, 0.92);
                --vision-profile-hover-background: linear-gradient(135deg, rgba(219, 247, 255, 0.98), rgba(192, 238, 255, 0.94));
                --vision-profile-hover-shadow: 0 0 0 1px rgba(129, 230, 255, 0.72), 0 0 16px rgba(65, 203, 255, 0.46), 0 10px 24px rgba(10, 98, 141, 0.24);
                --vision-accent: #0FA5A2;
                --vision-accent-strong: #1D4D7C;
                --vision-panel-text: #1e456e;
                --vision-panel-border: rgba(163, 208, 232, 0.55);
                --vision-panel-bg: linear-gradient(140deg, rgba(255, 255, 255, 0.62), rgba(238, 248, 255, 0.46));
                --vision-panel-glow: rgba(45, 212, 191, 0.55);
            }

            body.vision-theme-blue {
                --vision-main-background: radial-gradient(1400px 500px at 10% -20%, rgba(34, 132, 222, 0.24), transparent 60%), radial-gradient(1000px 500px at 100% 0%, rgba(129, 196, 255, 0.18), transparent 55%), linear-gradient(180deg, #f1f8ff 0%, #eaf4ff 100%);
                --vision-top-bar-background: rgba(244, 250, 255, 0.94);
                --vision-side-menu-background: linear-gradient(180deg, #ffffff 0%, #eef6ff 100%);
                --vision-nav-active-background: linear-gradient(135deg, #156fd1, #0f4c9a);
                --vision-nav-active-color: #f6fbff;
                --vision-hover-background: rgba(34, 132, 222, 0.10);
                --vision-hover-border: rgba(34, 132, 222, 0.22);
                --vision-hover-color: #156fd1;
                --vision-profile-hover-border: rgba(88, 154, 209, 0.92);
                --vision-profile-hover-background: linear-gradient(135deg, rgba(232, 244, 255, 0.98), rgba(213, 234, 255, 0.94));
                --vision-profile-hover-shadow: 0 0 0 1px rgba(134, 196, 255, 0.72), 0 0 16px rgba(63, 165, 255, 0.40), 0 10px 24px rgba(14, 82, 138, 0.22);
                --vision-accent: #156fd1;
                --vision-accent-strong: #0f4c9a;
                --vision-panel-text: #174a7d;
                --vision-panel-border: rgba(134, 196, 255, 0.58);
                --vision-panel-bg: linear-gradient(140deg, rgba(255, 255, 255, 0.68), rgba(235, 246, 255, 0.48));
                --vision-panel-glow: rgba(63, 165, 255, 0.58);
            }

            body.vision-theme-red {
                --vision-main-background: radial-gradient(1400px 500px at 10% -20%, rgba(220, 82, 82, 0.24), transparent 60%), radial-gradient(1000px 500px at 100% 0%, rgba(255, 191, 191, 0.16), transparent 55%), linear-gradient(180deg, #fff4f4 0%, #ffecec 100%);
                --vision-top-bar-background: rgba(255, 246, 246, 0.95);
                --vision-side-menu-background: linear-gradient(180deg, #ffffff 0%, #fff1f1 100%);
                --vision-nav-active-background: linear-gradient(135deg, #d33f49, #8f2433);
                --vision-nav-active-color: #fff8f8;
                --vision-hover-background: rgba(220, 82, 82, 0.10);
                --vision-hover-border: rgba(220, 82, 82, 0.22);
                --vision-hover-color: #d33f49;
                --vision-profile-hover-border: rgba(224, 114, 114, 0.92);
                --vision-profile-hover-background: linear-gradient(135deg, rgba(255, 237, 237, 0.98), rgba(255, 225, 225, 0.94));
                --vision-profile-hover-shadow: 0 0 0 1px rgba(255, 170, 170, 0.72), 0 0 16px rgba(255, 124, 124, 0.34), 0 10px 24px rgba(152, 50, 50, 0.20);
                --vision-accent: #d33f49;
                --vision-accent-strong: #8f2433;
                --vision-panel-text: #9e3540;
                --vision-panel-border: rgba(224, 114, 114, 0.58);
                --vision-panel-bg: linear-gradient(140deg, rgba(255, 255, 255, 0.68), rgba(255, 240, 240, 0.48));
                --vision-panel-glow: rgba(255, 124, 124, 0.50);
            }

            body.vision-theme-yellow {
                --vision-main-background: radial-gradient(1400px 500px at 10% -20%, rgba(232, 177, 38, 0.28), transparent 60%), radial-gradient(1000px 500px at 100% 0%, rgba(255, 238, 181, 0.18), transparent 55%), linear-gradient(180deg, #fffaf0 0%, #fff3d6 100%);
                --vision-top-bar-background: rgba(255, 251, 240, 0.95);
                --vision-side-menu-background: linear-gradient(180deg, #ffffff 0%, #fff7e4 100%);
                --vision-nav-active-background: linear-gradient(135deg, #d39a15, #8e5f09);
                --vision-nav-active-color: #fffdf7;
                --vision-hover-background: rgba(232, 177, 38, 0.12);
                --vision-hover-border: rgba(232, 177, 38, 0.24);
                --vision-hover-color: #c98f00;
                --vision-profile-hover-border: rgba(230, 194, 86, 0.92);
                --vision-profile-hover-background: linear-gradient(135deg, rgba(255, 248, 220, 0.98), rgba(255, 242, 194, 0.94));
                --vision-profile-hover-shadow: 0 0 0 1px rgba(248, 214, 123, 0.72), 0 0 16px rgba(255, 204, 84, 0.34), 0 10px 24px rgba(162, 124, 22, 0.18);
                --vision-accent: #c98f00;
                --vision-accent-strong: #8e5f09;
                --vision-panel-text: #9a6e00;
                --vision-panel-border: rgba(230, 194, 86, 0.58);
                --vision-panel-bg: linear-gradient(140deg, rgba(255, 255, 255, 0.70), rgba(255, 248, 225, 0.50));
                --vision-panel-glow: rgba(255, 204, 84, 0.52);
            }

            body.vision-theme-black {
                --vision-main-background: radial-gradient(1400px 500px at 10% -20%, rgba(68, 74, 88, 0.30), transparent 60%), radial-gradient(1000px 500px at 100% 0%, rgba(156, 163, 175, 0.16), transparent 55%), linear-gradient(180deg, #1f2733 0%, #121822 100%);
                --vision-top-bar-background: rgba(25, 32, 44, 0.96);
                --vision-side-menu-background: linear-gradient(180deg, #1f2733 0%, #151b24 100%);
                --vision-nav-active-background: linear-gradient(135deg, #586174, #262d3a);
                --vision-nav-active-color: #f8fafc;
                --vision-hover-background: rgba(148, 163, 184, 0.12);
                --vision-hover-border: rgba(148, 163, 184, 0.24);
                --vision-hover-color: #d8e0ea;
                --vision-profile-hover-border: rgba(114, 128, 145, 0.92);
                --vision-profile-hover-background: linear-gradient(135deg, rgba(33, 41, 53, 0.98), rgba(24, 31, 42, 0.94));
                --vision-profile-hover-shadow: 0 0 0 1px rgba(86, 95, 109, 0.70), 0 0 16px rgba(74, 85, 104, 0.30), 0 10px 24px rgba(0, 0, 0, 0.38);
                --vision-accent: #c7d2e1;
                --vision-accent-strong: #e2e8f0;
                --vision-panel-text: #d6deea;
                --vision-panel-border: rgba(109, 121, 139, 0.58);
                --vision-panel-bg: linear-gradient(140deg, rgba(23, 30, 41, 0.92), rgba(15, 20, 29, 0.88));
                --vision-panel-glow: rgba(148, 163, 184, 0.28);
            }

            body.vision-theme-white {
                --vision-main-background: radial-gradient(1400px 500px at 10% -20%, rgba(203, 213, 225, 0.34), transparent 60%), radial-gradient(1000px 500px at 100% 0%, rgba(241, 245, 249, 0.22), transparent 55%), linear-gradient(180deg, #ffffff 0%, #f6f8fb 100%);
                --vision-top-bar-background: rgba(255, 255, 255, 0.96);
                --vision-side-menu-background: linear-gradient(180deg, #ffffff 0%, #f6f8fb 100%);
                --vision-nav-active-background: linear-gradient(135deg, #7a8798, #475569);
                --vision-nav-active-color: #ffffff;
                --vision-hover-background: rgba(148, 163, 184, 0.10);
                --vision-hover-border: rgba(148, 163, 184, 0.24);
                --vision-hover-color: #475569;
                --vision-profile-hover-border: rgba(203, 213, 225, 0.95);
                --vision-profile-hover-background: linear-gradient(135deg, rgba(250, 251, 252, 0.98), rgba(243, 246, 249, 0.95));
                --vision-profile-hover-shadow: 0 0 0 1px rgba(226, 232, 240, 0.9), 0 0 16px rgba(203, 213, 225, 0.30), 0 10px 24px rgba(148, 163, 184, 0.18);
                --vision-accent: #64748b;
                --vision-accent-strong: #334155;
                --vision-panel-text: #334155;
                --vision-panel-border: rgba(203, 213, 225, 0.78);
                --vision-panel-bg: linear-gradient(140deg, rgba(255, 255, 255, 0.70), rgba(249, 250, 251, 0.54));
                --vision-panel-glow: rgba(148, 163, 184, 0.30);
            }

            body.vision-theme-default,
            body.vision-theme-blue,
            body.vision-theme-red,
            body.vision-theme-yellow,
            body.vision-theme-black,
            body.vision-theme-white {
                background: var(--vision-main-background);
            }

            body.vision-theme-default .global-quick-toggle,
            body.vision-theme-blue .global-quick-toggle,
            body.vision-theme-red .global-quick-toggle,
            body.vision-theme-yellow .global-quick-toggle,
            body.vision-theme-black .global-quick-toggle,
            body.vision-theme-white .global-quick-toggle {
                background: rgba(255, 255, 255, 0.88);
                border-color: var(--vision-panel-border);
                color: var(--vision-panel-text);
            }

            body.vision-theme-default .global-quick-toggle:hover,
            body.vision-theme-blue .global-quick-toggle:hover,
            body.vision-theme-red .global-quick-toggle:hover,
            body.vision-theme-yellow .global-quick-toggle:hover,
            body.vision-theme-black .global-quick-toggle:hover,
            body.vision-theme-white .global-quick-toggle:hover {
                color: var(--vision-accent);
                border-color: var(--vision-accent);
                box-shadow: 0 0 12px var(--vision-panel-glow), 0 0 26px rgba(56, 189, 248, 0.22);
            }

            body.vision-theme-default .global-glass-panel,
            body.vision-theme-blue .global-glass-panel,
            body.vision-theme-red .global-glass-panel,
            body.vision-theme-yellow .global-glass-panel,
            body.vision-theme-black .global-glass-panel,
            body.vision-theme-white .global-glass-panel {
                border-color: var(--vision-panel-border);
                background: var(--vision-panel-bg);
            }

            body.vision-theme-default .global-glass-head,
            body.vision-theme-blue .global-glass-head,
            body.vision-theme-red .global-glass-head,
            body.vision-theme-yellow .global-glass-head,
            body.vision-theme-black .global-glass-head,
            body.vision-theme-white .global-glass-head,
            body.vision-theme-default .global-action-btn,
            body.vision-theme-blue .global-action-btn,
            body.vision-theme-red .global-action-btn,
            body.vision-theme-yellow .global-action-btn,
            body.vision-theme-black .global-action-btn,
            body.vision-theme-white .global-action-btn,
            body.vision-theme-default .global-action-link,
            body.vision-theme-blue .global-action-link,
            body.vision-theme-red .global-action-link,
            body.vision-theme-yellow .global-action-link,
            body.vision-theme-black .global-action-link,
            body.vision-theme-white .global-action-link {
                color: var(--vision-panel-text);
            }

            body.vision-theme-default .global-action-btn,
            body.vision-theme-blue .global-action-btn,
            body.vision-theme-red .global-action-btn,
            body.vision-theme-yellow .global-action-btn,
            body.vision-theme-black .global-action-btn,
            body.vision-theme-white .global-action-btn,
            body.vision-theme-default .global-action-link,
            body.vision-theme-blue .global-action-link,
            body.vision-theme-red .global-action-link,
            body.vision-theme-yellow .global-action-link,
            body.vision-theme-black .global-action-link,
            body.vision-theme-white .global-action-link {
                border-color: var(--vision-panel-border);
                background: rgba(255, 255, 255, 0.90);
            }

            body.vision-theme-default .global-action-btn:hover,
            body.vision-theme-blue .global-action-btn:hover,
            body.vision-theme-red .global-action-btn:hover,
            body.vision-theme-yellow .global-action-btn:hover,
            body.vision-theme-black .global-action-btn:hover,
            body.vision-theme-white .global-action-btn:hover,
            body.vision-theme-default .global-action-link:hover,
            body.vision-theme-blue .global-action-link:hover,
            body.vision-theme-red .global-action-link:hover,
            body.vision-theme-yellow .global-action-link:hover,
            body.vision-theme-black .global-action-link:hover,
            body.vision-theme-white .global-action-link:hover {
                color: var(--vision-accent);
                border-color: var(--vision-accent-border, var(--vision-accent));
                box-shadow: 0 0 12px var(--vision-panel-glow), 0 0 24px rgba(56, 189, 248, 0.18);
            }

            body.vision-theme-default .global-action-link.power,
            body.vision-theme-blue .global-action-link.power,
            body.vision-theme-red .global-action-link.power,
            body.vision-theme-yellow .global-action-link.power,
            body.vision-theme-black .global-action-link.power,
            body.vision-theme-white .global-action-link.power {
                color: #b84848;
            }

            body.vision-theme-default .global-action-link.upgrade,
            body.vision-theme-blue .global-action-link.upgrade,
            body.vision-theme-red .global-action-link.upgrade,
            body.vision-theme-yellow .global-action-link.upgrade,
            body.vision-theme-black .global-action-link.upgrade,
            body.vision-theme-white .global-action-link.upgrade {
                color: #c19a3f;
            }

            @keyframes loader-bounce {
                0%, 80%, 100% {
                    transform: translateY(0);
                    opacity: 0.5;
                }
                40% {
                    transform: translateY(-8px);
                    opacity: 1;
                }
            }
        </style>
    </head>
    {% set currentLocale = app.request.locale|default('en') %}
    <body class="vision-theme-{{ app.request.session.get('vision_theme')|default('default') }}">
        <button id="globalQuickToggle" class="global-quick-toggle" type="button" aria-label="{{ 'panel.slide_me'|trans }}">⌄ {{ 'panel.slide_me'|trans }} ⌄<span id="globalQuickBadge" class="global-quick-badge">!</span></button>
        <div id="globalGlassOverlay" class="global-glass-overlay" aria-hidden="true"></div>
        <aside id="globalGlassPanel" class="global-glass-panel" aria-hidden="true">
            <div class="global-glass-head">
                <div class="global-glass-brand">{{ 'panel.control_title'|trans }}</div>
                <button id="globalGlassClose" class="global-glass-close" type="button" aria-label="{{ 'panel.close'|trans }}">x</button>
            </div>
            <div class="global-glass-actions">
                <button id="globalThemeButton" class="global-action-btn settings" type="button" aria-label="{{ 'panel.dark_mode'|trans }}">
                    <span id="globalThemeIcon" class="global-action-icon">🌙</span>
                    <span id="globalThemeLabel">{{ 'panel.dark_mode'|trans }}</span>
                </button>
                <button id="globalCollectCoinBtn" class="global-action-btn global-action-coin" type="button" aria-label="{{ 'panel.collect'|trans }}" disabled>
                    <div class="global-coin-head">
                        <span class="global-action-icon">💎</span>
                        <span id="globalCoinCount" class="global-coin-count">0</span>
                    </div>
                    <div id="globalCoinTier" class="global-coin-tier">standard • +1</div>
                    <div id="globalCoinTimer" class="global-coin-timer">{{ 'panel.ready_to_collect'|trans }}</div>
                    <span id="globalCoinBtnLabel">{{ 'panel.collect'|trans }}</span>
                </button>
                <a id="globalUpgradeBtn" class="global-action-link upgrade" href="{{ path('app_premium') }}" aria-label="{{ 'panel.upgrade_plan'|trans }}" style="display: none;">
                    <span class="global-action-icon">⭐</span>
                    <span>{{ 'panel.upgrade_plan'|trans }}</span>
                </a>
                <a class="global-action-link settings" href="{{ path('app_settings') }}" data-no-loader="true" data-turbo="false" aria-label="{{ 'panel.settings'|trans }}">
                    <span class="global-action-icon">⚙</span>
                    <span>{{ 'panel.settings'|trans }}</span>
                </a>
                {% if app.user and is_granted('ROLE_USER') %}
                    <a class="global-action-link settings" href="{{ path('app_vision_test') }}" data-no-loader="true" data-turbo="false" aria-label="{{ 'panel.eye_test'|trans }}">
                        <span class="global-action-icon">👁️</span>
                        <span>{{ 'panel.eye_test'|trans }}</span>
                    </a>
                {% endif %}
                <div class="global-action-btn global-action-language settings">
                    <label for="languageSelect" class="global-language-title">🌍 {{ 'panel.language'|trans }}</label>
                    <select id="languageSelect" name="locale" class="global-language-select" onchange="window.location.href='/language/' + this.value;">
                        <option value="en" {% if currentLocale == 'en' %}selected{% endif %}>🇺🇸 {{ 'panel.language_en'|trans }}</option>
                        <option value="fr" {% if currentLocale == 'fr' %}selected{% endif %}>🇫🇷 {{ 'panel.language_fr'|trans }}</option>
                    </select>
                </div>
                <a id="globalLogoutLink" class="global-action-link power" href="{{ path('app_logout') }}" aria-label="{{ 'panel.logout'|trans }}">
                    <span class="global-action-icon">⏻</span>
                    <span>{{ 'panel.logout'|trans }}</span>
                </a>
            </div>
        </aside>
        <div id="globalLoader" class="global-loader" aria-hidden="true">
            <img class="global-loader-logo" src="{{ asset('images/logo.png') }}" alt="Rehletna logo">
            <div id="globalLoaderText" class="global-loader-text">{{ 'panel.loading_page'|trans }}</div>
            <div class="global-loader-dots" aria-label="Loading">
                <span></span>
                <span></span>
                <span></span>
            </div>
        </div>
        <div id="logoutConfirmModal" class="logout-confirm-modal" aria-hidden="true">
            <div class="logout-confirm-backdrop" id="logoutConfirmBackdrop"></div>
            <div class="logout-confirm-card" role="dialog" aria-modal="true" aria-labelledby="logoutConfirmTitle">
                <h3 id="logoutConfirmTitle" class="logout-confirm-title">Confirm Logout</h3>
                <p class="logout-confirm-text">Are you sure you want to log out?</p>
                <div class="logout-confirm-actions">
                    <button id="logoutConfirmCancel" type="button" class="logout-confirm-btn cancel">Cancel</button>
                    <button id="logoutConfirmOk" type="button" class="logout-confirm-btn ok">OK</button>
                </div>
            </div>
        </div>
        {% block body %}{% endblock %}
        <script>
            (function () {
                const loader = document.getElementById('globalLoader');
                const loaderText = document.getElementById('globalLoaderText');
                const globalQuickToggle = document.getElementById('globalQuickToggle');
                const globalGlassOverlay = document.getElementById('globalGlassOverlay');
                const globalGlassPanel = document.getElementById('globalGlassPanel');
                const globalGlassClose = document.getElementById('globalGlassClose');
                const globalThemeButton = document.getElementById('globalThemeButton');
                const globalThemeIcon = document.getElementById('globalThemeIcon');
                const globalThemeLabel = document.getElementById('globalThemeLabel');
                const globalQuickBadge = document.getElementById('globalQuickBadge');
                const globalCollectCoinBtn = document.getElementById('globalCollectCoinBtn');
                const globalUpgradeBtn = document.getElementById('globalUpgradeBtn');
                const globalCoinCount = document.getElementById('globalCoinCount');
                const globalCoinTier = document.getElementById('globalCoinTier');
                const globalCoinTimer = document.getElementById('globalCoinTimer');
                const globalCoinBtnLabel = document.getElementById('globalCoinBtnLabel');
                const globalLogoutLink = document.getElementById('globalLogoutLink');
                const logoutConfirmModal = document.getElementById('logoutConfirmModal');
                const logoutConfirmBackdrop = document.getElementById('logoutConfirmBackdrop');
                const logoutConfirmCancel = document.getElementById('logoutConfirmCancel');
                const logoutConfirmOk = document.getElementById('logoutConfirmOk');
                const panelText = {
                    darkMode: '{{ 'panel.dark_mode'|trans|e('js') }}',
                    lightMode: '{{ 'panel.light_mode'|trans|e('js') }}',
                    collectNow: '{{ 'panel.collect_now'|trans|e('js') }}',
                    collectingSoon: '{{ 'panel.collecting_soon'|trans|e('js') }}',
                    collecting: '{{ 'panel.collecting'|trans|e('js') }}',
                    readyToCollect: '{{ 'panel.ready_to_collect'|trans|e('js') }}',
                    availableIn: '{{ 'panel.available_in'|trans({'%seconds%': '__SECONDS__'})|e('js') }}',
                    returningMain: '{{ 'panel.returning_main'|trans|e('js') }}'
                };
                let dragStartY = 0;
                let dragDistance = 0;
                let isDraggingToggle = false;
                let coinCooldownRemaining = 0;
                let coinCountdownInterval = null;

                if (!loader) {
                    return;
                }

                const showLoader = (text) => {
                    if (loaderText && text) {
                        loaderText.textContent = text;
                    }
                    loader.classList.add('active');
                    loader.setAttribute('aria-hidden', 'false');
                };

                const hideLoader = () => {
                    loader.classList.remove('active');
                    loader.setAttribute('aria-hidden', 'true');
                };

                const syncThemeIcon = () => {
                    if (!globalThemeIcon || !globalThemeLabel) {
                        return;
                    }
                    const isDark = document.documentElement.classList.contains('dark-mode') || document.body.classList.contains('dark-mode');
                    globalThemeIcon.textContent = isDark ? '☀️' : '🌙';
                    globalThemeLabel.textContent = isDark ? panelText.lightMode : panelText.darkMode;
                };

                const syncCoinNotification = () => {
                    if (!globalQuickBadge) {
                        return;
                    }
                    if (coinCooldownRemaining <= 0) {
                        globalQuickBadge.classList.add('show');
                    } else {
                        globalQuickBadge.classList.remove('show');
                    }
                };

                const updateCoinUi = () => {
                    if (!globalCollectCoinBtn || !globalCoinTimer || !globalCoinBtnLabel) {
                        return;
                    }

                    const isReady = coinCooldownRemaining <= 0;
                    globalCollectCoinBtn.disabled = !isReady;
                    globalCoinBtnLabel.textContent = isReady ? panelText.collectNow : panelText.collectingSoon;
                    globalCoinTimer.textContent = isReady
                        ? panelText.readyToCollect
                        : panelText.availableIn.replace('__SECONDS__', String(coinCooldownRemaining));
                    const progress = Math.max(0, Math.min(100, ((30 - coinCooldownRemaining) / 30) * 100));
                    
                    // Update collect coin button progress line only
                    globalCollectCoinBtn.style.setProperty('--coin-button-progress', progress + '%');
                    
                    syncCoinNotification();
                };

                const startCoinCountdown = (seconds) => {
                    coinCooldownRemaining = Math.max(0, parseInt(seconds || 0, 10));
                    updateCoinUi();

                    if (coinCountdownInterval) {
                        clearInterval(coinCountdownInterval);
                    }

                    if (coinCooldownRemaining <= 0) {
                        return;
                    }

                    coinCountdownInterval = window.setInterval(() => {
                        coinCooldownRemaining = Math.max(0, coinCooldownRemaining - 1);
                        updateCoinUi();
                        if (coinCooldownRemaining <= 0) {
                            clearInterval(coinCountdownInterval);
                            coinCountdownInterval = null;
                        }
                    }, 1000);
                };

                const loadCoinStatus = () => {
                    if (!globalCollectCoinBtn) {
                        return;
                    }

                    fetch('{{ path('app_collect_coin_status') }}', {
                        credentials: 'same-origin',
                        headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    })
                        .then((response) => {
                            if (!response.ok) {
                                throw new Error('coin-status-failed');
                            }
                            return response.json();
                        })
                        .then((payload) => {
                            if (!payload || !payload.success) {
                                return;
                            }

                            if (globalCoinCount) {
                                globalCoinCount.textContent = String(payload.coins || 0);
                            }
                            if (globalCoinTier) {
                                const tierLabel = String(payload.tier || 'standard').toLowerCase();
                                globalCoinTier.textContent = tierLabel + ' • +' + String(payload.reward || 1);
                            }
                            startCoinCountdown(payload.cooldownRemaining || 0);
                        })
                        .catch(() => {
                            // Keep panel usable even if status endpoint is not available for this page.
                        });
                };

                const checkUpgradeButton = () => {
                    if (!globalUpgradeBtn) {
                        return;
                    }

                    fetch('{{ path('app_collect_coin_status') }}', {
                        credentials: 'same-origin',
                        headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    })
                        .then((response) => response.json())
                        .then((payload) => {
                            if (payload && payload.tier) {
                                const tier = String(payload.tier).toLowerCase();
                                if (tier === 'standard') {
                                    globalUpgradeBtn.style.display = 'flex';
                                } else {
                                    globalUpgradeBtn.style.display = 'none';
                                }
                            }
                        })
                        .catch(() => {
                            // Don't show button if we can't determine tier
                            globalUpgradeBtn.style.display = 'none';
                        });
                };

                const collectCoins = () => {
                    if (!globalCollectCoinBtn || globalCollectCoinBtn.disabled) {
                        return;
                    }

                    globalCollectCoinBtn.disabled = true;
                    globalCoinBtnLabel.textContent = panelText.collecting;

                    fetch('{{ path('app_collect_coin') }}', {
                        method: 'POST',
                        credentials: 'same-origin',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                            'X-Requested-With': 'XMLHttpRequest'
                        },
                        body: ''
                    })
                        .then((response) => response.json())
                        .then((payload) => {
                            if (!payload || !payload.success) {
                                startCoinCountdown(payload && payload.cooldownRemaining ? payload.cooldownRemaining : 0);
                                return;
                            }

                            if (globalCoinCount) {
                                globalCoinCount.textContent = String(payload.coins || 0);
                            }
                            if (globalCoinTier) {
                                const tierLabel = String(payload.tier || 'standard').toLowerCase();
                                globalCoinTier.textContent = tierLabel + ' • +' + String(payload.awarded || 1);
                            }
                            startCoinCountdown(payload.cooldownRemaining || 30);
                        })
                        .catch(() => {
                            loadCoinStatus();
                        });
                };

                const openGlassPanel = () => {
                    if (!globalGlassPanel || !globalGlassOverlay) {
                        return;
                    }
                    globalGlassPanel.classList.add('open');
                    globalGlassOverlay.classList.add('open');
                    globalGlassPanel.setAttribute('aria-hidden', 'false');
                    globalGlassOverlay.setAttribute('aria-hidden', 'false');
                };

                const closeGlassPanel = () => {
                    if (!globalGlassPanel || !globalGlassOverlay) {
                        return;
                    }
                    globalGlassPanel.classList.remove('open');
                    globalGlassOverlay.classList.remove('open');
                    globalGlassPanel.setAttribute('aria-hidden', 'true');
                    globalGlassOverlay.setAttribute('aria-hidden', 'true');
                };

                const openLogoutConfirm = () => {
                    if (!logoutConfirmModal) {
                        return;
                    }
                    logoutConfirmModal.classList.add('open');
                    logoutConfirmModal.setAttribute('aria-hidden', 'false');
                };

                const closeLogoutConfirm = () => {
                    if (!logoutConfirmModal) {
                        return;
                    }
                    logoutConfirmModal.classList.remove('open');
                    logoutConfirmModal.setAttribute('aria-hidden', 'true');
                };

                window.showGlobalLoader = showLoader;
                window.hideGlobalLoader = hideLoader;

                syncThemeIcon();

                if (globalQuickToggle) {
                    const resetTogglePosition = function () {
                        globalQuickToggle.classList.remove('dragging');
                        globalQuickToggle.style.top = '6px';
                        dragDistance = 0;
                        isDraggingToggle = false;
                    };

                    globalQuickToggle.addEventListener('pointerdown', function (event) {
                        dragStartY = event.clientY;
                        dragDistance = 0;
                        isDraggingToggle = true;
                        globalQuickToggle.classList.add('dragging');
                        globalQuickToggle.setPointerCapture(event.pointerId);
                    });

                    globalQuickToggle.addEventListener('pointermove', function (event) {
                        if (!isDraggingToggle) {
                            return;
                        }
                        dragDistance = Math.max(0, Math.min(70, event.clientY - dragStartY));
                        globalQuickToggle.style.top = (6 + dragDistance) + 'px';
                    });

                    globalQuickToggle.addEventListener('pointerup', function (event) {
                        if (!isDraggingToggle) {
                            return;
                        }
                        if (dragDistance >= 38) {
                            if (globalGlassPanel && globalGlassPanel.classList.contains('open')) {
                                closeGlassPanel();
                            } else {
                                openGlassPanel();
                            }
                        }
                        resetTogglePosition();
                        globalQuickToggle.releasePointerCapture(event.pointerId);
                    });

                    globalQuickToggle.addEventListener('pointercancel', function () {
                        resetTogglePosition();
                    });
                }

                if (globalGlassOverlay) {
                    globalGlassOverlay.addEventListener('click', closeGlassPanel);
                }

                if (globalGlassClose) {
                    globalGlassClose.addEventListener('click', closeGlassPanel);
                }

                if (globalThemeButton) {
                    globalThemeButton.addEventListener('click', function () {
                        if (window.toggleTheme) {
                            window.toggleTheme();
                        }
                        syncThemeIcon();
                    });
                }

                if (globalLogoutLink) {
                    globalLogoutLink.addEventListener('click', function (event) {
                        event.preventDefault();
                        closeGlassPanel();
                        hideLoader();
                        openLogoutConfirm();
                    });
                }

                if (logoutConfirmBackdrop) {
                    logoutConfirmBackdrop.addEventListener('click', function () {
                        closeLogoutConfirm();
                        hideLoader();
                    });
                }

                if (logoutConfirmCancel) {
                    logoutConfirmCancel.addEventListener('click', function () {
                        closeLogoutConfirm();
                        hideLoader();
                    });
                }

                if (logoutConfirmOk) {
                    logoutConfirmOk.addEventListener('click', function () {
                        if (!globalLogoutLink) {
                            closeLogoutConfirm();
                            return;
                        }
                        closeLogoutConfirm();
                        showLoader('Signing you out...');
                        window.location.assign(globalLogoutLink.href);
                    });
                }

                if (globalCollectCoinBtn) {
                    globalCollectCoinBtn.addEventListener('click', collectCoins);
                }

                loadCoinStatus();
                checkUpgradeButton();

                window.addEventListener('themechange', syncThemeIcon);
                window.addEventListener('pageshow', function () {
                    hideLoader();
                    closeGlassPanel();
                });
                window.addEventListener('load', function () {
                    hideLoader();
                    closeGlassPanel();
                });
                document.addEventListener('visibilitychange', function () {
                    if (document.visibilityState === 'visible') {
                        hideLoader();
                        closeGlassPanel();
                    }
                });

                document.addEventListener('keydown', function (event) {
                    if (event.key === 'Escape') {
                        closeGlassPanel();
                        closeLogoutConfirm();
                    }
                });

                document.addEventListener('click', function (event) {
                    const backMainButton = event.target.closest('.back-main-btn');
                    if (!backMainButton) {
                        return;
                    }

                    const href = backMainButton.getAttribute('href');
                    if (!href) {
                        return;
                    }

                    event.preventDefault();
                    showLoader(panelText.returningMain);
                    window.location.assign(href);
                });

                document.addEventListener('click', function (event) {
                    const settingsLink = event.target.closest('.global-action-link.settings');
                    if (!settingsLink) {
                        return;
                    }

                    const href = settingsLink.getAttribute('href');
                    if (!href) {
                        return;
                    }

                    event.preventDefault();
                    closeGlassPanel();
                    window.location.assign(href);
                });

                document.addEventListener('click', function (event) {
                    const panelLink = event.target.closest('#globalGlassPanel a[href]');
                    if (!panelLink) {
                        return;
                    }

                    closeGlassPanel();
                });

                document.addEventListener('click', (event) => {
                    if (event.defaultPrevented) {
                        return;
                    }

                    const link = event.target.closest('a[href]');
                    if (!link) {
                        return;
                    }

                    const href = link.getAttribute('href') || '';
                    if (
                        href.startsWith('#') ||
                        href.startsWith('mailto:') ||
                        href.startsWith('tel:') ||
                        href.startsWith('javascript:') ||
                        link.target === '_blank' ||
                        link.hasAttribute('download') ||
                        link.dataset.noLoader === 'true'
                    ) {
                        return;
                    }

                    const url = new URL(link.href, window.location.origin);
                    if (url.origin !== window.location.origin) {
                        return;
                    }

                    showLoader('Opening page...');
                });

                document.addEventListener('submit', (event) => {
                    const form = event.target;
                    if (!(form instanceof HTMLFormElement)) {
                        return;
                    }

                    if (form.dataset.noLoader === 'true') {
                        return;
                    }

                    showLoader('Loading...');
                });
            })();
        </script>
    </body>
</html>
