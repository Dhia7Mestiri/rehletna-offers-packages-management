                width: 30px;
                height: 30px;
                border-radius: 999px;
                background: rgba(25, 69, 117, 0.1);
                color: #194575;
                cursor: pointer;
                font-size: 16px;
            }

            .global-glass-actions {
                padding: 22px;
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
                gap: 14px;
                max-width: 760px;
            }

            .global-glass-layout {
