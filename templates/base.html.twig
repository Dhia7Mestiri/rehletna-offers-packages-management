                background: rgba(40, 60, 80, 1);
                color: #2dd4bf;
                box-shadow: 0 6px 16px rgba(45, 212, 191, 0.2);
            }

            .global-loader-logo {
                width: clamp(220px, 34vw, 360px);
                max-width: 100%;
                height: auto;
                margin-bottom: 12px;
                filter: drop-shadow(0 4px 10px rgba(0, 0, 0, 0.28));
            }

            .global-loader-text {
                font-size: 1rem;
                opacity: 0.92;
                margin-bottom: 22px;
            }

            .global-loader-dots {
                display: flex;
                gap: 10px;
                align-items: center;
                justify-content: center;
            }

            .global-loader-dots span {
                width: 12px;
                height: 12px;
                border-radius: 50%;
                background: #ffffff;
                animation: loader-bounce 0.95s infinite ease-in-out;
            }

            .global-loader-dots span:nth-child(2) {
                animation-delay: 0.12s;
            }

            .global-loader-dots span:nth-child(3) {
                animation-delay: 0.24s;
            }

            .logout-confirm-modal {
                position: fixed;
                inset: 0;
                z-index: 10010;
                display: none;
            }

            .logout-confirm-modal.open {
                display: block;
            }

            .logout-confirm-backdrop {
                position: absolute;
                inset: 0;
                background: rgba(6, 16, 28, 0.58);
                backdrop-filter: blur(4px);
            }

            .logout-confirm-card {
                position: relative;
                width: min(420px, calc(100vw - 24px));
                margin: 16vh auto 0;
                border-radius: 16px;
                border: 1px solid rgba(152, 189, 216, 0.6);
                background: rgba(255, 255, 255, 0.96);
                box-shadow: 0 18px 40px rgba(8, 35, 66, 0.25);
                padding: 18px;
                color: #1e456e;
            }

            .logout-confirm-title {
                margin: 0;
                font-size: 20px;
                font-weight: 800;
            }

            .logout-confirm-text {
                margin: 10px 0 0;
                color: #456482;
                font-size: 14px;
                line-height: 1.5;
            }

            .logout-confirm-actions {
                margin-top: 16px;
                display: flex;
                justify-content: flex-end;
                gap: 10px;
            }

            .logout-confirm-btn {
                border: none;
                border-radius: 10px;
                padding: 9px 14px;
                font-weight: 700;
                cursor: pointer;
                min-width: 96px;
            }

            /* Requested color swap: OK uses cancel color, Cancel uses OK color. */
            .logout-confirm-btn.ok {
                background: #ff5e62;
                color: #ffffff;
            }

            .logout-confirm-btn.cancel {
                background: #0BA4A1;
                color: #ffffff;
            }

            @media (max-width: 980px) {
                .global-glass-layout {
                    grid-template-columns: 1fr;
                    gap: 14px;
                }

                .global-glass-divider {
                    display: none;
                }

                .global-profile-side {
                    width: 100%;
                }
            }

            html.dark-mode .logout-confirm-card {
                background: rgba(18, 32, 50, 0.96);
                border-color: rgba(70, 98, 126, 0.75);
                color: #d0e0f0;
            }

            html.dark-mode .logout-confirm-text {
                color: #a9bfd6;
            }

