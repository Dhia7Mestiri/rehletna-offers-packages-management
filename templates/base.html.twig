                position: absolute;
                top: -5px;
                right: -7px;
                min-width: 16px;
                height: 16px;
                border-radius: 999px;
                background: #ff5e62;
                color: #fff;
                font-size: 10px;
                font-weight: 800;
                display: none;
                align-items: center;
                justify-content: center;
                padding: 0 4px;
                box-shadow: 0 4px 10px rgba(217, 74, 90, 0.4);
            }

            .global-quick-badge.show {
                display: inline-flex;
            }

            .global-glass-overlay {
                position: fixed;
                inset: 0;
                background: rgba(255, 255, 255, 0.16);
                backdrop-filter: blur(1px);
                opacity: 0;
                pointer-events: none;
                transition: opacity 0.25s ease;
                z-index: 10001;
            }

            .global-glass-overlay.open {
                opacity: 1;
                pointer-events: auto;
            }

            .global-glass-panel {
                position: fixed;
                inset: 0;
                width: 100vw;
                height: 100vh;
                border-radius: 0;
                border: 1px solid rgba(163, 208, 232, 0.55);
                background:
                    linear-gradient(140deg, rgba(255, 255, 255, 0.62), rgba(238, 248, 255, 0.46)),
                    radial-gradient(420px 220px at 10% -10%, rgba(11, 164, 161, 0.12), transparent 72%);
