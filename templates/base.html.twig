    {% set currentLocale = app.request.locale|default('en') %}
    <body class="vision-theme-{{ app.request.session.get('vision_theme')|default('default') }}">
        <button id="globalQuickToggle" class="global-quick-toggle" type="button" aria-label="{{ 'panel.slide_me'|trans }}">⌄ {{ 'panel.slide_me'|trans }} ⌄<span id="globalQuickBadge" class="global-quick-badge">!</span></button>
        <div id="globalGlassOverlay" class="global-glass-overlay" aria-hidden="true"></div>
        <aside id="globalGlassPanel" class="global-glass-panel" aria-hidden="true">
            <div class="global-glass-head">
                <div class="global-glass-brand">{{ 'panel.control_title'|trans }}</div>
                <button id="globalGlassClose" class="global-glass-close" type="button" aria-label="{{ 'panel.close'|trans }}">x</button>
            </div>
            <div class="global-glass-layout">
                <div class="global-glass-actions">
                    <button id="globalThemeButton" class="global-action-btn settings" type="button" aria-label="{{ 'panel.dark_mode'|trans }}">
                        <span id="globalThemeIcon" class="global-action-icon">🌙</span>
                        <span id="globalThemeLabel">{{ 'panel.dark_mode'|trans }}</span>
                    </button>
                    <button id="globalCollectCoinBtn" class="global-action-btn global-action-coin" type="button" aria-label="{{ 'panel.collect'|trans }}" disabled>
                        <div class="global-coin-head">
                            <span class="global-action-icon">💎</span>
                            <span id="globalCoinCount" class="global-coin-count">0</span>
                        </div>
                        <div id="globalCoinTier" class="global-coin-tier">standard • +1</div>
                        <div id="globalCoinTimer" class="global-coin-timer">{{ 'panel.ready_to_collect'|trans }}</div>
                        <span id="globalCoinBtnLabel">{{ 'panel.collect'|trans }}</span>
                    </button>
                    <a id="globalUpgradeBtn" class="global-action-link upgrade" href="{{ path('app_premium') }}" aria-label="{{ 'panel.upgrade_plan'|trans }}" style="display: none;">
                        <span class="global-action-icon">⭐</span>
                        <span>{{ 'panel.upgrade_plan'|trans }}</span>
                    </a>
                    <a class="global-action-link settings" href="{{ path('app_settings') }}" data-no-loader="true" data-turbo="false" aria-label="{{ 'panel.settings'|trans }}">
                        <span class="global-action-icon">⚙</span>
                        <span>{{ 'panel.settings'|trans }}</span>
                    </a>
                    {% if app.user and is_granted('ROLE_USER') %}
                        <a class="global-action-link settings" href="{{ path('app_vision_test') }}" data-no-loader="true" data-turbo="false" aria-label="{{ 'panel.eye_test'|trans }}">
                            <span class="global-action-icon">👁️</span>
                            <span>{{ 'panel.eye_test'|trans }}</span>
                        </a>
                    {% endif %}
                    <div class="global-action-btn global-action-language settings">
                        <label for="languageSelect" class="global-language-title">🌍 {{ 'panel.language'|trans }}</label>
                        <select id="languageSelect" name="locale" class="global-language-select" onchange="window.location.href='/language/' + this.value;">
                            <option value="en" {% if currentLocale == 'en' %}selected{% endif %}>🇺🇸 {{ 'panel.language_en'|trans }}</option>
                            <option value="fr" {% if currentLocale == 'fr' %}selected{% endif %}>🇫🇷 {{ 'panel.language_fr'|trans }}</option>
                        </select>
                    </div>
                    <a id="globalLogoutLink" class="global-action-link power" href="{{ path('app_logout') }}" aria-label="{{ 'panel.logout'|trans }}">
                        <span class="global-action-icon">⏻</span>
                        <span>{{ 'panel.logout'|trans }}</span>
                    </a>
                </div>
                <div class="global-glass-divider" aria-hidden="true"></div>
                <aside class="global-profile-side" aria-label="Current user profile">
                    <img id="globalProfileAvatar" class="global-profile-avatar" src="{{ (app.user and app.user.profile and app.user.profile.imageUrl) ? app.user.profile.imageUrl : asset('images/default_image.png') }}" alt="User profile">
                    <div id="globalProfileName" class="global-profile-name">{{ app.user ? (app.user.fullName|default(app.user.username)) : 'Guest' }}</div>
                    <div id="globalProfileRole" class="global-profile-role">
                        {% if app.user and 'ROLE_ADMIN' in app.user.roles %}
                            ADMIN
                        {% elseif app.user and 'ROLE_GUIDE' in app.user.roles %}
                            GUIDE
                        {% elseif app.user and 'ROLE_AGENCY' in app.user.roles %}
                            AGENCY
                        {% else %}
                            USER
                        {% endif %}
                    </div>
                    <button id="globalTwoFactorBtn" class="global-profile-twofa" type="button" aria-label="Toggle 2FA">
                        <span class="global-action-icon">🛡️</span>
                        <span id="globalTwoFactorLabel">Enable 2FA</span>
                    </button>
                    <button id="globalQrEmailBtn" class="global-profile-qr" type="button" aria-label="Send login QR">
                        <span class="global-action-icon">📧</span>
                        <span id="globalQrEmailLabel">Send QR Code</span>
                    </button>
                    <button id="globalFaceIdBtn" class="global-profile-faceid" type="button" aria-label="Capture face id">
                        <span class="global-action-icon">📷</span>
                        <span id="globalFaceIdLabel">Face Id</span>
                    </button>
                </aside>
            </div>
        </aside>
        <div id="globalLoader" class="global-loader" aria-hidden="true">
            <img class="global-loader-logo" src="{{ asset('images/logo.png') }}" alt="Rehletna logo">
            <div id="globalLoaderText" class="global-loader-text">{{ 'panel.loading_page'|trans }}</div>
            <div class="global-loader-dots" aria-label="Loading">
                <span></span>
                <span></span>
                <span></span>
            </div>
        </div>
        <div id="logoutConfirmModal" class="logout-confirm-modal" aria-hidden="true">
            <div class="logout-confirm-backdrop" id="logoutConfirmBackdrop"></div>
            <div class="logout-confirm-card" role="dialog" aria-modal="true" aria-labelledby="logoutConfirmTitle">
                <h3 id="logoutConfirmTitle" class="logout-confirm-title">Confirm Logout</h3>
                <p class="logout-confirm-text">Are you sure you want to log out?</p>
                <div class="logout-confirm-actions">
                    <button id="logoutConfirmCancel" type="button" class="logout-confirm-btn cancel">Cancel</button>
                    <button id="logoutConfirmOk" type="button" class="logout-confirm-btn ok">OK</button>
                </div>
            </div>
        </div>
        <div id="globalFaceModal" class="global-face-modal" aria-hidden="true">
            <div id="globalFaceModalBackdrop" class="global-face-modal-backdrop"></div>
            <div class="global-face-modal-card" role="dialog" aria-modal="true" aria-labelledby="globalFaceModalTitle">
                <div class="global-face-modal-head">
                    <h3 id="globalFaceModalTitle" class="global-face-modal-title">Capture Face Id</h3>
                    <button id="globalFaceModalClose" class="global-face-modal-close" type="button" aria-label="Close">x</button>
                </div>
                <div class="global-face-modal-body">
                    <div class="global-face-video-wrap">
                        <video id="globalFaceVideo" class="global-face-video" autoplay playsinline muted></video>
                        <img id="globalFacePreview" class="global-face-preview" alt="Captured face preview">
                    </div>
                    <p id="globalFaceStatus" class="global-face-status">Allow camera access, center your face, then capture.</p>
                    <div class="global-face-actions">
                        <button id="globalFaceCaptureBtn" class="global-face-btn capture" type="button">Capture</button>
                        <button id="globalFaceRetakeBtn" class="global-face-btn cancel" type="button" style="display:none;">Retake</button>
                        <button id="globalFaceSaveBtn" class="global-face-btn capture" type="button" style="display:none;">Save</button>
                        <button id="globalFaceCancelBtn" class="global-face-btn cancel" type="button">Cancel</button>
                    </div>
                </div>
            </div>
        </div>
        {% block body %}{% endblock %}
        <script>
            (function () {
                const loader = document.getElementById('globalLoader');
                const loaderText = document.getElementById('globalLoaderText');
                const globalQuickToggle = document.getElementById('globalQuickToggle');
                const globalGlassOverlay = document.getElementById('globalGlassOverlay');
                const globalGlassPanel = document.getElementById('globalGlassPanel');
                const globalGlassClose = document.getElementById('globalGlassClose');
                const globalThemeButton = document.getElementById('globalThemeButton');
                const globalThemeIcon = document.getElementById('globalThemeIcon');
                const globalThemeLabel = document.getElementById('globalThemeLabel');
                const globalQuickBadge = document.getElementById('globalQuickBadge');
                const globalCollectCoinBtn = document.getElementById('globalCollectCoinBtn');
                const globalUpgradeBtn = document.getElementById('globalUpgradeBtn');
                const globalCoinCount = document.getElementById('globalCoinCount');
                const globalCoinTier = document.getElementById('globalCoinTier');
                const globalCoinTimer = document.getElementById('globalCoinTimer');
                const globalCoinBtnLabel = document.getElementById('globalCoinBtnLabel');
                const globalLogoutLink = document.getElementById('globalLogoutLink');
                const globalTwoFactorBtn = document.getElementById('globalTwoFactorBtn');
                const globalTwoFactorLabel = document.getElementById('globalTwoFactorLabel');
                const globalQrEmailBtn = document.getElementById('globalQrEmailBtn');
                const globalQrEmailLabel = document.getElementById('globalQrEmailLabel');
                const globalFaceIdBtn = document.getElementById('globalFaceIdBtn');
                const globalFaceIdLabel = document.getElementById('globalFaceIdLabel');
                const globalFaceModal = document.getElementById('globalFaceModal');
                const globalFaceModalBackdrop = document.getElementById('globalFaceModalBackdrop');
                const globalFaceModalClose = document.getElementById('globalFaceModalClose');
                const globalFaceVideo = document.getElementById('globalFaceVideo');
                const globalFacePreview = document.getElementById('globalFacePreview');
                const globalFaceStatus = document.getElementById('globalFaceStatus');
                const globalFaceCaptureBtn = document.getElementById('globalFaceCaptureBtn');
                const globalFaceRetakeBtn = document.getElementById('globalFaceRetakeBtn');
                const globalFaceSaveBtn = document.getElementById('globalFaceSaveBtn');
                const globalFaceCancelBtn = document.getElementById('globalFaceCancelBtn');
                const globalProfileAvatar = document.getElementById('globalProfileAvatar');
                const globalProfileName = document.getElementById('globalProfileName');
                const globalProfileRole = document.getElementById('globalProfileRole');
                const logoutConfirmModal = document.getElementById('logoutConfirmModal');
                const logoutConfirmBackdrop = document.getElementById('logoutConfirmBackdrop');
                const logoutConfirmCancel = document.getElementById('logoutConfirmCancel');
                const logoutConfirmOk = document.getElementById('logoutConfirmOk');
                const panelText = {
                    darkMode: '{{ 'panel.dark_mode'|trans|e('js') }}',
                    lightMode: '{{ 'panel.light_mode'|trans|e('js') }}',
                    collectNow: '{{ 'panel.collect_now'|trans|e('js') }}',
                    collectingSoon: '{{ 'panel.collecting_soon'|trans|e('js') }}',
                    collecting: '{{ 'panel.collecting'|trans|e('js') }}',
                    readyToCollect: '{{ 'panel.ready_to_collect'|trans|e('js') }}',
                    availableIn: '{{ 'panel.available_in'|trans({'%seconds%': '__SECONDS__'})|e('js') }}',
                    returningMain: '{{ 'panel.returning_main'|trans|e('js') }}'
                };
                let dragStartY = 0;
                let dragDistance = 0;
                let isDraggingToggle = false;
                let coinCooldownRemaining = 0;
                let coinCountdownInterval = null;
                let faceStream = null;
                let capturedFaceImageData = '';

                if (!loader) {
                    return;
                }

                const showLoader = (text) => {
                    if (loaderText && text) {
                        loaderText.textContent = text;
                    }
                    loader.classList.add('active');
                    loader.setAttribute('aria-hidden', 'false');
                };

                const hideLoader = () => {
                    loader.classList.remove('active');
                    loader.setAttribute('aria-hidden', 'true');
                };

                const syncThemeIcon = () => {
                    if (!globalThemeIcon || !globalThemeLabel) {
                        return;
                    }
                    const isDark = document.documentElement.classList.contains('dark-mode') || document.body.classList.contains('dark-mode');
                    globalThemeIcon.textContent = isDark ? '☀️' : '🌙';
                    globalThemeLabel.textContent = isDark ? panelText.lightMode : panelText.darkMode;
                };

                const syncCoinNotification = () => {
                    if (!globalQuickBadge) {
                        return;
                    }
                    if (coinCooldownRemaining <= 0) {
                        globalQuickBadge.classList.add('show');
                    } else {
                        globalQuickBadge.classList.remove('show');
                    }
                };

                const updateCoinUi = () => {
                    if (!globalCollectCoinBtn || !globalCoinTimer || !globalCoinBtnLabel) {
                        return;
                    }

                    const isReady = coinCooldownRemaining <= 0;
                    globalCollectCoinBtn.disabled = !isReady;
                    globalCoinBtnLabel.textContent = isReady ? panelText.collectNow : panelText.collectingSoon;
                    globalCoinTimer.textContent = isReady
                        ? panelText.readyToCollect
                        : panelText.availableIn.replace('__SECONDS__', String(coinCooldownRemaining));
                    const progress = Math.max(0, Math.min(100, ((30 - coinCooldownRemaining) / 30) * 100));
                    
                    // Update collect coin button progress line only
                    globalCollectCoinBtn.style.setProperty('--coin-button-progress', progress + '%');
                    
                    syncCoinNotification();
                };

                const startCoinCountdown = (seconds) => {
                    coinCooldownRemaining = Math.max(0, parseInt(seconds || 0, 10));
                    updateCoinUi();

                    if (coinCountdownInterval) {
                        clearInterval(coinCountdownInterval);
                    }

                    if (coinCooldownRemaining <= 0) {
                        return;
                    }

                    coinCountdownInterval = window.setInterval(() => {
                        coinCooldownRemaining = Math.max(0, coinCooldownRemaining - 1);
                        updateCoinUi();
                        if (coinCooldownRemaining <= 0) {
                            clearInterval(coinCountdownInterval);
                            coinCountdownInterval = null;
                        }
                    }, 1000);
                };

                const loadCoinStatus = () => {
                    if (!globalCollectCoinBtn) {
                        return;
                    }

                    fetch('{{ path('app_collect_coin_status') }}', {
                        credentials: 'same-origin',
                        headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    })
                        .then((response) => {
                            if (!response.ok) {
                                throw new Error('coin-status-failed');
                            }
                            return response.json();
                        })
                        .then((payload) => {
                            if (!payload || !payload.success) {
                                return;
                            }

                            if (globalCoinCount) {
                                globalCoinCount.textContent = String(payload.coins || 0);
                            }
                            if (globalCoinTier) {
                                const tierLabel = String(payload.tier || 'standard').toLowerCase();
                                globalCoinTier.textContent = tierLabel + ' • +' + String(payload.reward || 1);
                            }
                            startCoinCountdown(payload.cooldownRemaining || 0);
                        })
                        .catch(() => {
                            // Keep panel usable even if status endpoint is not available for this page.
                        });
                };

                const checkUpgradeButton = () => {
                    if (!globalUpgradeBtn) {
                        return;
                    }

                    fetch('{{ path('app_collect_coin_status') }}', {
                        credentials: 'same-origin',
                        headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    })
                        .then((response) => response.json())
                        .then((payload) => {
                            if (payload && payload.tier) {
                                const tier = String(payload.tier).toLowerCase();
                                if (tier === 'standard') {
                                    globalUpgradeBtn.style.display = 'flex';
                                } else {
                                    globalUpgradeBtn.style.display = 'none';
                                }
                            }
                        })
                        .catch(() => {
                            // Don't show button if we can't determine tier
                            globalUpgradeBtn.style.display = 'none';
                        });
                };

                const collectCoins = () => {
                    if (!globalCollectCoinBtn || globalCollectCoinBtn.disabled) {
                        return;
                    }

                    globalCollectCoinBtn.disabled = true;
                    globalCoinBtnLabel.textContent = panelText.collecting;

                    fetch('{{ path('app_collect_coin') }}', {
                        method: 'POST',
                        credentials: 'same-origin',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                            'X-Requested-With': 'XMLHttpRequest'
                        },
                        body: ''
                    })
                        .then((response) => response.json())
                        .then((payload) => {
                            if (!payload || !payload.success) {
                                startCoinCountdown(payload && payload.cooldownRemaining ? payload.cooldownRemaining : 0);
                                return;
                            }

                            if (globalCoinCount) {
                                globalCoinCount.textContent = String(payload.coins || 0);
                            }
                            if (globalCoinTier) {
                                const tierLabel = String(payload.tier || 'standard').toLowerCase();
                                globalCoinTier.textContent = tierLabel + ' • +' + String(payload.awarded || 1);
                            }
                            startCoinCountdown(payload.cooldownRemaining || 30);
                        })
                        .catch(() => {
                            loadCoinStatus();
                        });
                };

                const loadProfileSummary = () => {
                    fetch('{{ path('app_panel_profile_summary') }}', {
                        credentials: 'same-origin',
                        headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    })
                        .then((response) => {
                            if (!response.ok) {
                                throw new Error('profile-summary-failed');
                            }
                            return response.json();
                        })
                        .then((payload) => {
                            if (!payload || !payload.success) {
                                return;
                            }

                            if (globalProfileAvatar && payload.imageUrl) {
                                globalProfileAvatar.src = payload.imageUrl;
                            }
                            if (globalProfileName && payload.name) {
                                globalProfileName.textContent = payload.name;
                            }
                            if (globalProfileRole && payload.role) {
                                globalProfileRole.textContent = payload.role;
                            }

                            const isEnabled = !!payload.twoFactorEnabled;
                            if (globalTwoFactorBtn) {
                                globalTwoFactorBtn.classList.toggle('active', isEnabled);
                            }
                            if (globalTwoFactorLabel) {
                                globalTwoFactorLabel.textContent = isEnabled ? 'Disable 2FA' : 'Enable 2FA';
                            }
                        })
                        .catch(() => {
                            // Keep defaults if summary endpoint is unavailable.
                        });
                };

                const openGlassPanel = () => {
                    if (!globalGlassPanel || !globalGlassOverlay) {
                        return;
                    }
                    globalGlassPanel.classList.add('open');
                    globalGlassOverlay.classList.add('open');
                    globalGlassPanel.setAttribute('aria-hidden', 'false');
                    globalGlassOverlay.setAttribute('aria-hidden', 'false');
                    loadProfileSummary();
                };

                const closeGlassPanel = () => {
                    if (!globalGlassPanel || !globalGlassOverlay) {
                        return;
                    }
                    globalGlassPanel.classList.remove('open');
                    globalGlassOverlay.classList.remove('open');
                    globalGlassPanel.setAttribute('aria-hidden', 'true');
                    globalGlassOverlay.setAttribute('aria-hidden', 'true');
                };

                const openLogoutConfirm = () => {
                    if (!logoutConfirmModal) {
                        return;
                    }
                    logoutConfirmModal.classList.add('open');
                    logoutConfirmModal.setAttribute('aria-hidden', 'false');
                };

                const closeLogoutConfirm = () => {
                    if (!logoutConfirmModal) {
                        return;
                    }
                    logoutConfirmModal.classList.remove('open');
                    logoutConfirmModal.setAttribute('aria-hidden', 'true');
                };

                const resetFaceCaptureState = () => {
                    capturedFaceImageData = '';

                    if (globalFacePreview) {
                        globalFacePreview.removeAttribute('src');
                        globalFacePreview.style.display = 'none';
                    }

                    if (globalFaceVideo) {
                        globalFaceVideo.style.display = 'block';
                    }

                    if (globalFaceCaptureBtn) {
                        globalFaceCaptureBtn.style.display = 'inline-flex';
                        globalFaceCaptureBtn.disabled = false;
                    }

                    if (globalFaceRetakeBtn) {
                        globalFaceRetakeBtn.style.display = 'none';
                        globalFaceRetakeBtn.disabled = false;
                    }

                    if (globalFaceSaveBtn) {
                        globalFaceSaveBtn.style.display = 'none';
                        globalFaceSaveBtn.disabled = false;
                    }
                };

                const setFaceStatus = (text) => {
                    if (globalFaceStatus) {
                        globalFaceStatus.textContent = text;
                    }
                };

                const stopFaceCamera = () => {
                    if (faceStream) {
                        faceStream.getTracks().forEach((track) => track.stop());
                        faceStream = null;
                    }

                    if (globalFaceVideo) {
                        globalFaceVideo.pause();
                        globalFaceVideo.srcObject = null;
                    }
                };

                const closeFaceModal = () => {
                    stopFaceCamera();
                    resetFaceCaptureState();
                    if (globalFaceModal) {
                        globalFaceModal.classList.remove('open');
                        globalFaceModal.setAttribute('aria-hidden', 'true');
                    }
                };

                const openFaceModal = async () => {
                    if (!globalFaceModal || !globalFaceVideo) {
                        return;
                    }

                    if (!navigator.mediaDevices || typeof navigator.mediaDevices.getUserMedia !== 'function') {
                        setFaceStatus('Camera is not supported in this browser.');
                        return;
                    }

                    try {
                        setFaceStatus('Requesting camera access...');
                        globalFaceModal.classList.add('open');
                        globalFaceModal.setAttribute('aria-hidden', 'false');

                        faceStream = await navigator.mediaDevices.getUserMedia({
                            video: {
                                facingMode: 'user',
                                width: { ideal: 640 },
                                height: { ideal: 480 }
                            },
                            audio: false
                        });

                        globalFaceVideo.srcObject = faceStream;
                        await globalFaceVideo.play();
                        resetFaceCaptureState();
                        setFaceStatus('Center your face, then click Capture & Save.');
                    } catch (error) {
                        closeFaceModal();
                        setFaceStatus('Unable to access camera. Please allow permission and try again.');
                        if (globalFaceIdLabel) {
                            globalFaceIdLabel.textContent = 'Face Id';
                        }
                    }
                };

                const captureFacePreview = () => {
                    if (!globalFaceVideo || !globalFaceVideo.videoWidth || !globalFaceVideo.videoHeight) {
                        setFaceStatus('Camera not ready. Please try again.');
                        return;
                    }

                    const canvas = document.createElement('canvas');
                    const displayWidth = Math.max(1, globalFaceVideo.clientWidth || 0);
                    const displayHeight = Math.max(1, globalFaceVideo.clientHeight || 0);

                    canvas.width = displayWidth;
                    canvas.height = displayHeight;

                    const context = canvas.getContext('2d');
                    if (!context) {
                        setFaceStatus('Capture failed.');
                        return;
                    }

                    context.drawImage(globalFaceVideo, 0, 0, displayWidth, displayHeight);
                    capturedFaceImageData = canvas.toDataURL('image/jpeg', 0.9);

                    if (globalFacePreview) {
                        globalFacePreview.src = capturedFaceImageData;
                        globalFacePreview.style.display = 'block';
                    }

                    globalFaceVideo.style.display = 'none';

                    if (globalFaceCaptureBtn) {
                        globalFaceCaptureBtn.style.display = 'none';
                    }

                    if (globalFaceRetakeBtn) {
                        globalFaceRetakeBtn.style.display = 'inline-flex';
                    }

                    if (globalFaceSaveBtn) {
                        globalFaceSaveBtn.style.display = 'inline-flex';
                    }

                    setFaceStatus('Preview ready. Save it or retake.');
                };

                const saveCapturedFace = () => {
                    if (!capturedFaceImageData) {
                        setFaceStatus('Capture photo first.');
                        return;
                    }

                    if (globalFaceSaveBtn) {
                        globalFaceSaveBtn.disabled = true;
                    }
                    if (globalFaceRetakeBtn) {
                        globalFaceRetakeBtn.disabled = true;
                    }
                    setFaceStatus('Saving face data...');

                    fetch('{{ path('app_panel_capture_face_id') }}', {
                        method: 'POST',
                        credentials: 'same-origin',
                        headers: {
                            'Content-Type': 'application/json',
                            'X-Requested-With': 'XMLHttpRequest'
                        },
                        body: JSON.stringify({ imageData: capturedFaceImageData })
                    })
                        .then((response) => response.json())
                        .then((payload) => {
                            if (!payload || !payload.success) {
                                setFaceStatus('Face save failed. Please retry.');
                                return;
                            }

                            setFaceStatus('Face data saved successfully.');
                            if (globalFaceIdLabel) {
                                globalFaceIdLabel.textContent = 'Face saved';
                                window.setTimeout(() => {
                                    globalFaceIdLabel.textContent = 'Face Id';
                                }, 2200);
                            }
                            window.setTimeout(() => {
                                closeFaceModal();
                            }, 500);
                        })
                        .catch(() => {
                            setFaceStatus('Face save failed. Please retry.');
                        })
                        .finally(() => {
                            if (globalFaceSaveBtn) {
                                globalFaceSaveBtn.disabled = false;
                            }
                            if (globalFaceRetakeBtn) {
                                globalFaceRetakeBtn.disabled = false;
                            }
                        });
                };

                const retakeCapturedFace = () => {
                    resetFaceCaptureState();
                    setFaceStatus('Retake ready. Center your face and capture again.');
                };

                window.showGlobalLoader = showLoader;
                window.hideGlobalLoader = hideLoader;

                syncThemeIcon();

                if (globalQuickToggle) {
                    const resetTogglePosition = function () {
                        globalQuickToggle.classList.remove('dragging');
                        globalQuickToggle.style.top = '6px';
                        dragDistance = 0;
                        isDraggingToggle = false;
                    };

                    globalQuickToggle.addEventListener('pointerdown', function (event) {
                        dragStartY = event.clientY;
                        dragDistance = 0;
                        isDraggingToggle = true;
                        globalQuickToggle.classList.add('dragging');
                        globalQuickToggle.setPointerCapture(event.pointerId);
                    });

                    globalQuickToggle.addEventListener('pointermove', function (event) {
                        if (!isDraggingToggle) {
                            return;
                        }
                        dragDistance = Math.max(0, Math.min(70, event.clientY - dragStartY));
                        globalQuickToggle.style.top = (6 + dragDistance) + 'px';
                    });

                    globalQuickToggle.addEventListener('pointerup', function (event) {
                        if (!isDraggingToggle) {
                            return;
                        }
                        if (dragDistance >= 38) {
                            if (globalGlassPanel && globalGlassPanel.classList.contains('open')) {
                                closeGlassPanel();
                            } else {
                                openGlassPanel();
                            }
                        }
                        resetTogglePosition();
                        globalQuickToggle.releasePointerCapture(event.pointerId);
                    });

                    globalQuickToggle.addEventListener('pointercancel', function () {
                        resetTogglePosition();
                    });
                }

                if (globalGlassOverlay) {
                    globalGlassOverlay.addEventListener('click', closeGlassPanel);
                }

                if (globalGlassClose) {
                    globalGlassClose.addEventListener('click', closeGlassPanel);
                }

                if (globalThemeButton) {
                    globalThemeButton.addEventListener('click', function () {
                        if (window.toggleTheme) {
                            window.toggleTheme();
                        }
                        syncThemeIcon();
                    });
                }

                if (globalLogoutLink) {
                    globalLogoutLink.addEventListener('click', function (event) {
                        event.preventDefault();
                        closeGlassPanel();
                        hideLoader();
                        openLogoutConfirm();
                    });
                }

                if (logoutConfirmBackdrop) {
                    logoutConfirmBackdrop.addEventListener('click', function () {
                        closeLogoutConfirm();
                        hideLoader();
                    });
                }

                if (logoutConfirmCancel) {
                    logoutConfirmCancel.addEventListener('click', function () {
                        closeLogoutConfirm();
                        hideLoader();
                    });
                }

                if (logoutConfirmOk) {
                    logoutConfirmOk.addEventListener('click', function () {
                        if (!globalLogoutLink) {
                            closeLogoutConfirm();
                            return;
                        }
                        closeLogoutConfirm();
                        showLoader('Signing you out...');
                        window.location.assign(globalLogoutLink.href);
                    });
                }

                if (globalCollectCoinBtn) {
                    globalCollectCoinBtn.addEventListener('click', collectCoins);
                }

                if (globalTwoFactorBtn) {
                    globalTwoFactorBtn.addEventListener('click', function () {
                        fetch('{{ path('app_panel_toggle_2fa') }}', {
                            method: 'POST',
                            credentials: 'same-origin',
                            headers: {
                                'X-Requested-With': 'XMLHttpRequest'
                            }
                        })
                            .then((response) => response.json())
                            .then((payload) => {
                                if (!payload || !payload.success) {
                                    return;
                                }

                                const isEnabled = !!payload.enabled;
                                globalTwoFactorBtn.classList.toggle('active', isEnabled);
                                if (globalTwoFactorLabel) {
                                    globalTwoFactorLabel.textContent = isEnabled ? 'Disable 2FA' : 'Enable 2FA';
                                }
                            })
                            .catch(() => {
                                // Keep UI unchanged if the request fails.
                            });
                    });
                }

                if (globalQrEmailBtn) {
                    globalQrEmailBtn.addEventListener('click', function () {
                        if (globalQrEmailLabel) {
                            globalQrEmailLabel.textContent = 'Sending...';
                        }

                        fetch('{{ path('app_panel_send_credentials_qr') }}', {
                            method: 'POST',
                            credentials: 'same-origin',
                            headers: {
                                'X-Requested-With': 'XMLHttpRequest'
                            }
                        })
                            .then((response) => response.json())
                            .then((payload) => {
                                if (!payload || !payload.success) {
                                    if (globalQrEmailLabel) {
                                        globalQrEmailLabel.textContent = 'Send failed';
                                    }
                                    return;
                                }

                                if (globalQrEmailLabel) {
                                    globalQrEmailLabel.textContent = 'QR sent to email';
                                    window.setTimeout(() => {
                                        globalQrEmailLabel.textContent = 'Send QR Code';
                                    }, 2000);
                                }
                            })
                            .catch(() => {
                                if (globalQrEmailLabel) {
                                    globalQrEmailLabel.textContent = 'Send failed';
                                    window.setTimeout(() => {
                                        globalQrEmailLabel.textContent = 'Send QR Code';
                                    }, 2000);
                                }
                            });
                    });
                }

                if (globalFaceIdBtn) {
                    globalFaceIdBtn.addEventListener('click', function () {
                        if (globalFaceIdLabel) {
                            globalFaceIdLabel.textContent = 'Opening camera...';
                        }

                        openFaceModal().finally(() => {
                            if (globalFaceIdLabel && globalFaceIdLabel.textContent === 'Opening camera...') {
                                globalFaceIdLabel.textContent = 'Face Id';
                            }
                        });
                    });
                }

                if (globalFaceCaptureBtn) {
                    globalFaceCaptureBtn.addEventListener('click', captureFacePreview);
                }

                if (globalFaceRetakeBtn) {
                    globalFaceRetakeBtn.addEventListener('click', retakeCapturedFace);
                }

                if (globalFaceSaveBtn) {
                    globalFaceSaveBtn.addEventListener('click', saveCapturedFace);
                }

                if (globalFaceCancelBtn) {
                    globalFaceCancelBtn.addEventListener('click', closeFaceModal);
                }

                if (globalFaceModalBackdrop) {
                    globalFaceModalBackdrop.addEventListener('click', closeFaceModal);
                }

                if (globalFaceModalClose) {
                    globalFaceModalClose.addEventListener('click', closeFaceModal);
                }

                loadCoinStatus();
                checkUpgradeButton();
                loadProfileSummary();

                window.addEventListener('themechange', syncThemeIcon);
                window.addEventListener('pageshow', function () {
                    hideLoader();
                    closeGlassPanel();
                    closeFaceModal();
                });
                window.addEventListener('load', function () {
                    hideLoader();
                    closeGlassPanel();
                    closeFaceModal();
                });
                document.addEventListener('visibilitychange', function () {
                    if (document.visibilityState === 'visible') {
                        hideLoader();
                        closeGlassPanel();
                    }
                });

                document.addEventListener('keydown', function (event) {
                    if (event.key === 'Escape') {
                        closeGlassPanel();
                        closeLogoutConfirm();
                        closeFaceModal();
                    }
                });

                document.addEventListener('click', function (event) {
                    const backMainButton = event.target.closest('.back-main-btn');
                    if (!backMainButton) {
                        return;
                    }

                    const href = backMainButton.getAttribute('href');
                    if (!href) {
                        return;
                    }

                    event.preventDefault();
                    showLoader(panelText.returningMain);
                    window.location.assign(href);
                });

                document.addEventListener('click', function (event) {
                    const settingsLink = event.target.closest('.global-action-link.settings');
                    if (!settingsLink) {
                        return;
                    }

                    const href = settingsLink.getAttribute('href');
                    if (!href) {
                        return;
                    }

                    event.preventDefault();
                    closeGlassPanel();
                    window.location.assign(href);
                });

                document.addEventListener('click', function (event) {
                    const panelLink = event.target.closest('#globalGlassPanel a[href]');
                    if (!panelLink) {
                        return;
                    }

                    closeGlassPanel();
                });

                document.addEventListener('click', (event) => {
                    if (event.defaultPrevented) {
                        return;
                    }

                    const link = event.target.closest('a[href]');
                    if (!link) {
                        return;
                    }

                    const href = link.getAttribute('href') || '';
                    if (
                        href.startsWith('#') ||
                        href.startsWith('mailto:') ||
                        href.startsWith('tel:') ||
                        href.startsWith('javascript:') ||
                        link.target === '_blank' ||
                        link.hasAttribute('download') ||
                        link.dataset.noLoader === 'true'
                    ) {
                        return;
                    }

                    const url = new URL(link.href, window.location.origin);
                    if (url.origin !== window.location.origin) {
                        return;
                    }

                    showLoader('Opening page...');
                });

                document.addEventListener('submit', (event) => {
                    const form = event.target;
                    if (!(form instanceof HTMLFormElement)) {
                        return;
                    }

                    if (form.dataset.noLoader === 'true') {
                        return;
                    }

                    showLoader('Loading...');
                });
            })();
        </script>
    </body>
</html>
