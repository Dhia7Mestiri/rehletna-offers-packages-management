                border-radius: 10px;
                padding: 8px 12px;
                font-size: 12px;
                font-weight: 800;
                color: #ffffff;
                background: linear-gradient(135deg, #0fa5a2, #1788b6);
                cursor: pointer;
            }

            .global-coin-btn:disabled {
                cursor: not-allowed;
                opacity: 0.65;
            }

            /* Ready state for coin collection button */
            #globalCollectCoinBtn:not(:disabled)::before {
                width: 100%;
                background: linear-gradient(90deg, #51cf66, #37b24d);
            }

