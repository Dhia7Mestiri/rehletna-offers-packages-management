<link rel="stylesheet" href="{{ asset('css/app1.css') }}?v=1.1">
        <script>
            (function () {
                function getStoredTheme() {
                    return localStorage.getItem('theme') === 'dark' ? 'dark' : 'light';
                }

                function applyTheme(theme) {
                    var isDark = theme === 'dark';
                    document.documentElement.classList.toggle('dark-mode', isDark);
                    if (document.body) {
                        document.body.classList.toggle('dark-mode', isDark);
                    }
                }

                window.getStoredTheme = getStoredTheme;
                window.applyTheme = applyTheme;
                window.toggleTheme = function () {
                    var next = getStoredTheme() === 'dark' ? 'light' : 'dark';
                    localStorage.setItem('theme', next);
                    applyTheme(next);
                    window.dispatchEvent(new CustomEvent('themechange', { detail: { theme: next } }));
                    return next;
                };

                applyTheme(getStoredTheme());
                document.addEventListener('DOMContentLoaded', function () {
                    applyTheme(getStoredTheme());
                });
            })();
        </script>
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
        <style>
            html,
            body {
                margin: 0;
                padding: 0;
                min-height: 100%;
                border: 0;
                outline: 0;
                background: #f4f9ff;
                overflow-x: hidden;
            }

            html.dark-mode,
            html.dark-mode body {
                background: #121a27;
                color: #e8eef5;
            }

            html.dark-mode input,
            html.dark-mode textarea,
            html.dark-mode select,
            html.dark-mode button {
                color-scheme: dark;
            }

            .global-loader {
                position: fixed;
                inset: 0;
                display: none;
                align-items: center;
                justify-content: center;
                flex-direction: column;
                background: linear-gradient(140deg, rgba(4, 22, 38, 0.92), rgba(11, 69, 96, 0.9));
                z-index: 9999;
                color: #ffffff;
                text-align: center;
                padding: 24px;
            }

            .global-loader.active {
                display: flex;
            }

            .global-quick-toggle {
                position: fixed;
                top: 6px;
                left: 50%;
                transform: translateX(-50%);
                width: 156px;
                height: 34px;
                border-radius: 999px;
                border: 1px solid rgba(11, 164, 161, 0.4);
                background: rgba(255, 255, 255, 0.86);
                color: #1f3f5f;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                font-size: 13px;
                font-weight: 800;
                letter-spacing: 0.2px;
                white-space: nowrap;
                cursor: pointer;
                box-shadow: 0 8px 18px rgba(10, 46, 88, 0.18);
                z-index: 10003;
                transition: transform 0.2s ease, background-color 0.2s ease, box-shadow 0.2s ease, top 0.2s ease;
                backdrop-filter: blur(8px);
                user-select: none;
                touch-action: none;
            }

            .global-quick-toggle:hover {
                transform: translateX(-50%);
                background: #ffffff;
                color: #0b8e8b;
                border-color: rgba(11, 164, 161, 0.82);
                box-shadow: 0 0 12px rgba(45, 212, 191, 0.55), 0 0 26px rgba(56, 189, 248, 0.28);
            }

            .global-quick-toggle.dragging {
                transition: none;
            }

