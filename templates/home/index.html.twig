{% extends 'base.html.twig' %}

{% block title %}Home - Rehletna.tn{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700;800&display=swap');

        :root {
            --home-bg-deep: #050a1f;
            --home-bg-mid: #0a1d3c;
            --home-bg-light: #12315f;
            --home-line: rgba(125, 211, 252, 0.22);
            --home-cyan: #67e8f9;
            --home-blue: #93c5fd;
            --home-text: #e8f4ff;
            --home-muted: #b9cce4;
        }

        .home-landing {
            min-height: 100vh;
            background: linear-gradient(150deg, var(--home-bg-deep), var(--home-bg-mid) 52%, var(--home-bg-light));
            color: var(--home-text);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 36px 16px 44px;
            position: relative;
            overflow: hidden;
            isolation: isolate;
            font-family: 'Space Grotesk', 'Segoe UI', Tahoma, sans-serif;
        }

        .global-quick-toggle,
        .global-glass-overlay,
        .global-glass-panel {
            display: none !important;
        }

        .home-top-tools {
            position: fixed;
            top: 16px;
            left: 16px;
            z-index: 35;
            display: flex;
            gap: 0;
        }

        .home-top-icon {
            width: 44px;
            height: 44px;
            border-radius: 12px;
            border: 1px solid rgba(138, 220, 255, 0.55);
            background: rgba(8, 24, 47, 0.9);
            color: #e7f7ff;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            cursor: pointer;
            box-shadow: 0 10px 20px rgba(3, 13, 25, 0.4);
            transition: transform 0.2s ease, background-color 0.2s ease, color 0.2s ease;
            padding: 0;
        }

        .home-top-icon img {
            width: 28px;
            height: 28px;
            object-fit: cover;
            border-radius: 6px;
        }

        .home-top-icon:hover {
            transform: translateY(-2px);
            background: #ffffff;
            color: #0d355a;
        }

        .home-bg-layer {
            position: absolute;
            pointer-events: none;
        }

        .home-bg-layer.grid {
            inset: 0;
            background-image:
                linear-gradient(var(--home-line) 1px, transparent 1px),
                linear-gradient(90deg, var(--home-line) 1px, transparent 1px);
            background-size: 34px 34px;
            opacity: 0.23;
            z-index: 0;
        }

        .home-bg-layer.glow-a,
        .home-bg-layer.glow-b,
        .home-bg-layer.glow-c {
            border-radius: 999px;
            filter: blur(2px);
            z-index: 0;
            animation: floatPulse 9s ease-in-out infinite;
        }

        .home-bg-layer.glow-a {
            width: 520px;
            height: 520px;
            left: -120px;
            top: -170px;
            background: radial-gradient(circle, rgba(103, 232, 249, 0.28), transparent 70%);
        }

        .home-bg-layer.glow-b {
            width: 600px;
            height: 600px;
            right: -180px;
            top: -180px;
            animation-delay: -2.2s;
            background: radial-gradient(circle, rgba(129, 140, 248, 0.22), transparent 70%);
        }

        .home-bg-layer.glow-c {
            width: 520px;
            height: 520px;
            right: -80px;
            bottom: -220px;
            animation-delay: -4.6s;
            background: radial-gradient(circle, rgba(56, 189, 248, 0.2), transparent 72%);
        }

        .home-bg-layer.logo-halo {
            width: 450px;
            height: 450px;
            left: 50%;
            top: 50%;
            transform: translate(-50%, -52%);
            opacity: 0.08;
            background: url('{{ asset('images/logo.png') }}') center/contain no-repeat;
            z-index: 0;
            animation: breathe 7s ease-in-out infinite;
        }

        .home-card {
            width: min(1040px, 100%);
            border: 1px solid rgba(148, 197, 255, 0.28);
            border-radius: 28px;
            background:
                linear-gradient(150deg, rgba(14, 28, 54, 0.82), rgba(8, 23, 44, 0.82)),
                radial-gradient(280px 160px at 16% -20%, rgba(103, 232, 249, 0.14), transparent 70%);
            backdrop-filter: blur(10px);
            box-shadow: 0 24px 52px rgba(0, 0, 0, 0.34);
            padding: 34px 26px;
            text-align: center;
            position: relative;
            z-index: 2;
        }

        .home-card::before {
            content: '';
            position: absolute;
            inset: 0;
            border-radius: inherit;
            background: linear-gradient(120deg, rgba(103, 232, 249, 0.09), rgba(147, 197, 253, 0.04), rgba(255, 255, 255, 0));
            pointer-events: none;
        }

        .home-logo {
            width: min(240px, 72vw);
            height: auto;
            margin-bottom: 4px;
            filter: drop-shadow(0 8px 22px rgba(5, 17, 29, 0.6));
        }

        .home-title {
            margin: 4px 0 0;
            font-size: clamp(32px, 5.4vw, 58px);
            font-weight: 800;
            letter-spacing: 0.2px;
            color: #f2fbff;
            text-shadow: 0 8px 30px rgba(20, 190, 240, 0.22);
        }

        .home-subtitle {
            margin: 12px auto 0;
            max-width: 720px;
            color: var(--home-blue);
            font-size: clamp(15px, 2.5vw, 21px);
            line-height: 1.65;
        }

        .home-description {
            margin: 16px auto 0;
            max-width: 760px;
            color: #d9e9f8;
            font-size: 16px;
            line-height: 1.7;
        }

        .home-cta-row {
            margin-top: 30px;
            display: flex;
            gap: 12px;
            justify-content: center;
            flex-wrap: wrap;
        }

        .home-btn {
            min-width: 180px;
            border: 1px solid rgba(153, 220, 255, 0.45);
            border-radius: 12px;
            text-decoration: none;
            font-size: 15px;
            font-weight: 700;
            padding: 12px 20px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            transition: transform 0.25s ease, background-color 0.25s ease, color 0.25s ease, box-shadow 0.25s ease;
        }

        .home-btn-primary {
            background: linear-gradient(135deg, #2dd4bf, #38bdf8);
            color: #03253d;
            border-color: rgba(94, 234, 212, 0.75);
        }

        .home-btn-primary:hover {
            transform: translateY(-2px);
            background: #ffffff;
            color: #0d355a;
            box-shadow: 0 10px 24px rgba(56, 189, 248, 0.25);
        }

        .home-dev-team {
            margin-top: 34px;
            padding: 22px 14px 14px;
            border: 1px solid rgba(139, 197, 255, 0.24);
            border-radius: 18px;
            background: rgba(9, 28, 52, 0.5);
        }

        .home-dev-team h2 {
            margin: 0;
            font-size: 24px;
            color: #f2f9ff;
        }

        .home-dev-team p {
            margin: 6px 0 0;
            color: var(--home-muted);
            font-size: 15px;
        }

        .home-dev-grid {
            margin-top: 18px;
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 16px;
        }

        .home-dev-card {
            border: 1px solid rgba(148, 197, 255, 0.3);
            border-radius: 14px;
            padding: 14px 10px;
            background: rgba(9, 33, 59, 0.76);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 10px;
            min-height: 154px;
            transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
            cursor: pointer;
        }

        .home-dev-card:hover {
            border-color: #38bdf8;
            box-shadow: 0 0 12px rgba(56, 189, 248, 0.75), 0 0 22px rgba(56, 189, 248, 0.4);
            transform: translateY(-2px);
        }

        .home-dev-avatar {
            width: 84px;
            height: 84px;
            border-radius: 999px;
            border: 2px dashed rgba(153, 220, 255, 0.75);
            background: radial-gradient(circle at 35% 30%, rgba(103, 232, 249, 0.12), rgba(9, 28, 52, 0.85));
            box-shadow: inset 0 0 18px rgba(103, 232, 249, 0.12);
        }

        .home-dev-avatar.has-photo {
            border-style: solid;
            border-color: rgba(111, 224, 255, 0.95);
            background-position: center;
            background-repeat: no-repeat;
            background-size: cover;
            box-shadow: 0 0 0 3px rgba(8, 31, 55, 0.72), 0 0 22px rgba(56, 189, 248, 0.35);
        }

        .home-dev-name {
            margin: 0;
            color: #e8f4ff;
            font-size: 14px;
            font-weight: 700;
            text-align: center;
            line-height: 1.35;
        }

        .home-dev-name.placeholder {
            color: #9bb8d7;
            font-weight: 600;
        }

        .home-dev-modal {
            position: fixed;
            inset: 0;
            z-index: 25;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 18px;
            background: rgba(4, 13, 28, 0.34);
            backdrop-filter: blur(9px);
            opacity: 0;
            visibility: hidden;
            transition: opacity 0.22s ease, visibility 0.22s ease;
        }

        .home-landing.is-dev-open .home-card,
        .home-landing.is-dev-open .home-bg-layer {
            filter: blur(7px);
            transform: scale(0.995);
            transition: filter 0.25s ease, transform 0.25s ease;
        }

        .home-dev-modal.is-open {
            opacity: 1;
            visibility: visible;
        }

        .home-dev-modal-content {
            width: min(980px, 95vw);
            height: min(680px, 90vh);
            border-radius: 24px;
            border: 1px solid rgba(148, 197, 255, 0.34);
            background:
                linear-gradient(150deg, rgba(14, 28, 54, 0.9), rgba(8, 23, 44, 0.9)),
                radial-gradient(340px 220px at 18% -20%, rgba(103, 232, 249, 0.14), transparent 72%);
            box-shadow: 0 20px 48px rgba(0, 0, 0, 0.35);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #f2fbff;
            font-size: clamp(44px, 10vw, 94px);
            font-weight: 800;
            user-select: none;
            padding: clamp(22px, 4vw, 46px);
            text-align: left;
        }

        .home-dev-panel {
            width: min(760px, 100%);
            border: 1px solid rgba(135, 211, 255, 0.36);
            border-radius: 18px;
            background: linear-gradient(150deg, rgba(8, 22, 41, 0.72), rgba(7, 26, 49, 0.62));
            box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.07), 0 18px 34px rgba(0, 0, 0, 0.24);
            padding: clamp(18px, 2.8vw, 30px);
        }

        .home-dev-panel-head {
            display: flex;
            align-items: center;
            gap: 14px;
            margin-bottom: 14px;
        }

        .home-dev-panel-avatar {
            width: 64px;
            height: 64px;
            border-radius: 999px;
            border: 2px solid rgba(111, 224, 255, 0.9);
            background: radial-gradient(circle at 35% 30%, rgba(103, 232, 249, 0.22), rgba(9, 28, 52, 0.9));
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            box-shadow: 0 0 0 3px rgba(8, 31, 55, 0.7), 0 0 18px rgba(56, 189, 248, 0.25);
            flex-shrink: 0;
        }

        .home-dev-panel-meta {
            display: flex;
            flex-direction: column;
            gap: 6px;
            min-width: 0;
        }

        .home-dev-panel-name {
            margin: 0;
            color: #edf8ff;
            font-size: clamp(18px, 2.2vw, 24px);
            font-weight: 700;
            line-height: 1.2;
        }

        .home-dev-panel-tag {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 6px 12px;
            border-radius: 999px;
            border: 1px solid rgba(108, 225, 255, 0.46);
            color: #a7efff;
            font-size: 12px;
            font-weight: 700;
            letter-spacing: 0.3px;
            text-transform: uppercase;
            margin-bottom: 12px;
        }

        .home-dev-panel h3 {
            margin: 0;
            color: #f3fbff;
            font-size: clamp(28px, 4vw, 44px);
            line-height: 1.15;
            text-shadow: 0 8px 26px rgba(56, 189, 248, 0.24);
        }

        .home-dev-panel p {
            margin: 14px 0 0;
            color: #d8ebff;
            font-size: clamp(16px, 1.8vw, 21px);
            line-height: 1.75;
            font-weight: 500;
        }

        .home-contact {
            margin-top: 36px;
            border: 1px solid rgba(139, 197, 255, 0.24);
            background: rgba(9, 28, 52, 0.58);
            border-radius: 18px;
            padding: 22px 16px 16px;
        }

        .home-contact h2 {
            margin: 0 0 6px;
            font-size: 24px;
            color: #f2f9ff;
        }

        .home-contact p {
            margin: 0;
            color: var(--home-muted);
            font-size: 15px;
        }

        .home-socials {
            margin-top: 18px;
            display: flex;
            gap: 12px;
            justify-content: center;
            flex-wrap: wrap;
        }

        .home-social {
            padding: 12px 14px;
            border-radius: 12px;
            border: 1px solid rgba(148, 197, 255, 0.34);
            color: #e8f6ff;
            text-decoration: none;
            background: rgba(10, 38, 66, 0.78);
            display: inline-flex;
            gap: 8px;
            align-items: center;
            min-width: 178px;
            font-size: 14px;
            font-weight: 700;
            justify-content: center;
            transition: transform 0.2s ease, background-color 0.2s ease, color 0.2s ease, box-shadow 0.2s ease;
        }

        .home-social:hover {
            transform: translateY(-2px);
            background: #ffffff;
            color: #0d355a;
            box-shadow: 0 8px 20px rgba(56, 189, 248, 0.2);
        }

        .home-social-icon {
            width: 22px;
            height: 22px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 999px;
            background: rgba(103, 232, 249, 0.16);
            font-size: 12px;
            font-weight: 800;
        }

        html.dark-mode .home-card {
            background: rgba(9, 22, 40, 0.86);
        }

        @keyframes floatPulse {
            0%,
            100% {
                transform: translateY(0px);
            }
            50% {
                transform: translateY(12px);
            }
        }

        @keyframes breathe {
            0%,
            100% {
                opacity: 0.07;
                transform: translate(-50%, -52%) scale(1);
            }
            50% {
                opacity: 0.11;
                transform: translate(-50%, -52%) scale(1.04);
            }
        }

        @media (max-width: 700px) {
            .home-card {
                padding: 24px 16px;
            }

            .home-top-tools {
                top: 12px;
                left: 12px;
            }

            .home-top-icon {
                width: 40px;
                height: 40px;
                font-size: 16px;
            }

            .home-btn {
                width: 100%;
            }

            .home-social {
                width: 100%;
                min-width: 0;
            }

            .home-dev-grid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        @media (max-width: 430px) {
            .home-dev-grid {
                grid-template-columns: minmax(0, 1fr);
            }
        }
    </style>
{% endblock %}

{% block body %}
<section class="home-landing">
    <div class="home-top-tools" aria-label="Page tools">
        <button type="button" class="home-top-icon" id="langToggleBtn" aria-label="Toggle language French and English" title="FR / EN">
            <img id="langFlagImg" src="{{ asset('images/usa.png') }}" alt="English">
        </button>
    </div>

    <span class="home-bg-layer grid" aria-hidden="true"></span>
    <span class="home-bg-layer glow-a" aria-hidden="true"></span>
    <span class="home-bg-layer glow-b" aria-hidden="true"></span>
    <span class="home-bg-layer glow-c" aria-hidden="true"></span>
    <span class="home-bg-layer logo-halo" aria-hidden="true"></span>

    <div class="home-card">
        <img src="{{ asset('images/logo.png') }}" alt="Rehltna logo" class="home-logo">

        <h1 class="home-title" id="homeTitle">Welcome to Rehltna.tn</h1>
        <p class="home-subtitle" id="homeSubtitle">Your futuristic travel companion for smooth and easy journeys.</p>

        <p class="home-description" id="homeDescription">
            Rehltna.tn is a modern platform designed to give clients a better travel experience from start to finish.
            Discover destinations, compare options quickly, and organize your trip with less effort and more confidence.
        </p>

        <div class="home-cta-row">
            <a href="{{ path('app_login') }}" class="home-btn home-btn-primary" id="homeStartBtn">Start Now</a>
        </div>

        <div class="home-dev-team" id="developers">
            <h2 id="devTitle">Our Developers</h2>
            <p id="devSubtitle">Image placeholders ready for your team profiles.</p>

            <div class="home-dev-grid">
                <article
                    class="home-dev-card"
                    role="button"
                    tabindex="0"
                    aria-label="Open developer page"
                    data-dev-name="Wassim Becharguia"
                    data-dev-module="User"
                    data-dev-photo="{{ asset('images/pic1.jpg') }}"
                    data-dev-title="Gestion des utilisateurs"
                    data-dev-description="Responsable de la gestion des utilisateurs, incluant la création, la modification et la sécurisation des comptes afin d’assurer une expérience fiable et fluide."
                    data-dev-title-en="User management"
                    data-dev-description-en="Responsible for user management, including account creation, updates, and security to ensure a reliable and smooth experience."
                    data-dev-module-en="User"
                    data-dev-title-fr="Gestion des utilisateurs"
                    data-dev-description-fr="Responsable de la gestion des utilisateurs, incluant la création, la modification et la sécurisation des comptes afin d’assurer une expérience fiable et fluide."
                    data-dev-module-fr="Utilisateur"
                >
                    <div class="home-dev-avatar has-photo" aria-hidden="true" style="background-image: url('{{ asset('images/pic1.jpg') }}');"></div>
                    <p class="home-dev-name">Wassim becharguia</p>
                </article>
                <article
                    class="home-dev-card"
                    role="button"
                    tabindex="0"
                    aria-label="Open developer page"
                    data-dev-name="Sahar Oueslati"
                    data-dev-module="Design"
                    data-dev-photo="{{ asset('images/pic3.jpg') }}"
                    data-dev-title="Experience utilisateur"
                    data-dev-description="Conception de parcours intuitifs et harmonisation des ecrans afin d'offrir une navigation claire, rapide et agreable pour tous les utilisateurs."
                    data-dev-title-en="User experience"
                    data-dev-description-en="Design of intuitive user journeys and harmonized interfaces to deliver clear, fast, and enjoyable navigation for everyone."
                    data-dev-module-en="Design"
                    data-dev-title-fr="Gestion des activités et des offres de guides touristiques"
                    data-dev-description-fr="Gestion des activités et des offres de guides touristiques, permettant la découverte et la réservation d'expériences variées"
                    data-dev-module-fr="Activités"
                >
                    <div class="home-dev-avatar has-photo" aria-hidden="true" style="background-image: url('{{ asset('images/pic3.jpg') }}');"></div>
                    <p class="home-dev-name">Sahar Oueslati</p>
                </article>
                <article
                    class="home-dev-card"
                    role="button"
                    tabindex="0"
                    aria-label="Open developer page"
                    data-dev-name="Doua Jlassi"
                    data-dev-module="Messagerie"
                    data-dev-photo="{{ asset('images/pic4.jpg') }}"
                    data-dev-title="Gestion des messageries"
                    data-dev-description="Gestion des messageries, facilitant la communication transparente entre utilisateurs et agences"
                    data-dev-title-en="Messaging management"
                    data-dev-description-en="Messaging management, facilitating transparent communication between users and agencies"
                    data-dev-module-en="Messaging"
                    data-dev-title-fr="Gestion des messageries"
                    data-dev-description-fr="Gestion des messageries, facilitant la communication transparente entre utilisateurs et agences"
                    data-dev-module-fr="Messagerie"
                >
                    <div class="home-dev-avatar has-photo" aria-hidden="true" style="background-image: url('{{ asset('images/pic4.jpg') }}');"></div>
                    <p class="home-dev-name">Doua Jlassi</p>
                </article>
                <article
                    class="home-dev-card"
                    role="button"
                    tabindex="0"
                    aria-label="Open developer page"
                    data-dev-name="Achref Souli"
                    data-dev-module="Performance"
                    data-dev-title="Performance et optimisation"
                    data-dev-description="Optimisation des temps de reponse, reduction des charges inutiles et amelioration de la fluidite generale pour une plateforme plus rapide."
                >
                    <div class="home-dev-avatar" aria-hidden="true"></div>
                    <p class="home-dev-name">Achref Souli</p>
                </article>
                <article
                    class="home-dev-card"
                    role="button"
                    tabindex="0"
                    aria-label="Open developer page"
                    data-dev-name="Wajdi Farhat"
                    data-dev-module="API"
                    data-dev-photo="{{ asset('images/pic2.jpg') }}"
                    data-dev-title="Integration API"
                    data-dev-description="Connexion des services externes et synchronisation des donnees en temps reel afin d'ameliorer la coherence et la qualite des informations."
                    data-dev-title-en="API integration"
                    data-dev-description-en="Connection of external services and real-time data synchronization to improve consistency and data quality."
                    data-dev-module-en="API"
                    data-dev-title-fr="Gestion des publications"
                    data-dev-description-fr="Gestion des publications, animant la communauté avec contenu engageant"
                    data-dev-module-fr="Publications"
                >
                    <div class="home-dev-avatar has-photo" aria-hidden="true" style="background-image: url('{{ asset('images/pic2.jpg') }}');"></div>
                    <p class="home-dev-name">Wajdi Farhat</p>
                </article>
                <article
                    class="home-dev-card"
                    role="button"
                    tabindex="0"
                    aria-label="Open developer page"
                    data-dev-name="Dhia Mestiri"
                    data-dev-module="Security"
                    data-dev-title="Qualite et securite"
                    data-dev-description="Validation des fonctionnalites, controle des erreurs critiques et renforcement des mecanismes de securite pour maintenir une application fiable."
                >
                    <div class="home-dev-avatar" aria-hidden="true"></div>
                    <p class="home-dev-name">Dhia mestiri</p>
                </article>
            </div>
        </div>

        <div class="home-contact" id="contact-us">
            <h2>Contact Us</h2>
            <p>Connect with Rehltna and stay updated across all channels.</p>

            <div class="home-socials">
                <a href="https://www.facebook.com/rehltna.tn" target="_blank" rel="noopener noreferrer" class="home-social" aria-label="Facebook Rehltna">
                    <span class="home-social-icon">FB</span>
                    <span>Facebook</span>
                </a>
                <a href="https://www.instagram.com/rehltna.tn" target="_blank" rel="noopener noreferrer" class="home-social" aria-label="Instagram Rehltna">
                    <span class="home-social-icon">IG</span>
                    <span>Instagram</span>
                </a>
                <a href="mailto:rehltna.tn@gmail.com" class="home-social" aria-label="Email Rehltna">
                    <span class="home-social-icon">GM</span>
