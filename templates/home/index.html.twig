                    <div class="home-dev-panel-avatar" id="homeDevPanelAvatar" aria-hidden="true"></div>
                    <div class="home-dev-panel-meta">
                        <h4 class="home-dev-panel-name" id="homeDevPanelName">Wassim Becharguia</h4>
