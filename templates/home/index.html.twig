{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const homeLanding = document.querySelector('.home-landing');
            const devCards = document.querySelectorAll('.home-dev-card');
            const devModal = document.getElementById('homeDevModal');
            const devModalContent = devModal ? devModal.querySelector('.home-dev-modal-content') : null;
            const langToggleBtn = document.getElementById('langToggleBtn');
            const homeTitle = document.getElementById('homeTitle');
            const homeSubtitle = document.getElementById('homeSubtitle');
            const homeDescription = document.getElementById('homeDescription');
            const homeStartBtn = document.getElementById('homeStartBtn');
            const devTitle = document.getElementById('devTitle');
            const devSubtitle = document.getElementById('devSubtitle');
            const panelAvatar = document.getElementById('homeDevPanelAvatar');
            const panelName = document.getElementById('homeDevPanelName');
            const panelModule = document.getElementById('homeDevPanelModule');
            const panelTitle = document.getElementById('homeDevPanelTitle');
            const panelDescription = document.getElementById('homeDevPanelDescription');

            if (!devModal || !devModalContent || !panelAvatar || !panelName || !panelModule || !panelTitle || !panelDescription || devCards.length === 0 || !langToggleBtn) {
                return;
            }

            const baseTranslations = {
                en: {
                    homeTitle: 'Welcome to Rehltna.tn',
                    homeSubtitle: 'Your futuristic travel companion for smooth and easy journeys.',
                    homeDescription: 'Rehltna.tn is a modern platform designed to give clients a better travel experience from start to finish. Discover destinations, compare options quickly, and organize your trip with less effort and more confidence.',
                    startNow: 'Start Now',
                    devTitle: 'Our Developers',
                    devSubtitle: 'Image placeholders ready for your team profiles.',
                    modulePrefix: 'Module: '
                },
                fr: {
                    homeTitle: 'Bienvenue sur Rehltna.tn',
                    homeSubtitle: 'Votre compagnon de voyage futuriste pour des trajets fluides et simples.',
                    homeDescription: 'Rehletna.tn est une plateforme web innovante de réservation de voyages et d\'événements multi-agences. Ce projet représente une solution technologique complète et sécurisée qui transforme l\'organisation des voyages en un processus simple, collaboratif et personnalisé.',
                    startNow: 'Commencer',
                    devTitle: 'Nos developpeurs',
                    devSubtitle: 'Profils de l equipe en presentation.',
                    modulePrefix: 'Module: '
                }
            };

            const getLocalizedField = function (card, baseName, lang, fallback) {
                const key = baseName + lang.charAt(0).toUpperCase() + lang.slice(1);
                return card.dataset[key] || card.dataset[baseName] || fallback;
            };

            let activeLang = 'en';
            let activeCard = null;

            const applyLanguage = function () {
                const t = baseTranslations[activeLang];
                if (homeTitle) {
                    homeTitle.textContent = t.homeTitle;
                }
                if (homeSubtitle) {
                    homeSubtitle.textContent = t.homeSubtitle;
                }
                if (homeDescription) {
                    homeDescription.textContent = t.homeDescription;
                }
                if (homeStartBtn) {
                    homeStartBtn.textContent = t.startNow;
                }
                if (devTitle) {
                    devTitle.textContent = t.devTitle;
                }
                if (devSubtitle) {
                    devSubtitle.textContent = t.devSubtitle;
                }
                if (activeCard) {
                    panelModule.textContent = t.modulePrefix + getLocalizedField(activeCard, 'devModule', activeLang, 'General');
                    panelTitle.textContent = getLocalizedField(activeCard, 'devTitle', activeLang, 'Developer profile');
                    panelDescription.textContent = getLocalizedField(activeCard, 'devDescription', activeLang, 'No description available.');
                }
            };

            if (langToggleBtn) {
                const langFlagImg = document.getElementById('langFlagImg');
                langToggleBtn.addEventListener('click', function () {
                    activeLang = activeLang === 'en' ? 'fr' : 'en';
                    if (langFlagImg) {
                        langFlagImg.src = activeLang === 'en' ? '{{ asset('images/usa.png') }}' : '{{ asset('images/france.png') }}';
                        langFlagImg.alt = activeLang === 'en' ? 'English' : 'Français';
                    }
                    applyLanguage();
                });
            }

            const openModal = function (card) {
                activeCard = card;
                const photo = card.dataset.devPhoto || '';
                panelName.textContent = card.dataset.devName || 'Developer';
                panelModule.textContent = baseTranslations[activeLang].modulePrefix + getLocalizedField(card, 'devModule', activeLang, 'General');
                panelTitle.textContent = getLocalizedField(card, 'devTitle', activeLang, 'Developer profile');
                panelDescription.textContent = getLocalizedField(card, 'devDescription', activeLang, 'No description available.');
                panelAvatar.style.backgroundImage = photo ? 'url("' + photo + '")' : '';
                devModal.classList.add('is-open');
                devModal.setAttribute('aria-hidden', 'false');
                if (homeLanding) {
                    homeLanding.classList.add('is-dev-open');
                }
            };

            const closeModal = function () {
                devModal.classList.remove('is-open');
                devModal.setAttribute('aria-hidden', 'true');
                if (homeLanding) {
                    homeLanding.classList.remove('is-dev-open');
                }
            };

            devCards.forEach(function (card) {
                card.addEventListener('click', function () {
                    openModal(card);
                });

                card.addEventListener('keydown', function (event) {
                    if (event.key === 'Enter' || event.key === ' ') {
                        event.preventDefault();
                        openModal(card);
                    }
                });
            });

            devModal.addEventListener('click', function (event) {
                if (event.target === devModal) {
                    closeModal();
                }
            });

            devModalContent.addEventListener('click', function (event) {
                event.stopPropagation();
            });

            document.addEventListener('keydown', function (event) {
                if (event.key === 'Escape' && devModal.classList.contains('is-open')) {
                    closeModal();
                }
            });

            applyLanguage();
        });
    </script>
{% endblock %}