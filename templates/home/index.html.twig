{% extends 'base.html.twig' %}

{% block title %}Home - Rehletna.tn{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="row">
        <div class="col-12">
            <h1>Welcome to Rehletna.tn</h1>
            {% if app.user %}
                <p>You are logged in as: {{ app.user.fullName }}</p>
                <a href="{{ path('app_logout') }}" class="btn btn-danger">Logout</a>
            {% else %}
                <p>You are not logged in.</p>
                <a href="{{ path('app_login') }}" class="btn btn-primary">Login</a>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}