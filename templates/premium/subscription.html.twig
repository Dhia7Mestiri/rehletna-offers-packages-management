{# templates/premium/subscription.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Premium Subscription - Rehletna.tn{% endblock %}

{% block body %}
<div class="premium-container">
    <div class="premium-header">
        <h1>
            <span class="premium-star">⭐</span>
            Premium Subscription
        </h1>
        <a href="{{ path('app_mainpage') }}" class="back-main-btn">← Back to Main</a>
    </div>

    <div class="premium-user-info">
        <div class="user-row">
            <div class="info-label">User</div>
            <div class="info-value">{{ user.username }}</div>
        </div>
        <div class="user-row">
            <div class="info-label">Email</div>
            <div class="info-value">{{ user.email }}</div>
        </div>
        <div class="user-row">
            <div class="info-label">Current Plan</div>
            <div class="info-value">{{ profile.member_premium|default('Standard') | capitalize }} Member</div>
        </div>
        <div class="user-row">
            <div class="info-label coins-info">
                <span class="coin-icon">💛</span>
                <span>Your Coins:</span>
            </div>
            <div class="info-value coin-count">0</div>
        </div>
    </div>

    <div class="plans-grid">
        <!-- PREMIUM Plan -->
        <div class="plan-card">
            <div class="plan-header">
                <span class="plan-star">⭐</span>
                <h2>PREMIUM</h2>
            </div>
            <div class="plan-price">
                <span class="amount">29</span><span class="currency">DT</span>
                <span class="period">/month</span>
            </div>
            <div class="plan-divider"></div>
            <ul class="plan-features">
                <li><span class="checkmark">✓</span> Change username anytime</li>
                <li><span class="checkmark">✓</span> Get 1 coin every 30 seconds</li>
                <li><span class="checkmark">✓</span> 10 bonus coins on signup</li>
                <li><span class="checkmark">✓</span> Priority customer support</li>
            </ul>
            <button class="plan-btn primary-btn" onclick="selectPlan('premium', 29)">GET PLAN</button>
        </div>

        <!-- VIP Plan (BEST VALUE) -->
        <div class="plan-card best-value">
            <div class="plan-badge">💎 BEST VALUE</div>
            <div class="plan-header">
                <span class="plan-crown">👑</span>
                <h2>VIP</h2>
            </div>
            <div class="plan-price">
                <span class="amount">59</span><span class="currency">DT</span>
                <span class="period">/month</span>
            </div>
            <div class="plan-divider"></div>
            <ul class="plan-features">
                <li><span class="checkmark">✓</span> Change username anytime</li>
                <li><span class="checkmark">✓</span> Get 5 coins every 30 seconds</li>
                <li><span class="checkmark">✓</span> 20 bonus coins on signup</li>
                <li><span class="checkmark">✓</span> 2% discount on all bookings</li>
                <li><span class="checkmark">✓</span> Priority customer support</li>
            </ul>
            <button class="plan-btn vip-btn" onclick="selectPlan('vip', 59)">GET PLAN</button>
        </div>

        <!-- VIP+ Plan -->
        <div class="plan-card">
            <div class="plan-header">
                <span class="plan-crown-plus">💠</span>
                <h2>VIP+</h2>
            </div>
            <div class="plan-price">
                <span class="amount">99</span><span class="currency">DT</span>
                <span class="period">/month</span>
            </div>
            <div class="plan-divider"></div>
            <ul class="plan-features">
                <li><span class="checkmark">✓</span> Change username anytime</li>
                <li><span class="checkmark">✓</span> Get 5 coins every 30 seconds</li>
                <li><span class="checkmark">✓</span> 25 bonus coins on signup</li>
                <li><span class="checkmark">✓</span> 3% discount on all bookings</li>
                <li><span class="checkmark">✓</span> Create groups without admin confirmation</li>
                <li><span class="checkmark">✓</span> Priority customer support</li>
            </ul>
            <button class="plan-btn premium-plus-btn" onclick="selectPlan('vip+', 99)">GET PLAN</button>
        </div>
    </div>

    <div id="checkoutOverlay" class="checkout-overlay" aria-hidden="true">
        <div class="checkout-modal" role="dialog" aria-modal="true" aria-labelledby="checkoutTitle">
            <button id="checkoutCloseBtn" type="button" class="checkout-close" aria-label="Close checkout">x</button>
            <h3 id="checkoutTitle">Card Payment</h3>
            <p id="checkoutPlanText" class="checkout-plan-text">Selected plan: PREMIUM - 29DT/month</p>

            <div class="cc-scene">
                <div id="creditCardPreview" class="cc-card">
                    <div class="cc-face cc-front">
                        <div class="cc-chip"></div>
                        <div id="previewCardNumber" class="cc-number">•••• •••• •••• ••••</div>
                        <div class="cc-front-bottom">
                            <div>
                                <div class="cc-label">Card Holder</div>
                                <div id="previewCardHolder" class="cc-value">YOUR NAME</div>
                            </div>
                            <div>
                                <div class="cc-label">Expires</div>
                                <div id="previewExpiry" class="cc-value">MM/YY</div>
                            </div>
                        </div>
                    </div>
                    <div class="cc-face cc-back">
                        <div class="cc-strip"></div>
                        <div class="cc-cvc-wrap">
                            <div class="cc-label">CVC</div>
                            <div id="previewCvc" class="cc-cvc">•••</div>
                        </div>
                    </div>
                </div>
            </div>

            <form id="checkoutForm" class="checkout-form">
                <input type="hidden" id="checkoutOffer" name="offer" value="premium">

                <label class="checkout-label" for="cardHolderInput">Card Holder</label>
                <input id="cardHolderInput" name="cardHolder" class="checkout-input" type="text" placeholder="Name on card" required>

                <label class="checkout-label" for="cardNumberInput">Card Number</label>
                <input id="cardNumberInput" name="cardNumber" class="checkout-input" type="text" inputmode="numeric" maxlength="19" placeholder="1234 5678 9012 3456" required>

                <div class="checkout-row">
                    <div>
                        <label class="checkout-label" for="expiryInput">Expiry</label>
                        <input id="expiryInput" name="expiry" class="checkout-input" type="text" inputmode="numeric" maxlength="5" placeholder="MM/YY" required>
                    </div>
                    <div>
                        <label class="checkout-label" for="cvcInput">CVC</label>
                        <input id="cvcInput" name="cvc" class="checkout-input" type="password" inputmode="numeric" maxlength="4" placeholder="123" required>
                    </div>
                </div>

                <div id="checkoutMessage" class="checkout-message" aria-live="polite"></div>

                <button id="checkoutSubmitBtn" class="checkout-submit" type="submit">Confirm Payment</button>
            </form>
        </div>
    </div>
</div>

<style>
    .premium-container {
        min-height: 100vh;
        padding: 40px 20px;
        background:
            radial-gradient(1400px 500px at 10% -20%, rgba(10, 160, 159, 0.15), transparent 60%),
            radial-gradient(1000px 500px at 100% 0%, rgba(252, 186, 48, 0.12), transparent 55%),
            linear-gradient(180deg, #f4f9ff 0%, #eff6fb 100%);
    }

    html.dark-mode .premium-container {
        background:
            radial-gradient(1400px 500px at 10% -20%, rgba(45, 212, 191, 0.08), transparent 60%),
            radial-gradient(1000px 500px at 100% 0%, rgba(252, 186, 48, 0.06), transparent 55%),
            linear-gradient(180deg, #121a27 0%, #1a2a3a 100%);
    }

    .premium-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        max-width: 1200px;
        margin: 0 auto 40px;
        gap: 20px;
    }

    .premium-header h1 {
        font-size: 32px;
        font-weight: 800;
        margin: 0;
        color: #1e456e;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    html.dark-mode .premium-header h1 {
        color: #e2e8f0;
    }

    .premium-star {
        font-size: 28px;
    }

    .back-main-btn {
        padding: 10px 20px;
        background: rgba(30, 69, 110, 0.1);
        border: 1px solid rgba(30, 69, 110, 0.3);
        border-radius: 8px;
        color: #1e456e;
        text-decoration: none;
        font-weight: 600;
        font-size: 14px;
        cursor: pointer;
        transition: all 0.3s ease;
        white-space: nowrap;
    }

    .back-main-btn:hover {
        background: rgba(30, 69, 110, 0.2);
        transform: translateY(-2px);
    }

    html.dark-mode .back-main-btn {
        background: rgba(94, 234, 212, 0.1);
        border-color: rgba(94, 234, 212, 0.3);
        color: #5ee4d4;
    }

    html.dark-mode .back-main-btn:hover {
        background: rgba(94, 234, 212, 0.15);
    }

    .premium-user-info {
        max-width: 1200px;
        margin: 0 auto 50px;
        background: rgba(255, 255, 255, 0.9);
        border-radius: 16px;
        padding: 24px;
        border: 1px solid rgba(152, 189, 216, 0.3);
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
    }

    html.dark-mode .premium-user-info {
        background: rgba(20, 33, 48, 0.8);
        border-color: rgba(72, 105, 138, 0.4);
    }

    .user-row {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .info-label {
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        color: #5b7894;
        letter-spacing: 0.5px;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    html.dark-mode .info-label {
        color: #b7cadf;
    }

    .info-value {
        font-size: 16px;
        font-weight: 600;
        color: #1e456e;
    }

    html.dark-mode .info-value {
        color: #e2e8f0;
    }

    .coin-icon {
        font-size: 14px;
    }

    .coin-count {
        font-size: 24px;
        font-weight: 800;
        color: #f5a623;
    }

    .plans-grid {
        max-width: 1200px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        gap: 30px;
    }

    .plan-card {
        background: rgba(255, 255, 255, 0.92);
        border: 1px solid rgba(152, 189, 216, 0.4);
        border-radius: 16px;
        padding: 32px 24px;
        transition: all 0.3s ease;
        position: relative;
        display: flex;
        flex-direction: column;
    }

    .plan-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 16px 32px rgba(13, 50, 86, 0.15);
    }

    html.dark-mode .plan-card {
        background: rgba(20, 33, 48, 0.92);
        border-color: rgba(72, 105, 138, 0.4);
    }

    .plan-badge {
        position: absolute;
        top: -12px;
        left: 50%;
        transform: translateX(-50%);
        background: linear-gradient(135deg, #f5a623, #ffc107);
        color: #ffffff;
        padding: 6px 16px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 700;
        box-shadow: 0 4px 12px rgba(245, 166, 35, 0.3);
    }

    .best-value {
        border: 2px solid #f5a623;
        transform: scale(1.05);
    }

    .plan-header {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 16px;
    }

    .plan-header h2 {
        font-size: 20px;
        font-weight: 800;
        margin: 0;
        color: #1e456e;
    }

    html.dark-mode .plan-header h2 {
        color: #e2e8f0;
    }

    .plan-star,
    .plan-crown,
    .plan-crown-plus {
        font-size: 24px;
    }

    .plan-price {
        display: flex;
        align-items: baseline;
        gap: 4px;
        margin-bottom: 20px;
    }

    .amount {
        font-size: 32px;
        font-weight: 800;
        color: #0fa5a2;
    }

    .best-value .amount {
        color: #f5a623;
    }

    .currency {
        font-size: 18px;
        font-weight: 700;
        color: #0fa5a2;
    }

    .best-value .currency {
        color: #f5a623;
    }

    .period {
        font-size: 12px;
        color: #5b7894;
        margin-left: 4px;
    }

    html.dark-mode .period {
        color: #b7cadf;
    }

    .plan-divider {
        height: 1px;
        background: rgba(152, 189, 216, 0.2);
        margin: 20px 0;
    }

    html.dark-mode .plan-divider {
        background: rgba(72, 105, 138, 0.3);
    }

    .plan-features {
        list-style: none;
        margin: 0 0 24px;
        padding: 0;
        flex-grow: 1;
    }

    .plan-features li {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        font-size: 13px;
        color: #5b7894;
        margin-bottom: 10px;
        line-height: 1.5;
    }

    html.dark-mode .plan-features li {
        color: #b7cadf;
    }

    .checkmark {
        color: #0fa5a2;
        font-weight: 800;
        flex-shrink: 0;
        margin-top: 2px;
    }

    .best-value .checkmark {
        color: #f5a623;
    }

    .plan-btn {
        padding: 12px 24px;
        border: none;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 800;
        text-transform: uppercase;
        cursor: pointer;
        transition: all 0.3s ease;
        width: 100%;
        letter-spacing: 0.5px;
    }

    .primary-btn {
        background: linear-gradient(135deg, #0fa5a2, #1788b6);
        color: #ffffff;
    }

    .primary-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 16px rgba(15, 165, 162, 0.3);
    }

    .vip-btn {
        background: linear-gradient(135deg, #f5a623, #ffc107);
        color: #ffffff;
        font-weight: 900;
    }

    .vip-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 16px rgba(245, 166, 35, 0.4);
    }

    .premium-plus-btn {
        background: linear-gradient(135deg, #8b5cf6, #a855f7);
        color: #ffffff;
    }

    .premium-plus-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 16px rgba(139, 92, 246, 0.3);
    }

    @media (max-width: 768px) {
        .premium-header {
            flex-direction: column;
            text-align: center;
        }

        .premium-header h1 {
            font-size: 24px;
            justify-content: center;
        }

        .back-main-btn {
            width: 100%;
            text-align: center;
        }

        .premium-user-info {
            grid-template-columns: 1fr;
        }

        .plans-grid {
            gap: 20px;
        }

        .best-value {
            transform: scale(1);
        }
    }

    html.dark-mode .plan-card:hover {
        box-shadow: 0 16px 32px rgba(45, 212, 191, 0.1);
    }

    .checkout-overlay {
        position: fixed;
        inset: 0;
        display: none;
        align-items: center;
        justify-content: center;
        padding: 18px;
        background: rgba(8, 24, 40, 0.55);
        backdrop-filter: blur(6px);
        z-index: 3000;
    }

    .checkout-overlay.show {
        display: flex;
    }

    .checkout-modal {
        width: min(520px, 100%);
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(246, 251, 255, 0.95));
        border: 1px solid rgba(152, 189, 216, 0.5);
        border-radius: 20px;
        padding: 24px;
        position: relative;
        box-shadow: 0 20px 40px rgba(11, 42, 70, 0.25);
    }

    .checkout-close {
        position: absolute;
        top: 10px;
        right: 10px;
        width: 32px;
        height: 32px;
        border: none;
        border-radius: 50%;
        background: rgba(9, 73, 108, 0.08);
        color: #1e456e;
        cursor: pointer;
        font-weight: 700;
    }

    .checkout-modal h3 {
        margin: 0 0 6px;
        color: #144468;
        font-size: 24px;
    }

    .checkout-plan-text {
        margin: 0 0 16px;
        color: #59758f;
        font-size: 13px;
        font-weight: 600;
    }

    .cc-scene {
        perspective: 1200px;
        margin-bottom: 14px;
    }

    .cc-card {
        width: 100%;
        height: 188px;
        position: relative;
        transform-style: preserve-3d;
        transition: transform 0.65s cubic-bezier(0.2, 0.8, 0.2, 1);
        border-radius: 16px;
    }

    .cc-card.is-flipped {
        transform: rotateY(180deg);
    }

    .cc-face {
        position: absolute;
        inset: 0;
        border-radius: 16px;
        backface-visibility: hidden;
        padding: 18px;
        box-sizing: border-box;
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.3);
    }

    .cc-front {
        background:
            radial-gradient(320px 140px at -10% -20%, rgba(255, 255, 255, 0.4), transparent 70%),
            linear-gradient(135deg, #0f8faf, #0f4b84 60%, #0a2f55);
        color: #ffffff;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    .cc-chip {
        width: 42px;
        height: 30px;
        border-radius: 8px;
        background: linear-gradient(145deg, #ffd875, #e6b84c);
        box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.15);
    }

    .cc-number {
        margin-top: 14px;
        font-size: 25px;
        font-weight: 700;
        letter-spacing: 1.6px;
        font-family: 'Courier New', monospace;
        text-shadow: 0 2px 8px rgba(0, 0, 0, 0.35);
    }

    .cc-front-bottom {
        display: flex;
        justify-content: space-between;
        gap: 12px;
    }

    .cc-label {
        font-size: 10px;
        text-transform: uppercase;
        letter-spacing: 0.7px;
        opacity: 0.8;
    }

    .cc-value {
        margin-top: 3px;
        font-size: 14px;
        font-weight: 700;
        letter-spacing: 0.6px;
        text-transform: uppercase;
    }

    .cc-back {
        transform: rotateY(180deg);
        background:
            radial-gradient(280px 130px at 110% 110%, rgba(255, 255, 255, 0.2), transparent 70%),
            linear-gradient(145deg, #1f2d3f, #162331);
        color: #ffffff;
    }

    .cc-strip {
        height: 36px;
        background: rgba(4, 8, 16, 0.85);
        margin: 10px -18px 0;
    }

    .cc-cvc-wrap {
        margin-top: 22px;
        margin-left: auto;
        width: 136px;
    }

    .cc-cvc {
        margin-top: 4px;
        border-radius: 8px;
        background: rgba(255, 255, 255, 0.95);
        color: #1b2a3d;
        padding: 8px 10px;
        font-size: 16px;
        font-family: 'Courier New', monospace;
        letter-spacing: 2px;
        text-align: right;
        font-weight: 700;
    }

    .checkout-form {
        display: grid;
        gap: 10px;
    }

    .checkout-label {
        font-size: 12px;
        font-weight: 700;
        color: #365874;
    }

    .checkout-input {
        width: 100%;
        box-sizing: border-box;
        border: 1px solid rgba(122, 161, 190, 0.55);
        border-radius: 10px;
        padding: 11px 12px;
        font-size: 14px;
        background: #ffffff;
        color: #1e456e;
    }

    .checkout-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
    }

    .checkout-message {
        min-height: 18px;
        font-size: 12px;
        font-weight: 700;
    }

    .checkout-message.error {
        color: #c0392b;
    }

    .checkout-message.success {
        color: #1f8a4c;
    }

    .checkout-submit {
        border: none;
        border-radius: 12px;
        padding: 12px 14px;
        font-size: 13px;
        font-weight: 800;
        color: #ffffff;
        background: linear-gradient(135deg, #0fa5a2, #1788b6);
        cursor: pointer;
        margin-top: 4px;
    }

    .checkout-submit:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }

    html.dark-mode .checkout-modal {
        background: linear-gradient(180deg, rgba(21, 33, 48, 0.98), rgba(20, 31, 44, 0.95));
        border-color: rgba(66, 95, 125, 0.8);
    }

    html.dark-mode .checkout-close {
        background: rgba(145, 194, 233, 0.12);
        color: #d3e7f7;
    }

    html.dark-mode .checkout-modal h3 {
        color: #d8e8f6;
    }

    html.dark-mode .checkout-plan-text {
        color: #9fb5c9;
    }

    html.dark-mode .checkout-label {
        color: #bcd2e5;
    }

    html.dark-mode .checkout-input {
        border-color: rgba(95, 130, 160, 0.75);
        background: rgba(11, 20, 31, 0.85);
        color: #e6f0f8;
    }

    html.dark-mode .cc-front {
        background:
            radial-gradient(320px 140px at -10% -20%, rgba(255, 255, 255, 0.2), transparent 70%),
            linear-gradient(135deg, #156f8a, #123f68 60%, #10283f);
    }

    @media (max-width: 520px) {
        .cc-card {
            height: 176px;
        }

        .cc-number {
            font-size: 21px;
            letter-spacing: 1.2px;
        }
    }
</style>

<script>
    (function () {
        const checkoutOverlay = document.getElementById('checkoutOverlay');
        const checkoutCloseBtn = document.getElementById('checkoutCloseBtn');
        const checkoutForm = document.getElementById('checkoutForm');
        const checkoutOffer = document.getElementById('checkoutOffer');
        const checkoutPlanText = document.getElementById('checkoutPlanText');
        const checkoutSubmitBtn = document.getElementById('checkoutSubmitBtn');
        const checkoutMessage = document.getElementById('checkoutMessage');
        const creditCardPreview = document.getElementById('creditCardPreview');
        const previewCardNumber = document.getElementById('previewCardNumber');
        const previewCardHolder = document.getElementById('previewCardHolder');
        const previewExpiry = document.getElementById('previewExpiry');
        const previewCvc = document.getElementById('previewCvc');
        const cardHolderInput = document.getElementById('cardHolderInput');
        const cardNumberInput = document.getElementById('cardNumberInput');
        const expiryInput = document.getElementById('expiryInput');
        const cvcInput = document.getElementById('cvcInput');

        const syncCardPreview = () => {
            if (previewCardHolder && cardHolderInput) {
                const holder = String(cardHolderInput.value || '').trim();
                previewCardHolder.textContent = holder !== '' ? holder.toUpperCase() : 'YOUR NAME';
            }

            if (previewCardNumber && cardNumberInput) {
                const cardDigits = String(cardNumberInput.value || '').replace(/\D+/g, '').slice(0, 16);
                let grouped = cardDigits.replace(/(\d{4})(?=\d)/g, '$1 ').trim();
                if (grouped === '') {
                    grouped = '•••• •••• •••• ••••';
                }
                previewCardNumber.textContent = grouped;
            }

            if (previewExpiry && expiryInput) {
                const expiry = String(expiryInput.value || '').trim();
                previewExpiry.textContent = expiry !== '' ? expiry : 'MM/YY';
            }

            if (previewCvc && cvcInput) {
                const cvcDigits = String(cvcInput.value || '').replace(/\D+/g, '').slice(0, 4);
                previewCvc.textContent = cvcDigits !== '' ? cvcDigits : '•••';
            }
        };

        const showCardBack = (isBackVisible) => {
            if (!creditCardPreview) {
                return;
            }
            creditCardPreview.classList.toggle('is-flipped', !!isBackVisible);
        };

        const setCheckoutMessage = (text, type) => {
            if (!checkoutMessage) {
                return;
            }
            checkoutMessage.textContent = text || '';
            checkoutMessage.classList.remove('error', 'success');
            if (type) {
                checkoutMessage.classList.add(type);
            }
        };

        const openCheckout = (planType, price) => {
            if (!checkoutOverlay || !checkoutOffer || !checkoutPlanText) {
                return;
            }

            checkoutOffer.value = String(planType || 'premium');
            checkoutPlanText.textContent = 'Selected plan: ' + String(planType || '').toUpperCase() + ' - ' + String(price || 0) + 'DT/month';
            setCheckoutMessage('', null);
            syncCardPreview();
            showCardBack(false);
            checkoutOverlay.classList.add('show');
            checkoutOverlay.setAttribute('aria-hidden', 'false');
        };

        const closeCheckout = () => {
            if (!checkoutOverlay) {
                return;
            }
            checkoutOverlay.classList.remove('show');
            checkoutOverlay.setAttribute('aria-hidden', 'true');
        };

        window.selectPlan = openCheckout;

        if (checkoutCloseBtn) {
            checkoutCloseBtn.addEventListener('click', closeCheckout);
        }

        if (checkoutOverlay) {
            checkoutOverlay.addEventListener('click', function (event) {
                if (event.target === checkoutOverlay) {
                    closeCheckout();
                }
            });
        }

        if (cardNumberInput) {
            cardNumberInput.addEventListener('input', function () {
                const digits = this.value.replace(/\D+/g, '').slice(0, 16);
                this.value = digits.replace(/(\d{4})(?=\d)/g, '$1 ').trim();
                syncCardPreview();
            });
        }

        if (cardHolderInput) {
            cardHolderInput.addEventListener('input', syncCardPreview);
        }

        if (expiryInput) {
            expiryInput.addEventListener('input', function () {
                const digits = this.value.replace(/\D+/g, '').slice(0, 4);
                if (digits.length >= 3) {
                    this.value = digits.slice(0, 2) + '/' + digits.slice(2);
                } else {
                    this.value = digits;
                }
                syncCardPreview();
            });
        }

        if (cvcInput) {
            cvcInput.addEventListener('input', syncCardPreview);
            cvcInput.addEventListener('focus', function () {
                showCardBack(true);
            });
            cvcInput.addEventListener('blur', function () {
                showCardBack(false);
            });
        }

        syncCardPreview();

        if (checkoutForm) {
            checkoutForm.addEventListener('submit', function (event) {
                event.preventDefault();

                const formData = new FormData(checkoutForm);
                const payload = {
                    offer: formData.get('offer'),
                    cardHolder: formData.get('cardHolder'),
                    cardNumber: formData.get('cardNumber'),
                    expiry: formData.get('expiry'),
                    cvc: formData.get('cvc'),
                };

                setCheckoutMessage('', null);
                if (checkoutSubmitBtn) {
                    checkoutSubmitBtn.disabled = true;
                    checkoutSubmitBtn.textContent = 'Processing...';
                }

                fetch('{{ path('app_premium_subscribe') }}', {
                    method: 'POST',
                    credentials: 'same-origin',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest',
                    },
                    body: JSON.stringify(payload),
                })
                    .then((response) => response.json())
                    .then((data) => {
                        if (!data || !data.success) {
                            setCheckoutMessage((data && data.message) ? data.message : 'Payment failed.', 'error');
                            return;
                        }

                        setCheckoutMessage('Offer accepted. Your plan is now ' + String(data.offer || '').toUpperCase() + '.', 'success');
                        window.setTimeout(function () {
                            window.location.reload();
                        }, 900);
                    })
                    .catch(() => {
                        setCheckoutMessage('Network error. Please try again.', 'error');
                    })
                    .finally(() => {
                        if (checkoutSubmitBtn) {
                            checkoutSubmitBtn.disabled = false;
                            checkoutSubmitBtn.textContent = 'Confirm Payment';
                        }
                    });
            });
        }

        document.addEventListener('keydown', function (event) {
            if (event.key === 'Escape') {
                closeCheckout();
            }
        });

        fetch('{{ path('app_collect_coin_status') }}', {
            credentials: 'same-origin',
            headers: { 'X-Requested-With': 'XMLHttpRequest' },
        })
            .then(response => response.json())
            .then(data => {
                if (data && data.coins !== undefined) {
                    const coinCount = document.querySelector('.coin-count');
                    if (coinCount) {
                        coinCount.textContent = data.coins;
                    }
                }
            })
            .catch(() => {
                // Keep page usable if endpoint fails.
            });
    })();
</script>
{% endblock %}
