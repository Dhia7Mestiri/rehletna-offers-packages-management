{% extends 'base.html.twig' %}
{% block title %}Reservations Dashboard{% endblock %}

{% block body %}
{% include 'partials/_offer_subnav.html.twig' %}

<div class="th-body">

    <div class="th-page-header" style="padding-left:0;padding-right:0">
        <div>
            <h1 class="th-page-title">Reservations Dashboard</h1>
            <p class="th-page-sub">Overview of all bookings for your offers.</p>
        </div>
        <a href="{{ path('app_agency_offer_index') }}" class="th-btn-outline">← My Offers</a>
    </div>

    {# ── Stat cards ── #}
    <div class="th-stats-grid">
        <div class="th-stat-card">
            <div class="th-stat-icon" style="background:var(--teal-light);color:var(--teal)">💰</div>
            <div class="th-stat-value">{{ stats.revenue|number_format(2) }} TND</div>
            <div class="th-stat-label">Total Revenue</div>
        </div>
        <div class="th-stat-card">
            <div class="th-stat-icon" style="background:var(--teal-light);color:var(--teal)">✅</div>
            <div class="th-stat-value">{{ stats.confirmed }}</div>
            <div class="th-stat-label">Confirmed</div>
        </div>
        <div class="th-stat-card">
            <div class="th-stat-icon" style="background:#fef6e7;color:#92400e">⏳</div>
            <div class="th-stat-value">{{ stats.pending }}</div>
            <div class="th-stat-label">Pending Payment</div>
        </div>
        <div class="th-stat-card">
            <div class="th-stat-icon" style="background:#fff0f0;color:#a32d2d">❌</div>
            <div class="th-stat-value">{{ stats.cancelled }}</div>
            <div class="th-stat-label">Cancelled</div>
        </div>
        <div class="th-stat-card">
            <div class="th-stat-icon" style="background:var(--navy-light);color:var(--navy)">👥</div>
            <div class="th-stat-value">{{ stats.persons }}</div>
            <div class="th-stat-label">Total Travellers</div>
        </div>
        <div class="th-stat-card">
            <div class="th-stat-icon" style="background:var(--navy-light);color:var(--navy)">📋</div>
            <div class="th-stat-value">{{ stats.total }}</div>
            <div class="th-stat-label">Total Bookings</div>
        </div>
    </div>

    {# ── Charts ── #}
    <div class="th-charts-grid">
        <div class="th-chart-card">
            <h3 class="th-chart-title">📈 Monthly Revenue (last 6 months)</h3>
            <canvas id="revenueChart" height="220"></canvas>
        </div>
        <div class="th-chart-card">
            <h3 class="th-chart-title">📊 Monthly Bookings (last 6 months)</h3>
            <canvas id="bookingsChart" height="220"></canvas>
        </div>
        <div class="th-chart-card">
            <h3 class="th-chart-title">🍩 Reservation Status</h3>
            <div style="max-width:260px;margin:0 auto">
                <canvas id="statusChart" height="220"></canvas>
            </div>
        </div>
    </div>

    {# ── Reservations Table ── #}
    {% if reservations is empty %}
        <div class="th-empty">
            <i class="bi bi-inbox th-empty-icon"></i>
            <h3 class="th-empty-title">No reservations yet</h3>
            <p class="th-empty-sub">Bookings for your offers will appear here.</p>
        </div>
    {% else %}

        {# Filter tabs #}
        <div class="th-rsv-filter-tabs" id="rsvTabs" style="margin-bottom:1rem">
            <button class="th-rsv-tab active" data-filter="ALL">All ({{ reservations|length }})</button>
            <button class="th-rsv-tab" data-filter="CONFIRMED">✅ Confirmed ({{ reservations|filter(r => r.status == 'CONFIRMED')|length }})</button>
            <button class="th-rsv-tab" data-filter="PENDING">⏳ Pending ({{ reservations|filter(r => r.status == 'PENDING')|length }})</button>
            <button class="th-rsv-tab" data-filter="CANCELLED">❌ Cancelled ({{ reservations|filter(r => r.status == 'CANCELLED')|length }})</button>
        </div>

        {# Table #}
        <div style="background:#fff;border-radius:16px;border:1px solid #e2ecf5;overflow:hidden;box-shadow:0 4px 20px rgba(27,58,107,0.06)">
            <table style="width:100%;border-collapse:collapse">
                <thead>
                    <tr style="background:#f8fafc;border-bottom:2px solid #e2ecf5">
                        <th style="padding:12px 16px;text-align:left;font-size:11px;font-weight:700;color:#6b8282;text-transform:uppercase;letter-spacing:0.5px">Offer</th>
                        <th style="padding:12px 16px;text-align:left;font-size:11px;font-weight:700;color:#6b8282;text-transform:uppercase;letter-spacing:0.5px">Client</th>
                        <th style="padding:12px 16px;text-align:left;font-size:11px;font-weight:700;color:#6b8282;text-transform:uppercase;letter-spacing:0.5px">Trip Dates</th>
                        <th style="padding:12px 16px;text-align:center;font-size:11px;font-weight:700;color:#6b8282;text-transform:uppercase;letter-spacing:0.5px">Persons</th>
                        <th style="padding:12px 16px;text-align:center;font-size:11px;font-weight:700;color:#6b8282;text-transform:uppercase;letter-spacing:0.5px">Payment</th>
                        <th style="padding:12px 16px;text-align:right;font-size:11px;font-weight:700;color:#6b8282;text-transform:uppercase;letter-spacing:0.5px">Amount</th>
                        <th style="padding:12px 16px;text-align:center;font-size:11px;font-weight:700;color:#6b8282;text-transform:uppercase;letter-spacing:0.5px">Status</th>
                        <th style="padding:12px 16px;text-align:center;font-size:11px;font-weight:700;color:#6b8282;text-transform:uppercase;letter-spacing:0.5px">Actions</th>
                    </tr>
                </thead>
                <tbody id="rsvList">
                    {% for reservation in reservations %}
                        <tr style="border-bottom:1px solid #f0f4f8;transition:background 0.15s"
                            data-status="{{ reservation.status }}"
                            onmouseover="this.style.background='#f8fafc'"
                            onmouseout="this.style.background='transparent'">

                            {# Offer #}
                            <td style="padding:12px 16px">
                                <div style="display:flex;align-items:center;gap:10px">
                                    <div style="width:44px;height:44px;border-radius:8px;overflow:hidden;flex-shrink:0">
                                        <img src="{{ reservation.offer.imageUrl ?: 'https://via.placeholder.com/44?text=🌍' }}"
                                             alt="{{ reservation.offer.title }}"
                                             style="width:100%;height:100%;object-fit:cover">
                                    </div>
                                    <div>
                                        <div style="font-size:12px;font-weight:700;color:#1b3a6b;max-width:160px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">
                                            {{ reservation.offer.title }}
                                        </div>
                                        <div style="font-size:10px;color:#9db8c0">{{ reservation.createdAt|date('d/m/Y H:i') }}</div>
                                    </div>
                                </div>
                            </td>

                            {# Client #}
                            <td style="padding:12px 16px">
                                <div style="font-size:12px;font-weight:700;color:#1b3a6b">
                                    <i class="bi bi-person-fill" style="color:#1dbcaa"></i>
                                    {{ reservation.user.fullName|default(reservation.user.username) }}
                                </div>
                                <div style="font-size:11px;color:#9db8c0">{{ reservation.user.email }}</div>
                            </td>

                            {# Dates #}
                            <td style="padding:12px 16px">
                                <div style="font-size:12px;color:#1b3a6b;font-weight:600">{{ reservation.offer.startDate|date('d/m/Y') }}</div>
                                <div style="font-size:11px;color:#9db8c0">→ {{ reservation.offer.endDate|date('d/m/Y') }}</div>
                            </td>

                            {# Persons #}
                            <td style="padding:12px 16px;text-align:center">
                                <span style="background:#f0f4f8;border-radius:999px;padding:3px 10px;font-size:12px;font-weight:700;color:#1b3a6b">
                                    <i class="bi bi-people-fill"></i> {{ reservation.numberOfPersons }}
                                </span>
                            </td>

                            {# Payment #}
                            <td style="padding:12px 16px;text-align:center">
                                {% if reservation.paymentStatus == 'PAID' %}
                                    <span style="background:#e6f8f6;color:#0a7a70;font-size:11px;font-weight:700;padding:3px 8px;border-radius:999px">💳 Paid</span>
                                {% else %}
                                    <span style="background:#f0f4f8;color:#6b8282;font-size:11px;font-weight:700;padding:3px 8px;border-radius:999px">⏳ {{ reservation.paymentStatus }}</span>
                                {% endif %}
                            </td>

                            {# Amount #}
                            <td style="padding:12px 16px;text-align:right">
                                <div style="font-size:14px;font-weight:800;color:#1b3a6b">{{ reservation.totalAmount }}</div>
                                <div style="font-size:10px;color:#9db8c0">TND</div>
                            </td>

                            {# Status #}
                            <td style="padding:12px 16px;text-align:center">
                                {% if reservation.status == 'CONFIRMED' %}
                                    <span style="background:#e6f8f6;color:#0a7a70;font-size:11px;font-weight:700;padding:4px 10px;border-radius:999px">✅ Confirmed</span>
                                {% elseif reservation.status == 'PENDING' %}
                                    <span style="background:#fff8e6;color:#c05621;font-size:11px;font-weight:700;padding:4px 10px;border-radius:999px">⏳ Pending</span>
                                {% elseif reservation.status == 'CANCELLED' %}
                                    <span style="background:#fff0f0;color:#a32d2d;font-size:11px;font-weight:700;padding:4px 10px;border-radius:999px">❌ Cancelled</span>
                                {% endif %}
                            </td>

                            {# Actions #}
                            <td style="padding:12px 16px;text-align:center">
                                <a href="{{ path('app_reservation_agency_show', {id: reservation.id}) }}"
                                   style="background:#f0f4f8;border:1px solid #e2ecf5;border-radius:8px;padding:5px 12px;font-size:11px;font-weight:700;color:#1b3a6b;text-decoration:none"
                                   onmouseover="this.style.background='#e6f8f6';this.style.borderColor='#1dbcaa'"
                                   onmouseout="this.style.background='#f0f4f8';this.style.borderColor='#e2ecf5'">
                                    View →
                                </a>
                            </td>

                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

    {% endif %}

</div>

<script>
var monthlyData    = {{ monthlyData|json_encode|raw }};
var confirmedCount = {{ stats.confirmed }};
var pendingCount   = {{ stats.pending }};
var cancelledCount = {{ stats.cancelled }};
</script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js" onload="initCharts()"></script>
<script>
function initCharts() {
    var labels   = monthlyData.map(function(d) { return d.month; });
    var revenues = monthlyData.map(function(d) { return d.revenue; });
    var bookings = monthlyData.map(function(d) { return d.bookings; });
    var teal  = '#1dbcaa'; var navy = '#1b3a6b'; var gold = '#f5a623'; var red = '#ef4444';

    new Chart(document.getElementById('revenueChart'), {
        type: 'line',
        data: { labels: labels, datasets: [{ label: 'Revenue (TND)', data: revenues, borderColor: teal, backgroundColor: 'rgba(29,188,170,0.15)', borderWidth: 2.5, pointBackgroundColor: teal, pointRadius: 5, fill: true, tension: 0.4 }] },
        options: { responsive: true, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true }, x: { grid: { display: false } } } }
    });

    new Chart(document.getElementById('bookingsChart'), {
        type: 'bar',
        data: { labels: labels, datasets: [{ label: 'Bookings', data: bookings, backgroundColor: navy, borderRadius: 8, borderSkipped: false }] },
        options: { responsive: true, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } }, x: { grid: { display: false } } } }
    });

    new Chart(document.getElementById('statusChart'), {
        type: 'doughnut',
        data: { labels: ['Confirmed', 'Pending', 'Cancelled'], datasets: [{ data: [confirmedCount, pendingCount, cancelledCount], backgroundColor: [teal, gold, red], borderWidth: 0, hoverOffset: 6 }] },
        options: { responsive: true, cutout: '68%', plugins: { legend: { position: 'bottom', labels: { padding: 16, font: { size: 13 } } } } }
    });
}

if (typeof Chart !== 'undefined') { initCharts(); }

// Filter tabs — now works on table rows
document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.th-rsv-tab').forEach(function(tab) {
        tab.addEventListener('click', function() {
            document.querySelectorAll('.th-rsv-tab').forEach(function(t) { t.classList.remove('active'); });
            this.classList.add('active');
            var filter = this.dataset.filter;
            document.querySelectorAll('#rsvList tr').forEach(function(row) {
                row.style.display = (filter === 'ALL' || row.dataset.status === filter) ? '' : 'none';
            });
        });
    });
});
</script>
{% endblock %}
