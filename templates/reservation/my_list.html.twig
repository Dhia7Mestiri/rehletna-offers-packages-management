{% extends 'base.html.twig' %}
{% block title %}My Reservations{% endblock %}

{% block body %}
<div class="th-body">
{% include 'partials/_offer_subnav.html.twig' %}

    <div class="th-page-header" style="padding-left:0;padding-right:0">
        <div>
            <h1 class="th-page-title">My Reservations</h1>
            <p class="th-page-sub">Track all your travel bookings.</p>
        </div>
        <a href="{{ path('app_offer_index') }}" class="th-btn-primary">🔖 Browse Offers</a>
    </div>

    {% if reservations is empty %}
        <div class="th-empty">
            <i class="bi bi-calendar2-x th-empty-icon"></i>
            <h3 class="th-empty-title">No reservations yet</h3>
            <p class="th-empty-sub">Browse our offers and book your next adventure!</p>
            <a href="{{ path('app_offer_index') }}" class="th-btn-gold" style="margin-top:1rem;display:inline-block">🔖 Explore Offers</a>
        </div>
    {% else %}

        {# Stats row #}
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:1rem;margin-bottom:1.5rem">
            {% set confirmed = reservations|filter(r => r.status == 'CONFIRMED')|length %}
            {% set pending   = reservations|filter(r => r.status == 'PENDING')|length %}
            {% set cancelled = reservations|filter(r => r.status == 'CANCELLED')|length %}
            {% set total_spent = 0 %}
            {% for r in reservations %}{% if r.status == 'CONFIRMED' %}{% set total_spent = total_spent + r.totalAmount %}{% endif %}{% endfor %}

            <div style="background:#fff;border-radius:14px;padding:1rem;border:1px solid #e2ecf5;text-align:center">
                <div style="font-size:1.6rem;font-weight:800;color:#1b3a6b">{{ reservations|length }}</div>
                <div style="font-size:11px;color:#6b8282;font-weight:600;text-transform:uppercase">Total</div>
            </div>
            <div style="background:#e6f8f6;border-radius:14px;padding:1rem;border:1px solid rgba(29,188,170,0.2);text-align:center">
                <div style="font-size:1.6rem;font-weight:800;color:#0a7a70">{{ confirmed }}</div>
                <div style="font-size:11px;color:#0a7a70;font-weight:600;text-transform:uppercase">Confirmed</div>
            </div>
            <div style="background:#fff8e6;border-radius:14px;padding:1rem;border:1px solid rgba(245,166,35,0.2);text-align:center">
                <div style="font-size:1.6rem;font-weight:800;color:#c05621">{{ pending }}</div>
                <div style="font-size:11px;color:#c05621;font-weight:600;text-transform:uppercase">Pending</div>
            </div>
            <div style="background:#fff0f0;border-radius:14px;padding:1rem;border:1px solid rgba(229,62,62,0.2);text-align:center">
                <div style="font-size:1.6rem;font-weight:800;color:#a32d2d">{{ cancelled }}</div>
                <div style="font-size:11px;color:#a32d2d;font-weight:600;text-transform:uppercase">Cancelled</div>
            </div>
            <div style="background:linear-gradient(135deg,#1b3a6b,#0f6e56);border-radius:14px;padding:1rem;text-align:center">
                <div style="font-size:1.3rem;font-weight:800;color:#fff">{{ total_spent }} TND</div>
                <div style="font-size:11px;color:rgba(255,255,255,0.7);font-weight:600;text-transform:uppercase">Total Spent</div>
            </div>
        </div>

        {# Table #}
        <div style="background:#fff;border-radius:16px;border:1px solid #e2ecf5;overflow:hidden;box-shadow:0 4px 20px rgba(27,58,107,0.06)">
            <table style="width:100%;border-collapse:collapse">
                <thead>
                    <tr style="background:#f8fafc;border-bottom:2px solid #e2ecf5">
                        <th style="padding:12px 16px;text-align:left;font-size:11px;font-weight:700;color:#6b8282;text-transform:uppercase;letter-spacing:0.5px">Offer</th>
                        <th style="padding:12px 16px;text-align:left;font-size:11px;font-weight:700;color:#6b8282;text-transform:uppercase;letter-spacing:0.5px">Destination</th>
                        <th style="padding:12px 16px;text-align:left;font-size:11px;font-weight:700;color:#6b8282;text-transform:uppercase;letter-spacing:0.5px">Trip Dates</th>
                        <th style="padding:12px 16px;text-align:center;font-size:11px;font-weight:700;color:#6b8282;text-transform:uppercase;letter-spacing:0.5px">Persons</th>
                        <th style="padding:12px 16px;text-align:right;font-size:11px;font-weight:700;color:#6b8282;text-transform:uppercase;letter-spacing:0.5px">Amount</th>
                        <th style="padding:12px 16px;text-align:center;font-size:11px;font-weight:700;color:#6b8282;text-transform:uppercase;letter-spacing:0.5px">Status</th>
                        <th style="padding:12px 16px;text-align:center;font-size:11px;font-weight:700;color:#6b8282;text-transform:uppercase;letter-spacing:0.5px">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for reservation in reservations %}
                        <tr style="border-bottom:1px solid #f0f4f8;transition:background 0.15s"
                            onmouseover="this.style.background='#f8fafc'"
                            onmouseout="this.style.background='transparent'">

                            <td style="padding:12px 16px">
                                <div style="display:flex;align-items:center;gap:10px">
                                    <div style="width:48px;height:48px;border-radius:10px;overflow:hidden;flex-shrink:0">
                                        <img src="{{ reservation.offer.imageUrl ?: 'https://via.placeholder.com/48?text=🌍' }}"
                                             alt="{{ reservation.offer.title }}"
                                             style="width:100%;height:100%;object-fit:cover">
                                    </div>
                                    <div>
                                        <div style="font-size:13px;font-weight:700;color:#1b3a6b;max-width:180px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">
                                            {{ reservation.offer.title }}
                                        </div>
                                        <div style="font-size:11px;color:#9db8c0">Booked {{ reservation.createdAt|date('d/m/Y') }}</div>
                                    </div>
                                </div>
                            </td>

                            <td style="padding:12px 16px">
                                <div style="font-size:12px;color:#6b8282">
                                    <i class="bi bi-geo-alt-fill" style="color:#1dbcaa"></i>
                                    {{ reservation.offer.location ?: '—' }}
                                </div>
                            </td>

                            <td style="padding:12px 16px">
                                <div style="font-size:12px;color:#1b3a6b;font-weight:600">{{ reservation.offer.startDate|date('d/m/Y') }}</div>
                                <div style="font-size:11px;color:#9db8c0">→ {{ reservation.offer.endDate|date('d/m/Y') }}</div>
                            </td>

                            <td style="padding:12px 16px;text-align:center">
                                <span style="background:#f0f4f8;border-radius:999px;padding:3px 10px;font-size:12px;font-weight:700;color:#1b3a6b">
                                    <i class="bi bi-people-fill"></i> {{ reservation.numberOfPersons }}
                                </span>
                            </td>

                            <td style="padding:12px 16px;text-align:right">
                                <div style="font-size:14px;font-weight:800;color:#1b3a6b">{{ reservation.totalAmount }}</div>
                                <div style="font-size:10px;color:#9db8c0">TND</div>
                            </td>

                            <td style="padding:12px 16px;text-align:center">
                                {% if reservation.status == 'CONFIRMED' %}
                                    <span style="background:#e6f8f6;color:#0a7a70;font-size:11px;font-weight:700;padding:4px 10px;border-radius:999px">✅ Confirmed</span>
                                {% elseif reservation.status == 'PENDING' %}
                                    <span style="background:#fff8e6;color:#c05621;font-size:11px;font-weight:700;padding:4px 10px;border-radius:999px">⏳ Pending</span>
                                {% elseif reservation.status == 'CANCELLED' %}
                                    <span style="background:#fff0f0;color:#a32d2d;font-size:11px;font-weight:700;padding:4px 10px;border-radius:999px">❌ Cancelled</span>
                                {% elseif reservation.status == 'REJECTED' %}
                                    <span style="background:#fff0f0;color:#a32d2d;font-size:11px;font-weight:700;padding:4px 10px;border-radius:999px">🚫 Rejected</span>
                                {% endif %}
                            </td>

                            <td style="padding:12px 16px;text-align:center">
                                <a href="{{ path('app_reservation_my_show', {id: reservation.id}) }}"
                                   style="background:#f0f4f8;border:1px solid #e2ecf5;border-radius:8px;padding:5px 12px;font-size:11px;font-weight:700;color:#1b3a6b;text-decoration:none"
                                   onmouseover="this.style.background='#e6f8f6';this.style.borderColor='#1dbcaa'"
                                   onmouseout="this.style.background='#f0f4f8';this.style.borderColor='#e2ecf5'">
                                    View →
                                </a>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

    {% endif %}
</div>
{% endblock %}
