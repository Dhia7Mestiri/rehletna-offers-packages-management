{% extends 'base.html.twig' %}
{% block title %}Reservation #{{ reservation.id }}{% endblock %}

{% block body %}
<div class="th-body">
{% include 'partials/_offer_subnav.html.twig' %}

    <div class="th-page-header" style="padding-left:0;padding-right:0">
        <div>
            <h1 class="th-page-title">Reservation #{{ reservation.id }}</h1>
            <p class="th-page-sub">{{ reservation.offer.title }}</p>
        </div>
        <div class="th-header-actions">
            <a href="{{ path('app_reservation_my_list') }}" class="th-btn-outline">← My Reservations</a>
        </div>
    </div>

    <div class="th-detail-grid">

        {# Left — Status card #}
        <div class="th-rsv-status-card">
            <div class="th-rsv-status-badge th-rsv-status-{{ reservation.status|lower }}">
                {% if reservation.status == 'PENDING' %}⏳
                {% elseif reservation.status == 'CONFIRMED' %}✅
                {% elseif reservation.status == 'CANCELLED' %}❌
                {% elseif reservation.status == 'REJECTED' %}🚫
                {% endif %}
                {{ reservation.status }}
            </div>

            <div class="th-rsv-status-msg">
                {% if reservation.status == 'PENDING' %}
                    Your reservation is waiting for agency confirmation.
                {% elseif reservation.status == 'CONFIRMED' %}
                    Your reservation is confirmed! Get ready for your trip.
                {% elseif reservation.status == 'CANCELLED' %}
                    This reservation was cancelled.
                {% elseif reservation.status == 'REJECTED' %}
                    Unfortunately the agency could not accommodate this reservation.
                {% endif %}
            </div>

            {% if reservation.status == 'PENDING' %}
                <form method="post" action="{{ path('app_reservation_cancel', {id: reservation.id}) }}"
                      onsubmit="return confirm('Cancel this reservation?')">
                    <input type="hidden" name="_token" value="{{ csrf_token('cancel_reservation_' ~ reservation.id) }}">
                    <button type="submit" class="th-btn-danger" style="width:100%;margin-top:1rem">
                        ❌ Cancel Reservation
                    </button>
                </form>
            {% endif %}

            <div class="th-rsv-payment-badge th-rsv-pay-{{ reservation.paymentStatus|lower }}">
                💳 Payment: {{ reservation.paymentStatus }}
            </div>
        </div>

        {# Right — Details #}
        <div class="th-detail-panel">
            <h2 class="th-detail-title" style="font-size:1.2rem">Booking Details</h2>

            <div class="th-detail-meta-grid" style="grid-template-columns:1fr 1fr">
                <div class="th-meta-item">
                    <span class="th-meta-label">📅 Reserved on</span>
                    <span class="th-meta-value">{{ reservation.reservationDate|date('d/m/Y H:i') }}</span>
                </div>
                <div class="th-meta-item">
                    <span class="th-meta-label">👥 Persons</span>
                    <span class="th-meta-value">{{ reservation.numberOfPersons }}</span>
                </div>
                <div class="th-meta-item">
                    <span class="th-meta-label">📍 Location</span>
                    <span class="th-meta-value">{{ reservation.offer.location ?: '—' }}</span>
                </div>
                <div class="th-meta-item">
                    <span class="th-meta-label">🗓️ Trip dates</span>
                    <span class="th-meta-value">
                        {{ reservation.offer.startDate|date('d/m/Y') }} →
                        {{ reservation.offer.endDate|date('d/m/Y') }}
                    </span>
                </div>
            </div>

            {% if reservation.specialRequest %}
                <div class="th-rsv-special">
                    <span class="th-meta-label">💬 Special Requests</span>
                    <p>{{ reservation.specialRequest }}</p>
                </div>
            {% endif %}

            <div class="th-detail-price-block" style="margin-top:1rem">
                <span class="th-price-label">Total Amount</span>
                <div class="th-price-row">
                    <span class="th-price">{{ reservation.totalAmount }}</span>
                    <span class="th-price-cur">TND</span>
                </div>
            </div>

            <div class="th-detail-actions" style="margin-top:1rem">
                <a href="{{ path('app_offer_show', {id: reservation.offer.id}) }}" class="th-btn-outline">
                    🔍 View Offer
                </a>
            </div>
        </div>
    </div>
    {# ── Add this block to my_show.html.twig, after the reservation details card ── #}

{% set offer = reservation.offer %}
{% set today = "now"|date("Y-m-d") %}
{% set tripEnded = offer.endDate and offer.endDate|date("Y-m-d") <= today %}
{% set alreadyRated = existingRating is defined and existingRating is not null %}

<div class="th-form-card" style="margin-top:1.5rem">
    <h3 class="th-form-section-title">
        <i class="bi bi-star-fill me-2" style="color:#f5a623"></i>Rate Your Trip
    </h3>

    {% if reservation.status != 'CONFIRMED' %}
        <div style="background:#f0f4f8;border-radius:12px;padding:1rem;color:#6b8282;font-size:13px;text-align:center">
            <i class="bi bi-lock-fill me-2"></i>Rating is only available for confirmed reservations.
        </div>

    {% elseif not tripEnded %}
        <div style="background:#fff8e6;border:1px solid rgba(245,166,35,0.3);border-radius:12px;padding:1rem;text-align:center">
            <div style="font-size:1.5rem;margin-bottom:6px">⏳</div>
            <div style="font-size:13px;font-weight:700;color:#8a5700">Rating available after your trip ends</div>
            <div style="font-size:12px;color:#a06b00;margin-top:4px">
                Your trip ends on <strong>{{ offer.endDate|date('d/m/Y') }}</strong>
            </div>
        </div>

    {% elseif alreadyRated %}
        <div style="background:#e6f8f6;border:1px solid rgba(29,188,170,0.3);border-radius:12px;padding:1rem;text-align:center">
            <div style="font-size:1.5rem;margin-bottom:6px">✅</div>
            <div style="font-size:13px;font-weight:700;color:#0a7a70">You rated this trip!</div>
            <div style="margin-top:8px">
                {% for i in 1..5 %}
                    <span style="font-size:1.5rem;color:{% if i <= existingRating.stars %}#f5a623{% else %}#dde8f0{% endif %}">★</span>
                {% endfor %}
            </div>
            <div style="font-size:12px;color:#6b8282;margin-top:4px">
                Rated on {{ existingRating.createdAt|date('d/m/Y') }}
            </div>
        </div>

    {% else %}
        <p style="font-size:13px;color:#6b8282;margin-bottom:1rem">
            How was your experience with <strong>{{ offer.title }}</strong>?
        </p>

        <form method="post" action="{{ path('app_rating_submit', {id: reservation.id}) }}" id="ratingForm">
            <div style="display:flex;justify-content:center;gap:8px;margin-bottom:1.5rem" id="starWidget">
                {% for i in 1..5 %}
                    <label style="cursor:pointer;font-size:2.5rem;color:#dde8f0;transition:color 0.15s ease"
                           data-star="{{ i }}"
                           onmouseover="hoverStars({{ i }})"
                           onmouseout="resetStars()"
                           onclick="selectStar({{ i }})">★</label>
                {% endfor %}
            </div>
            <input type="hidden" name="stars" id="starsInput" value="5">

            <div style="text-align:center">
                <button type="submit" class="th-btn-gold" style="padding:10px 32px" id="submitRatingBtn">
                    ⭐ Submit Rating
                </button>
            </div>
        </form>

        <script>
        var selectedStars = 5;
        var labels = document.querySelectorAll('#starWidget label');

        function hoverStars(n) {
            labels.forEach(function(l, i) {
                l.style.color = i < n ? '#f5a623' : '#dde8f0';
            });
        }

        function resetStars() {
            labels.forEach(function(l, i) {
                l.style.color = i < selectedStars ? '#f5a623' : '#dde8f0';
            });
        }

        function selectStar(n) {
            selectedStars = n;
            document.getElementById('starsInput').value = n;
            resetStars();
        }

        // Default: show 5 stars selected
        selectStar(5);
        </script>
    {% endif %}
</div>

</div>
{% endblock %}
