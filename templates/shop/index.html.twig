{% extends 'base.html.twig' %}

{% block title %}{{ 'main.tab.shop'|trans }} - Rehletna.tn{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link href="https://api.mapbox.com/mapbox-gl-js/v2.15.0/mapbox-gl.css" rel="stylesheet" />
    <style>
        .shop-page {
            min-height: 100vh;
            padding: 26px;
            background:
                radial-gradient(800px 320px at 0% 0%, rgba(12, 158, 184, 0.14), transparent 60%),
                radial-gradient(820px 360px at 100% 0%, rgba(19, 180, 138, 0.12), transparent 64%),
                linear-gradient(180deg, #f6fbff 0%, #edf4fa 100%);
            color: #16324b;
        }

        .shop-shell {
            max-width: 1180px;
            margin: 0 auto;
        }

        .shop-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            margin-bottom: 16px;
            padding: 20px 22px;
            border-radius: 22px;
            background: linear-gradient(135deg, rgba(8, 97, 123, 0.96), rgba(14, 136, 161, 0.93));
            color: #fff;
            box-shadow: 0 18px 38px rgba(10, 52, 90, 0.2);
        }

        .shop-head h1 {
            margin: 0;
            font-size: clamp(28px, 3vw, 42px);
            line-height: 1.05;
        }

        .shop-head p {
            margin: 8px 0 0;
            color: rgba(255, 255, 255, 0.9);
            font-size: 14px;
        }

        .coins-pill {
            border-radius: 999px;
            border: 1px solid rgba(255, 255, 255, 0.34);
            background: rgba(255, 255, 255, 0.14);
            padding: 8px 14px;
            font-weight: 800;
            font-size: 14px;
            white-space: nowrap;
        }

        .shop-flash {
            border-radius: 12px;
            padding: 10px 12px;
            margin-bottom: 12px;
            font-weight: 700;
            font-size: 13px;
        }

        .shop-flash.success {
            border: 1px solid rgba(16, 185, 129, 0.28);
            background: rgba(16, 185, 129, 0.14);
            color: #0f8f66;
        }

        .shop-flash.error {
            border: 1px solid rgba(239, 68, 68, 0.22);
            background: rgba(239, 68, 68, 0.12);
            color: #bb3f3f;
        }

        .shop-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
            gap: 14px;
        }

        .product-card {
            border: 1px solid rgba(126, 152, 178, 0.28);
            border-radius: 18px;
            overflow: hidden;
            background: rgba(255, 255, 255, 0.95);
            box-shadow: 0 12px 24px rgba(10, 34, 62, 0.08);
            display: flex;
            flex-direction: column;
            min-height: 100%;
        }

        .product-image {
            width: 100%;
            height: 170px;
            object-fit: cover;
            background: #e8f0f8;
        }

        .product-body {
            padding: 14px;
            display: flex;
            flex-direction: column;
            gap: 10px;
            flex: 1;
        }

        .product-name {
            margin: 0;
            font-size: 20px;
            color: #174a78;
        }

        .product-meta {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

        .tag {
            border: 1px solid rgba(11, 164, 161, 0.3);
            background: rgba(11, 164, 161, 0.1);
            border-radius: 999px;
            padding: 4px 10px;
            font-size: 11px;
            font-weight: 700;
            color: #0b8e8b;
        }

        .product-desc {
            color: #5d7590;
            font-size: 13px;
            line-height: 1.45;
            min-height: 56px;
        }

        .product-foot {
            margin-top: auto;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
        }

        .price {
            font-size: 22px;
            font-weight: 800;
            color: #0d5e8a;
        }

        .order-btn {
            border: 0;
            border-radius: 12px;
            padding: 10px 12px;
            cursor: pointer;
            font-weight: 800;
            font-size: 13px;
            color: #fff;
            background: linear-gradient(135deg, #0fa5a2, #1788b6);
            transition: transform 0.2s ease, box-shadow 0.2s ease, opacity 0.2s ease;
        }

        .order-btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 10px 20px rgba(11, 154, 157, 0.28);
        }

        .order-btn:disabled {
            cursor: not-allowed;
            opacity: 0.55;
            box-shadow: none;
        }

        .modal-overlay {
            position: fixed;
            inset: 0;
            background: rgba(4, 16, 30, 0.55);
            backdrop-filter: blur(2px);
            display: none;
            align-items: center;
            justify-content: center;
            padding: 16px;
            z-index: 2100;
        }

        .modal-overlay.show {
            display: flex;
        }

        .order-modal {
            width: min(760px, 100%);
            max-height: calc(100vh - 40px);
            overflow: auto;
            border-radius: 20px;
            border: 1px solid rgba(137, 156, 174, 0.34);
            background: rgba(255, 255, 255, 0.98);
            box-shadow: 0 24px 46px rgba(0, 0, 0, 0.24);
        }

        .order-head {
            padding: 16px 18px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
            border-bottom: 1px solid rgba(137, 156, 174, 0.26);
        }

        .order-head h2 {
            margin: 0;
            color: #174a78;
        }

        .order-close {
            width: 34px;
            height: 34px;
            border: 0;
            border-radius: 10px;
            background: rgba(239, 68, 68, 0.13);
            color: #c13f3f;
            cursor: pointer;
            font-size: 18px;
            font-weight: 700;
        }

        .order-form {
            padding: 16px 18px 20px;
            display: grid;
            gap: 12px;
        }

        .order-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 10px;
        }

        .order-grid .field.full-width {
            grid-column: 1 / -1;
        }

        .field {
            display: grid;
            gap: 6px;
        }

        .field.full {
            grid-column: 1 / -1;
        }

        .field label {
            font-size: 12px;
            font-weight: 700;
            color: #5a728b;
        }

        .field input,
        .field textarea {
            width: 100%;
            border: 1px solid rgba(137, 156, 174, 0.4);
            border-radius: 12px;
            background: #fff;
            padding: 10px 12px;
            font: inherit;
            color: #16324b;
            box-sizing: border-box;
        }

        .field input:focus,
        .field textarea:focus {
            outline: none;
            border-color: rgba(12, 158, 184, 0.55);
            box-shadow: 0 0 0 4px rgba(12, 158, 184, 0.13);
        }

        #orderMap {
            width: 100%;
            height: 260px;
            border-radius: 14px;
            border: 1px solid rgba(137, 156, 174, 0.34);
        }

        .map-hint {
            font-size: 12px;
            color: #5a728b;
        }

        .order-summary {
            border: 1px solid rgba(137, 156, 174, 0.34);
            border-radius: 14px;
            background: rgba(244, 251, 255, 0.95);
            padding: 10px 12px;
            display: grid;
            gap: 4px;
            font-size: 13px;
            color: #214a73;
        }

        .order-actions {
            display: flex;
            justify-content: flex-end;
            gap: 10px;
        }

        .btn {
            border: 0;
            border-radius: 12px;
            padding: 10px 14px;
            font-weight: 800;
            cursor: pointer;
        }

        .btn-cancel {
            background: rgba(22, 55, 86, 0.1);
            color: #224a72;
        }

        .btn-submit {
            color: #fff;
            background: linear-gradient(135deg, #0fa5a2, #1788b6);
        }

        .btn-submit:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }

        .empty-state {
            border: 1px dashed rgba(137, 156, 174, 0.44);
            border-radius: 16px;
            background: rgba(255, 255, 255, 0.75);
            padding: 28px;
            text-align: center;
            color: #56708a;
        }

        body.dark-mode .shop-page {
            background:
                radial-gradient(900px 420px at 0% 0%, rgba(45, 212, 191, 0.11), transparent 60%),
                radial-gradient(760px 360px at 100% 0%, rgba(56, 189, 248, 0.1), transparent 64%),
                linear-gradient(180deg, #0c1420 0%, #111b2a 100%);
            color: #d9e5f0;
        }

        body.dark-mode .product-card,
        body.dark-mode .order-modal {
            background: rgba(16, 24, 37, 0.98);
            border-color: rgba(74, 96, 121, 0.44);
            color: #d9e5f0;
        }

        body.dark-mode .product-name,
        body.dark-mode .order-head h2,
        body.dark-mode .price {
            color: #dcecfb;
        }

        body.dark-mode .product-desc,
        body.dark-mode .field label,
        body.dark-mode .map-hint,
        body.dark-mode .order-summary {
            color: #98acc0;
        }

        body.dark-mode .field input,
        body.dark-mode .field textarea {
            background: rgba(10, 18, 29, 0.86);
            border-color: rgba(74, 96, 121, 0.52);
            color: #eff7ff;
        }

        body.dark-mode .order-summary {
            background: rgba(12, 22, 35, 0.86);
            border-color: rgba(93, 116, 141, 0.58);
        }

        @media (max-width: 760px) {
            .shop-page {
                padding: 16px;
            }

            .order-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
{% endblock %}

{% block body %}
    <div class="shop-page">
        <div class="shop-shell">
            <div class="shop-head">
                <div>
                    <h1>{{ 'main.tab.shop'|trans }}</h1>
                    <p>Browse products and order with your coins.</p>
                </div>
                <div class="coins-pill">Available coins: <span id="availableCoinsText">{{ availableCoins }}</span></div>
            </div>

            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="shop-flash {{ label == 'success' ? 'success' : 'error' }}">{{ message }}</div>
                {% endfor %}
            {% endfor %}

            {% if products is empty %}
                <div class="empty-state">No products available yet.</div>
            {% else %}
                <div class="shop-grid">
                    {% for product in products %}
                        {% set canAfford = availableCoins >= product.price_coins and product.quantity > 0 %}
                        <article class="product-card">
                            <img class="product-image" src="{{ product.image_url }}" alt="{{ product.name }}">
                            <div class="product-body">
                                <h3 class="product-name">{{ product.name }}</h3>
                                <div class="product-meta">
                                    <span class="tag">{{ product.category|default('General') }}</span>
                                    <span class="tag">Stock: {{ product.quantity }}</span>
                                </div>
                                <div class="product-desc">{{ product.description|default('No description available.') }}</div>
                                <div class="product-foot">
                                    <div class="price">{{ product.price_coins }} coins</div>
                                    <button
                                        type="button"
                                        class="order-btn"
                                        data-product-id="{{ product.id }}"
                                        data-product-name="{{ product.name|e('html_attr') }}"
                                        data-product-price="{{ product.price_coins }}"
                                        data-product-stock="{{ product.quantity }}"
                                        {% if not canAfford %}disabled{% endif %}
                                    >Order</button>
                                </div>
                            </div>
                        </article>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    </div>

    <div id="orderModalOverlay" class="modal-overlay" aria-hidden="true">
        <div class="order-modal">
            <div class="order-head">
                <h2>Confirm Order</h2>
                <button id="orderCloseBtn" class="order-close" type="button" aria-label="Close">x</button>
            </div>

            <form class="order-form" method="post" action="{{ path('app_shop_order') }}" data-no-loader="true" data-turbo="false">
                <input type="hidden" name="_token" value="{{ csrf_token('shop-order') }}">
                <input id="orderProductId" type="hidden" name="product_id" value="">
                <input type="hidden" name="quantity" value="1">
                <input id="orderLocationLat" type="hidden" name="location_lat" value="">
                <input id="orderLocationLng" type="hidden" name="location_lng" value="">

                <div class="order-summary">
                    <strong id="orderProductName">Product</strong>
                    <span>Price: <span id="orderProductPrice">0</span> coins each</span>
                    <span>Total: <strong id="orderTotalCoins">0</strong> coins</span>
                </div>

                <div class="order-grid">
                    <div class="field">
                        <label for="orderBuyerName">Name</label>
                            <label for="orderFirstName">First Name</label>
                            <input id="orderFirstName" type="text" name="first_name" value="{{ defaultFirstName }}" required>
                    <div class="field">
                        <label for="orderBuyerEmail">Email</label>
                            <label for="orderLastName">Last Name</label>
                            <input id="orderLastName" type="text" name="last_name" value="{{ defaultLastName }}" required>
                    <div class="field">
                        <div class="field full-width">
                            <label for="orderBuyerEmail">Email</label>
                            <input id="orderBuyerEmail" type="email" name="buyer_email" value="{{ defaultBuyerEmail }}" required>
                    <div class="field">
                        <div class="field full-width">
                            <label for="orderBuyerPhone">Phone Number</label>
                            <input id="orderBuyerPhone" type="text" name="buyer_phone" value="{{ defaultBuyerPhone }}" required>
                    <div class="field full">
                        <label for="orderLocationText">Location (from map)</label>
                        <input id="orderLocationText" type="text" name="location_text" placeholder="Click on map to pick your location">
                    </div>
                    <div class="field full">
                        <div id="orderMap"></div>
                        <div class="map-hint">Pin your location on the map, then save the order.</div>
                    </div>
                </div>

                <div class="order-actions">
                    <button id="orderCancelBtn" class="btn btn-cancel" type="button">Cancel</button>
                    <button id="orderSubmitBtn" class="btn btn-submit" type="submit">Order Now</button>
                </div>
            </form>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://api.mapbox.com/mapbox-gl-js/v2.15.0/mapbox-gl.js"></script>
    <script>
        (function () {
            const availableCoins = Number('{{ availableCoins }}');
            const mapboxToken = '{{ mapboxToken|e('js') }}';
            const overlay = document.getElementById('orderModalOverlay');
            const closeBtn = document.getElementById('orderCloseBtn');
            const cancelBtn = document.getElementById('orderCancelBtn');
            const submitBtn = document.getElementById('orderSubmitBtn');
            const productIdInput = document.getElementById('orderProductId');
            const productNameText = document.getElementById('orderProductName');
            const productPriceText = document.getElementById('orderProductPrice');
            const totalCoinsText = document.getElementById('orderTotalCoins');
            const locationTextInput = document.getElementById('orderLocationText');
            const latInput = document.getElementById('orderLocationLat');
            const lngInput = document.getElementById('orderLocationLng');
            let currentPrice = 0;
            let map = null;
            let marker = null;

            function openModal() {
                overlay.classList.add('show');
                overlay.setAttribute('aria-hidden', 'false');
            }

            function closeModal() {
                overlay.classList.remove('show');
                overlay.setAttribute('aria-hidden', 'true');
            }

            function updateTotal() {
                const total = currentPrice;
                totalCoinsText.textContent = String(total);
                submitBtn.disabled = total > availableCoins;
            }

            function initMap() {
                if (map || !mapboxToken || typeof mapboxgl === 'undefined') {
                    return;
                }

                mapboxgl.accessToken = mapboxToken;
                map = new mapboxgl.Map({
                    container: 'orderMap',
                    style: 'mapbox://styles/mapbox/streets-v12',
                    center: [10.1815, 36.8065],
                    zoom: 10,
                });

                map.on('click', function (event) {
                    const lng = event.lngLat.lng;
                    const lat = event.lngLat.lat;

                    if (!marker) {
                        marker = new mapboxgl.Marker({ color: '#0fa5a2' }).setLngLat([lng, lat]).addTo(map);
                    } else {
                        marker.setLngLat([lng, lat]);
                    }

                    latInput.value = lat.toFixed(6);
                    lngInput.value = lng.toFixed(6);

                    fetch('https://api.mapbox.com/geocoding/v5/mapbox.places/' + lng + ',' + lat + '.json?access_token=' + mapboxToken)
                        .then((response) => response.ok ? response.json() : null)
                        .then((payload) => {
                            const place = payload && payload.features && payload.features[0] ? payload.features[0].place_name : '';
                            locationTextInput.value = place || (lat.toFixed(6) + ', ' + lng.toFixed(6));
                        })
                        .catch(() => {
                            locationTextInput.value = lat.toFixed(6) + ', ' + lng.toFixed(6);
                        });
                });
            }

            document.querySelectorAll('.order-btn').forEach((button) => {
                button.addEventListener('click', function () {
                    currentPrice = Number(button.dataset.productPrice || 0);

                    productIdInput.value = String(button.dataset.productId || '');
                    productNameText.textContent = String(button.dataset.productName || 'Product');
                    productPriceText.textContent = String(currentPrice);
                    latInput.value = '';
                    lngInput.value = '';
                    locationTextInput.value = '';
                    updateTotal();
                    openModal();
                    initMap();

                    setTimeout(function () {
                        if (map) {
                            map.resize();
                        }
                    }, 120);
                });
            });

            closeBtn.addEventListener('click', closeModal);
            cancelBtn.addEventListener('click', closeModal);
            overlay.addEventListener('click', function (event) {
                if (event.target === overlay) {
                    closeModal();
                }
            });

            if (!mapboxToken) {
                const mapHint = document.querySelector('.map-hint');
                if (mapHint) {
                    mapHint.textContent = 'Mapbox token is missing. Set MAPBOX_PUBLIC_TOKEN in your environment to enable map picking.';
                }
            }
        })();
    </script>
{% endblock %}
