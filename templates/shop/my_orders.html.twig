{% extends 'base.html.twig' %}

{% block title %}{{ 'main.menu.my_orders'|trans }} - Rehletna.tn{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .orders-page {
            min-height: 100vh;
            padding: 24px;
            background:
                radial-gradient(820px 360px at 0% 0%, rgba(12, 158, 184, 0.12), transparent 62%),
                radial-gradient(820px 360px at 100% 0%, rgba(19, 180, 138, 0.1), transparent 64%),
                linear-gradient(180deg, #f7fbff 0%, #edf4fa 100%);
            color: #16324b;
        }

        .orders-shell {
            max-width: 1120px;
            margin: 0 auto;
        }

        .orders-head {
            border-radius: 20px;
            padding: 18px 20px;
            background: linear-gradient(135deg, rgba(8, 97, 123, 0.96), rgba(14, 136, 161, 0.93));
            color: #fff;
            box-shadow: 0 16px 32px rgba(10, 52, 90, 0.18);
            margin-bottom: 14px;
            display: flex;
            justify-content: space-between;
            gap: 10px;
            align-items: center;
            flex-wrap: wrap;
        }

        .orders-head h1 {
            margin: 0;
            font-size: clamp(22px, 2.5vw, 30px);
        }

        .orders-head a {
            color: #fff;
            border: 1px solid rgba(255, 255, 255, 0.32);
            border-radius: 999px;
            width: 38px;
            height: 38px;
            text-decoration: none;
            font-weight: 700;
            background: rgba(255, 255, 255, 0.12);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            line-height: 1;
        }

        .orders-head a:hover {
            background: rgba(255, 255, 255, 0.2);
        }

        .orders-stats {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
            gap: 10px;
            margin-bottom: 14px;
        }

        .orders-stat {
            border-radius: 14px;
            border: 1px solid rgba(137, 156, 174, 0.24);
            background: rgba(255, 255, 255, 0.9);
            box-shadow: 0 10px 20px rgba(10, 34, 62, 0.06);
            padding: 12px 14px;
        }

        .orders-stat small {
            display: block;
            color: #5f7690;
            font-size: 11px;
            letter-spacing: 0.4px;
            text-transform: uppercase;
            font-weight: 800;
            margin-bottom: 4px;
        }

        .orders-stat strong {
            font-size: 20px;
            line-height: 1;
            color: #103b64;
        }

        .orders-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 12px;
        }

        .order-card {
            border: 1px solid rgba(137, 156, 174, 0.28);
            border-radius: 18px;
            background:
                radial-gradient(420px 180px at 100% 0%, rgba(12, 158, 184, 0.08), transparent 62%),
                rgba(255, 255, 255, 0.97);
            box-shadow: 0 12px 24px rgba(10, 34, 62, 0.08);
            padding: 14px;
            display: grid;
            gap: 12px;
        }

        .order-card-head {
            display: flex;
            justify-content: space-between;
            gap: 10px;
            align-items: flex-start;
        }

        .order-card-title {
            margin: 0;
            color: #113e68;
            font-size: 16px;
            line-height: 1.05;
        }

        .order-card-subtitle {
            color: #5b7591;
            font-size: 11px;
            margin-top: 4px;
        }

        .order-meta {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 8px;
        }

        .order-meta-item {
            border-radius: 12px;
            border: 1px solid rgba(137, 156, 174, 0.22);
            background: rgba(245, 250, 255, 0.9);
            padding: 10px;
            min-height: 62px;
        }

        .order-meta-item small {
            display: block;
            color: #65809b;
            font-size: 10px;
            text-transform: uppercase;
            font-weight: 800;
            letter-spacing: 0.4px;
            margin-bottom: 4px;
        }

        .order-meta-item strong {
            color: #163f66;
            font-size: 14px;
            line-height: 1.3;
            word-break: break-word;
        }

        .order-address {
            border-top: 1px dashed rgba(137, 156, 174, 0.42);
            padding-top: 10px;
            color: #4e6782;
            font-size: 13px;
            line-height: 1.45;
        }

        .order-address strong {
            color: #214a73;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.4px;
            display: block;
            margin-bottom: 5px;
        }

        .status {
            display: inline-block;
            border-radius: 999px;
            padding: 4px 10px;
            font-size: 11px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            border: 1px solid transparent;
        }

        .status.pending {
            background: rgba(251, 191, 36, 0.16);
            color: #a46a02;
            border-color: rgba(251, 191, 36, 0.28);
        }

        .status.confirmed {
            background: rgba(16, 185, 129, 0.14);
            color: #0f8f66;
            border-color: rgba(16, 185, 129, 0.26);
        }

        .status.cancelled {
            background: rgba(239, 68, 68, 0.13);
            color: #bd3e3e;
            border-color: rgba(239, 68, 68, 0.22);
        }

        .status.delivered {
            background: rgba(59, 130, 246, 0.13);
            color: #1d65b8;
            border-color: rgba(59, 130, 246, 0.26);
        }

        .empty-orders {
            border: 1px dashed rgba(137, 156, 174, 0.44);
            border-radius: 16px;
            background: rgba(255, 255, 255, 0.8);
            padding: 24px;
            text-align: center;
            color: #56708a;
        }

        body.dark-mode .orders-page {
            background:
                radial-gradient(900px 420px at 0% 0%, rgba(45, 212, 191, 0.11), transparent 60%),
                radial-gradient(760px 360px at 100% 0%, rgba(56, 189, 248, 0.1), transparent 64%),
                linear-gradient(180deg, #0c1420 0%, #111b2a 100%);
            color: #d9e5f0;
        }

        body.dark-mode .orders-stat,
        body.dark-mode .order-card,
        body.dark-mode .order-meta-item,
        body.dark-mode .empty-orders {
            background: rgba(16, 24, 37, 0.98);
            border-color: rgba(74, 96, 121, 0.44);
            color: #d9e5f0;
        }

        body.dark-mode .orders-stat small,
        body.dark-mode .order-card-subtitle,
        body.dark-mode .order-meta-item small,
        body.dark-mode .order-address {
            color: #9bb1c8;
        }

        body.dark-mode .orders-stat strong,
        body.dark-mode .order-card-title,
        body.dark-mode .order-meta-item strong,
        body.dark-mode .order-address strong {
            color: #dcecfb;
        }

        body.dark-mode .order-meta-item {
            background: rgba(11, 22, 36, 0.88);
            border-color: rgba(74, 96, 121, 0.5);
        }

        body.dark-mode .order-address {
            border-top-color: rgba(74, 96, 121, 0.52);
        }

        @media (max-width: 720px) {
            .order-meta {
                grid-template-columns: 1fr;
            }
        }
    </style>
{% endblock %}

{% block body %}
    <div class="orders-page">
        <div class="orders-shell">
            <div class="orders-head">
                <h1>{{ 'main.menu.my_orders'|trans }}</h1>
                <a
                    href="{{ path('app_mainpage', {'module': 'shop'}) }}"
                    data-no-loader="true"
                    data-turbo="false"
                    aria-label="{{ 'shop.close_history'|trans }}"
                    title="{{ 'shop.close_history'|trans }}"
                >x</a>
            </div>

            {% if orders is empty %}
                <div class="empty-orders">{{ 'shop.orders.empty'|trans }}</div>
            {% else %}
                {% set pendingCount = 0 %}
                {% set deliveredCount = 0 %}
                {% set totalCoinsSpent = 0 %}
                {% for order in orders %}
                    {% set statusCounter = (order.status|default('pending')|lower) %}
                    {% if statusCounter == 'pending' %}
                        {% set pendingCount = pendingCount + 1 %}
                    {% endif %}
                    {% if statusCounter == 'delivered' %}
                        {% set deliveredCount = deliveredCount + 1 %}
                    {% endif %}
                    {% set totalCoinsSpent = totalCoinsSpent + (order.total_coins|default(0)) %}
                {% endfor %}

                <div class="orders-stats">
                    <div class="orders-stat">
                        <small>{{ 'shop.orders.stats.total'|trans }}</small>
                        <strong>{{ orders|length }}</strong>
                    </div>
                    <div class="orders-stat">
                        <small>{{ 'shop.orders.stats.pending'|trans }}</small>
                        <strong>{{ pendingCount }}</strong>
                    </div>
                    <div class="orders-stat">
                        <small>{{ 'shop.orders.stats.delivered'|trans }}</small>
                        <strong>{{ deliveredCount }}</strong>
                    </div>
                    <div class="orders-stat">
                        <small>{{ 'shop.orders.stats.coins_spent'|trans }}</small>
                        <strong>{{ totalCoinsSpent }}</strong>
                    </div>
                </div>

                <div class="orders-grid">
                    {% for order in orders %}
                        {% set status = (order.status|default('pending')|lower) %}
                        <article class="order-card">
                            <div class="order-card-head">
                                <div>
                                    <h2 class="order-card-title">{{ order.product_name|default('shop.orders.fallback_item'|trans({'%id%': order.shop_id})) }}</h2>
                                    <div class="order-card-subtitle">{{ 'shop.orders.number_date'|trans({'%id%': order.id, '%date%': order.purchase_date}) }}</div>
                                </div>
                                <span class="status {{ status }}">{{ ('shop.orders.status.' ~ status)|trans }}</span>
                            </div>

                            <div class="order-meta">
                                <div class="order-meta-item">
                                    <small>{{ 'shop.orders.quantity'|trans }}</small>
                                    <strong>{{ order.quantity }}</strong>
                                </div>
                                <div class="order-meta-item">
                                    <small>{{ 'shop.orders.total_coins'|trans }}</small>
                                    <strong>{{ order.total_coins }}</strong>
                                </div>
                                <div class="order-meta-item">
                                    <small>{{ 'shop.orders.buyer_email'|trans }}</small>
                                    <strong>{{ order.buyer_email|default('-') }}</strong>
                                </div>
                            </div>

                            <div class="order-address">
                                <strong>{{ 'shop.orders.delivery_info'|trans }}</strong>
                                {{ order.buyer_address|default('shop.orders.no_address'|trans)|nl2br }}
                            </div>
                        </article>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    </div>
{% endblock %}
