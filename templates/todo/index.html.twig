{% extends 'base.html.twig' %}

{% block title %}{{ 'todo.page_title'|trans }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .todo-page {
            min-height: 100vh;
            background:
                radial-gradient(1000px 420px at 0% -10%, rgba(8, 154, 151, 0.17), transparent 60%),
                radial-gradient(900px 400px at 100% -5%, rgba(26, 79, 124, 0.14), transparent 58%),
                linear-gradient(180deg, #f4f9ff 0%, #eef5fb 100%);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: #213142;
            padding: 24px 18px 34px;
        }

        .todo-shell {
            max-width: 1180px;
            margin: 0 auto;
        }

        .todo-top {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 10px;
            margin-bottom: 18px;
            flex-wrap: wrap;
        }

        .todo-title h1 {
            margin: 0;
            color: #173f69;
            font-size: 34px;
            letter-spacing: -0.3px;
        }

        .todo-title p {
            margin: 6px 0 0;
            color: #5c7289;
        }

        .top-actions {
            display: flex;
            gap: 10px;
            align-items: center;
        }

        .btn-pill {
            border-radius: 999px;
            padding: 10px 15px;
            text-decoration: none;
            font-weight: 700;
            font-size: 14px;
            border: 1px solid transparent;
        }

        .btn-back {
            background: #ffffff;
            border-color: #d5dfe9;
            color: #36516f;
        }

        .btn-add {
            background: linear-gradient(135deg, #0BA4A1, #0f7ab0);
            color: #ffffff;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 12px;
            margin-bottom: 16px;
        }

        .stat-card {
            background: #ffffff;
            border: 1px solid #dfe8f0;
            border-radius: 12px;
            padding: 12px;
            box-shadow: 0 6px 16px rgba(9, 33, 60, 0.06);
        }

        .stat-label {
            font-size: 11px;
            text-transform: uppercase;
            color: #61788f;
            font-weight: 700;
            letter-spacing: 0.4px;
        }

        .stat-value {
            margin-top: 8px;
            font-size: 34px;
            line-height: 1;
            font-weight: 800;
            color: #173f69;
        }

        .board {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 14px;
        }

        .column {
            background: #ffffff;
            border-radius: 14px;
            border: 1px solid #dce7f1;
            box-shadow: 0 8px 20px rgba(9, 33, 60, 0.05);
            overflow: hidden;
        }

        .column-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px 14px;
            border-bottom: 1px solid #e6edf5;
            background: #f8fbff;
        }

        .column-title {
            font-weight: 800;
            font-size: 13px;
            text-transform: uppercase;
            color: #37526f;
            letter-spacing: 0.4px;
        }

        .count {
            border-radius: 999px;
            background: #eaf2fa;
            color: #4a6581;
            font-size: 12px;
            font-weight: 700;
            padding: 3px 10px;
        }

        .column-body {
            min-height: 360px;
            padding: 12px;
            transition: background 0.2s ease;
        }

        .column-body.over {
            background: #e9f8f6;
            outline: 2px dashed #0BA4A1;
            outline-offset: -7px;
        }

        .todo-card {
            background: #ffffff;
            border: 1px solid #dce7f1;
            border-radius: 11px;
            padding: 11px;
            margin-bottom: 10px;
            cursor: grab;
            box-shadow: 0 4px 12px rgba(10, 32, 58, 0.06);
        }

        .todo-card.dragging {
            opacity: 0.6;
            transform: rotate(1deg);
        }

        .todo-main {
            font-weight: 700;
            color: #1a3f68;
            margin-bottom: 6px;
            line-height: 1.3;
        }

        .todo-desc {
            margin-bottom: 8px;
            color: #5d7389;
            font-size: 12px;
        }

        .todo-meta {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 8px;
            margin-bottom: 8px;
            font-size: 11px;
            color: #607a94;
        }

        .priority {
            padding: 3px 8px;
            border-radius: 999px;
            font-size: 11px;
            font-weight: 700;
        }

        .priority.low {
            background: #def4eb;
            color: #0b8a62;
        }

        .priority.medium {
            background: #fff3cf;
            color: #ba7b00;
        }

        .priority.high {
            background: #ffe3e3;
            color: #c92f2f;
        }

        .todo-actions {
            display: flex;
            gap: 8px;
        }

        .todo-actions form {
            margin: 0;
        }

        .mini-btn {
            border: 1px solid #d4dce6;
            border-radius: 8px;
            padding: 6px 9px;
            font-size: 11px;
            font-weight: 700;
            background: #f8fbff;
            color: #43607d;
            cursor: pointer;
        }

        .mini-btn.delete {
            border-color: #ffd7d7;
            background: #fff4f4;
            color: #d44747;
        }

        .todo-empty {
            color: #7d8fa2;
            font-size: 12px;
            text-align: center;
            padding-top: 24px;
        }

        .board-status {
            min-height: 22px;
            margin-top: 12px;
            font-size: 12px;
            font-weight: 700;
            color: #48617b;
        }

        @media (max-width: 960px) {
            .stats-grid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }

            .board {
                grid-template-columns: 1fr;
            }
        }
    </style>
{% endblock %}

{% block body %}
<div class="todo-page">
    <div class="todo-shell">
        <div class="todo-top">
            <div class="todo-title">
                <h1>{{ 'todo.board_title'|trans }}</h1>
                <p>{{ 'todo.board_subtitle'|trans }}</p>
            </div>
            <div class="top-actions">
                <a href="{{ path('app_mainpage') }}" class="btn-pill btn-back">{{ 'todo.back_main'|trans }}</a>
                <a href="{{ path('app_todo_new') }}" class="btn-pill btn-add">{{ 'todo.add_todo'|trans }}</a>
            </div>
        </div>

        {% set total = todos|length + completed_todos|length %}
        {% set completionRate = total > 0 ? ((completed_todos|length / total) * 100)|number_format(0) : 0 %}

        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-label">{{ 'todo.stats.total_tasks'|trans }}</div>
                <div class="stat-value" id="totalTasksStat">{{ total }}</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">{{ 'todo.stats.active'|trans }}</div>
                <div class="stat-value" id="activeTasksStat">{{ todos|length }}</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">{{ 'todo.stats.done'|trans }}</div>
                <div class="stat-value" id="doneTasksStat">{{ completed_todos|length }}</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">{{ 'todo.stats.completion'|trans }}</div>
                <div class="stat-value" id="completionRateStat">{{ completionRate }}%</div>
            </div>
        </div>

        <div class="board">
            <section class="column">
                <div class="column-header">
                    <span class="column-title">{{ 'todo.column.active'|trans }}</span>
                    <span class="count" id="activeCount">{{ todos|length }}</span>
                </div>
                <div class="column-body dropzone" data-state="active">
                    {% for todo in todos %}
                        <article class="todo-card" draggable="true" data-todo-id="{{ todo.id }}" data-url="{{ path('app_todo_state_update', {'id': todo.id}) }}" data-token="{{ csrf_token('todo-state-' ~ todo.id) }}">
                            <div class="todo-main">{{ todo.title }}</div>
                            {% if todo.description %}
                                <div class="todo-desc">{{ todo.description|slice(0, 120) }}{% if todo.description|length > 120 %}...{% endif %}</div>
                            {% endif %}
                            <div class="todo-meta">
                                {% if todo.dueDate %}
                                    <span>{{ 'todo.due'|trans }}: {{ todo.dueDate|date('Y-m-d H:i') }}</span>
                                {% else %}
                                    <span>{{ 'todo.no_deadline'|trans }}</span>
                                {% endif %}
                                {% if todo.priority == 2 %}
                                    <span class="priority high">{{ 'todo.priority.high'|trans }}</span>
                                {% elseif todo.priority == 1 %}
                                    <span class="priority medium">{{ 'todo.priority.medium'|trans }}</span>
                                {% else %}
                                    <span class="priority low">{{ 'todo.priority.low'|trans }}</span>
                                {% endif %}
                            </div>
                            <div class="todo-actions">
                                <form method="post" action="{{ path('app_todo_complete', {'id': todo.id}) }}">
                                    <button type="submit" class="mini-btn">{{ 'todo.complete'|trans }}</button>
                                </form>
                                <form method="post" action="{{ path('app_todo_delete', {'id': todo.id}) }}" onsubmit="return confirm('{{ 'todo.delete_confirm'|trans|e('js') }}');">
                                    <button type="submit" class="mini-btn delete">{{ 'todo.delete'|trans }}</button>
                                </form>
                            </div>
                        </article>
                    {% else %}
                        <div class="todo-empty">{{ 'todo.empty.active'|trans }}</div>
                    {% endfor %}
                </div>
            </section>

            <section class="column">
                <div class="column-header">
                    <span class="column-title">{{ 'todo.column.done'|trans }}</span>
                    <span class="count" id="doneCount">{{ completed_todos|length }}</span>
                </div>
                <div class="column-body dropzone" data-state="done">
                    {% for todo in completed_todos %}
                        <article class="todo-card" draggable="true" data-todo-id="{{ todo.id }}" data-url="{{ path('app_todo_state_update', {'id': todo.id}) }}" data-token="{{ csrf_token('todo-state-' ~ todo.id) }}">
                            <div class="todo-main">{{ todo.title }}</div>
                            <div class="todo-meta">
                                <span>{{ 'todo.completed'|trans }}: {{ todo.completedAt|date('Y-m-d H:i') }}</span>
                                <span class="priority low">{{ 'todo.column.done'|trans }}</span>
                            </div>
                            <div class="todo-actions">
                                <form method="post" action="{{ path('app_todo_delete', {'id': todo.id}) }}" onsubmit="return confirm('{{ 'todo.delete_confirm'|trans|e('js') }}');">
                                    <button type="submit" class="mini-btn delete">{{ 'todo.delete'|trans }}</button>
                                </form>
                            </div>
                        </article>
                    {% else %}
                        <div class="todo-empty">{{ 'todo.empty.done'|trans }}</div>
                    {% endfor %}
                </div>
            </section>
        </div>

        <div class="board-status" id="boardStatus"></div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        (function () {
            const zones = Array.from(document.querySelectorAll('.dropzone'));
            const statusEl = document.getElementById('boardStatus');
            const text = {
                updating: '{{ 'todo.status.updating'|trans|e('js') }}',
                movedDone: '{{ 'todo.status.moved_done'|trans|e('js') }}',
                movedActive: '{{ 'todo.status.moved_active'|trans|e('js') }}',
                couldNotMove: '{{ 'todo.status.could_not_move'|trans|e('js') }}',
                networkError: '{{ 'todo.status.network_error'|trans|e('js') }}'
            };
            let draggedCard = null;

            function showStatus(message, isError) {
                if (!statusEl) {
                    return;
                }
                statusEl.textContent = message;
                statusEl.style.color = isError ? '#c92f2f' : '#48617b';
            }

            function updateStats() {
                const active = document.querySelectorAll('.dropzone[data-state="active"] .todo-card').length;
                const done = document.querySelectorAll('.dropzone[data-state="done"] .todo-card').length;
                const total = active + done;
                const completion = total > 0 ? Math.round((done / total) * 100) : 0;

                const activeCount = document.getElementById('activeCount');
                const doneCount = document.getElementById('doneCount');
                const totalStat = document.getElementById('totalTasksStat');
                const activeStat = document.getElementById('activeTasksStat');
                const doneStat = document.getElementById('doneTasksStat');
                const completionStat = document.getElementById('completionRateStat');

                if (activeCount) activeCount.textContent = String(active);
                if (doneCount) doneCount.textContent = String(done);
                if (totalStat) totalStat.textContent = String(total);
                if (activeStat) activeStat.textContent = String(active);
                if (doneStat) doneStat.textContent = String(done);
                if (completionStat) completionStat.textContent = completion + '%';
            }

            function attachCardEvents(card) {
                card.addEventListener('dragstart', function () {
                    draggedCard = card;
                    card.classList.add('dragging');
                });

                card.addEventListener('dragend', function () {
                    card.classList.remove('dragging');
                    draggedCard = null;
                });
            }

            document.querySelectorAll('.todo-card').forEach(attachCardEvents);

            zones.forEach(function (zone) {
                zone.addEventListener('dragover', function (event) {
                    event.preventDefault();
                    zone.classList.add('over');
                });

                zone.addEventListener('dragleave', function () {
                    zone.classList.remove('over');
                });

                zone.addEventListener('drop', function (event) {
                    event.preventDefault();
                    zone.classList.remove('over');
                    if (!draggedCard) {
                        return;
                    }

                    const oldZone = draggedCard.closest('.dropzone');
                    const newState = zone.getAttribute('data-state');
                    const oldState = oldZone ? oldZone.getAttribute('data-state') : null;
                    if (!newState || !oldState || oldState === newState) {
                        return;
                    }

                    const url = draggedCard.getAttribute('data-url');
                    const token = draggedCard.getAttribute('data-token');
                    const todoId = draggedCard.getAttribute('data-todo-id');
                    if (!url || !token || !todoId) {
                        return;
                    }

                    zone.appendChild(draggedCard);
                    updateStats();
                    showStatus(text.updating.replace('%id%', todoId), false);

                    const body = new URLSearchParams();
                    body.set('state', newState);
                    body.set('_token', token);

                    fetch(url, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8'
                        },
                        body: body.toString()
                    })
                        .then(function (response) {
                            return response.json();
                        })
                        .then(function (data) {
                            if (data && data.success) {
                                showStatus(newState === 'done'
                                    ? text.movedDone.replace('%id%', todoId)
                                    : text.movedActive.replace('%id%', todoId), false);
                                return;
                            }

                            if (oldZone) {
                                oldZone.appendChild(draggedCard);
                            }
                            updateStats();
                            showStatus(text.couldNotMove.replace('%id%', todoId), true);
                        })
                        .catch(function () {
                            if (oldZone) {
                                oldZone.appendChild(draggedCard);
                            }
                            updateStats();
                            showStatus(text.networkError.replace('%id%', todoId), true);
                        });
                });
            });
        })();
    </script>
{% endblock %}